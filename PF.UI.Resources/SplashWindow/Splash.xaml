<pf:Window
    x:Class="PF.UI.Resources.Splash"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:PF.UI.Resources"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    Icon="/PF.UI.Resources;component/Images/ICO/-pfico.ico"
    Title="Splash"
    Width="900"
    Height="500"
    DataContext="{Binding RelativeSource={RelativeSource Mode=Self}}"
    Loaded="Window_Loaded"
    WindowStartupLocation="CenterScreen"
    WindowStyle="None"
    mc:Ignorable="d">

    <pf:Window.Resources>
        <local:MessageTypeToBrushConverter x:Key="MessageTypeToBrushConverter"></local:MessageTypeToBrushConverter>
    </pf:Window.Resources>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="148*" />
            <RowDefinition Height="20*" />
            <RowDefinition Height="17*" />
        </Grid.RowDefinitions>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="147*" />
                <RowDefinition Height="60*" />
                <RowDefinition Height="128*" />
                <RowDefinition Height="65*" />
            </Grid.RowDefinitions>
            <Image
                Width="900"
                Height="115"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Source="/PF.UI.Resources;component/Images/PNG/聚力LOGO.png" />
            <TextBlock
                Grid.Row="2"
                Width="0"
                Height="15"
                Margin="0,5,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Foreground="{DynamicResource PrimaryBrush}" />
            <TextBlock
                Grid.Row="2"
                Width="900"
                Height="38"
                Margin="0,9,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                FontSize="30"
                Foreground="White"
                Text="{Binding WelcomeText}"
                TextAlignment="Center" />
            <TextBlock
                Grid.Row="2"
                Width="900"
                Height="38"
                Margin="0,45,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                FontSize="30"
                Foreground="White"
                Text="{Binding VersionNumber}"
                TextAlignment="Center" />
            <TextBlock
                Grid.Row="2"
                Width="900"
                Height="14"
                Margin="0,80,0,0"
                HorizontalAlignment="Center"
                VerticalAlignment="Top"
                Foreground="White"
                Text="{Binding WelcomeText_small}"
                TextAlignment="Center" />
        </Grid>

        <TextBlock
            x:Name="showInfo"
            Grid.Row="1"
            Margin="3"
            HorizontalAlignment="Center"
            VerticalAlignment="Bottom"
            FontSize="20"
            Foreground="{Binding MessageType, Converter={StaticResource MessageTypeToBrushConverter}}"
            Text="{Binding Messageinfo}" />
        <pf:LoadingLine
            Grid.Row="2"
            DotCount="8"
            DotDiameter="12"
            DotSpeed="2"
            Foreground="{DynamicResource PrimaryBrush}"
            Style="{StaticResource LoadingLineLarge}" />
    </Grid>

</pf:Window>
