<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pfcontrol="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls">

    <Style BasedOn="{StaticResource SearchComboBoxBaseStyle}" TargetType="pfcontrol:SearchComboBox" />

    <Style
        x:Key="SearchComboBoxItem.Small"
        BasedOn="{StaticResource SearchComboBoxItemBaseStyle}"
        TargetType="pfcontrol:SearchComboBoxItem">
        <Setter Property="Padding" Value="6,0" />
        <Setter Property="MinHeight" Value="20" />
    </Style>

    <Style
        x:Key="SearchComboBox.Small"
        BasedOn="{StaticResource SearchComboBoxBaseStyle}"
        TargetType="pfcontrol:SearchComboBox">
        <Setter Property="ItemContainerStyle" Value="{StaticResource SearchComboBoxItem.Small}" />
        <Setter Property="MinHeight" Value="20" />
        <Setter Property="Padding" Value="6,2" />
    </Style>

</ResourceDictionary>
