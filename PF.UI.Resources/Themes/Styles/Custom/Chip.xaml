<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls">

    <!-- 默认（Filled，浅灰底） -->
    <Style TargetType="{x:Type pf:Chip}" BasedOn="{StaticResource ChipBaseStyle}" />

    <!-- 主色 Filled -->
    <Style x:Key="ChipPrimary" TargetType="{x:Type pf:Chip}" BasedOn="{StaticResource ChipBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="White" />
    </Style>

    <!-- 成功 Filled -->
    <Style x:Key="ChipSuccess" TargetType="{x:Type pf:Chip}" BasedOn="{StaticResource ChipBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource LightSuccessBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource DarkSuccessBrush}" />
    </Style>

    <!-- 危险 Filled -->
    <Style x:Key="ChipDanger" TargetType="{x:Type pf:Chip}" BasedOn="{StaticResource ChipBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource LightDangerBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource DarkDangerBrush}" />
    </Style>

    <!-- 警告 Filled -->
    <Style x:Key="ChipWarning" TargetType="{x:Type pf:Chip}" BasedOn="{StaticResource ChipBaseStyle}">
        <Setter Property="Background" Value="{DynamicResource LightWarningBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource DarkWarningBrush}" />
    </Style>

    <!-- 描边（Outlined） -->
    <Style x:Key="ChipOutlined" TargetType="{x:Type pf:Chip}" BasedOn="{StaticResource ChipOutlinedBaseStyle}" />

    <!-- 主色描边 -->
    <Style x:Key="ChipOutlinedPrimary" TargetType="{x:Type pf:Chip}" BasedOn="{StaticResource ChipOutlinedBaseStyle}">
        <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}" />
    </Style>

</ResourceDictionary>
