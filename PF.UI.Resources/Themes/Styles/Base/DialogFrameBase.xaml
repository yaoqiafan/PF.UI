<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls">

    <Style x:Key="DialogFrameBaseStyle" TargetType="{x:Type pf:DialogFrame}">
        <Setter Property="Background" Value="{DynamicResource BackgroundBrush}" />
        <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}" />
        <Setter Property="IconBackground" Value="{DynamicResource PrimaryBrush}" />
        <Setter Property="IconForeground" Value="White" />
        <Setter Property="MinWidth" Value="360" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type pf:DialogFrame}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <!-- 头部：图标 + 标题 -->
                                <RowDefinition Height="Auto" />
                                <!-- 内容区 -->
                                <RowDefinition Height="*" />
                                <!-- 脚部：按钮 -->
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- ── 头部 ── -->
                            <Border Grid.Row="0"
                                    Background="{DynamicResource RegionBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="20,14,20,14">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">

                                    <!-- 圆形图标 -->
                                    <Border Width="34" Height="34" CornerRadius="17"
                                            Background="{TemplateBinding IconBackground}"
                                            Margin="0,0,12,0"
                                            Visibility="{TemplateBinding ShowIcon,
                                                Converter={StaticResource Boolean2VisibilityConverter}}">
                                        <pf:PackIcon Kind="{TemplateBinding IconKind}"
                                                     Width="18" Height="18"
                                                     HorizontalAlignment="Center"
                                                     VerticalAlignment="Center"
                                                     Foreground="{TemplateBinding IconForeground}" />
                                    </Border>

                                    <!-- 标题文字 -->
                                    <TextBlock Text="{TemplateBinding Header}"
                                               FontSize="15" FontWeight="SemiBold"
                                               VerticalAlignment="Center"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                </StackPanel>
                            </Border>

                            <!-- ── 内容区 ── -->
                            <ContentPresenter Grid.Row="1"
                                              Margin="{TemplateBinding Padding}"
                                              Content="{TemplateBinding Content}"
                                              ContentTemplate="{TemplateBinding ContentTemplate}"
                                              ContentStringFormat="{TemplateBinding ContentStringFormat}" />

                            <!-- ── 脚部 ── -->
                            <Border Grid.Row="2"
                                    Background="{DynamicResource RegionBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="20,10"
                                    Visibility="{TemplateBinding ShowFooter,
                                        Converter={StaticResource Boolean2VisibilityConverter}}">
                                <ContentPresenter Content="{TemplateBinding FooterContent}"
                                                  HorizontalAlignment="Right" />
                            </Border>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
