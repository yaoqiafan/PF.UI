<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:pfcontrol="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls">

    <Style x:Key="ImageViewerBaseStyle" TargetType="pfcontrol:ImageViewer">
        <Setter Property="Focusable" Value="False" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="pfcontrol:ImageViewer">
                    <Border BorderThickness="{TemplateBinding BorderThickness}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            Background="{TemplateBinding Background}">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Main image canvas -->
                            <pfcontrol:SimplePanel x:Name="PART_PanelMain" ClipToBounds="True" Grid.RowSpan="2">
                                <Border HorizontalAlignment="Left" VerticalAlignment="Top"
                                        Height="{TemplateBinding ImageHeight}"
                                        Width="{TemplateBinding ImageWidth}"
                                        Margin="{TemplateBinding ImageMargin}">
                                    <Image Name="PART_ImageMain"
                                           RenderOptions.BitmapScalingMode="HighQuality"
                                           RenderTransformOrigin="0.5,0.5"
                                           Source="{TemplateBinding ImageSource}" />
                                </Border>

                                <!-- Tip content overlay -->
                                <Border x:Name="PART_TipOverlay"
                                        Visibility="{Binding Path=(pfcontrol:TipElement.Visibility), RelativeSource={RelativeSource TemplatedParent}}"
                                        Background="{DynamicResource DarkOpacityBrush}"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        CornerRadius="4" Padding="8,5" Margin="8"
                                        HorizontalAlignment="Left" VerticalAlignment="Bottom"
                                        IsHitTestVisible="False" MaxWidth="320">
                                    <ContentPresenter
                                        Content="{Binding Path=(pfcontrol:TipElement.Content), RelativeSource={RelativeSource TemplatedParent}}"
                                        TextElement.Foreground="{DynamicResource TextIconBrush}"
                                        TextElement.FontSize="12" />
                                </Border>
                            </pfcontrol:SimplePanel>

                            <!-- Mini-map (right-bottom overview) -->
                            <Border Grid.Row="0" Grid.RowSpan="2"
                                    Width="252" Height="162"
                                    HorizontalAlignment="Right" VerticalAlignment="Bottom"
                                    Background="{DynamicResource DarkOpacityBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}"
                                    BorderThickness="1">
                                <Border.Visibility>
                                    <MultiBinding Converter="{StaticResource BooleanArr2VisibilityConverter}">
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="ShowSmallImgInternal" />
                                        <Binding RelativeSource="{RelativeSource TemplatedParent}" Path="ShowImgMap" />
                                    </MultiBinding>
                                </Border.Visibility>
                                <Canvas ClipToBounds="True" Name="PART_CanvasSmallImg" MaxWidth="250" MaxHeight="160">
                                    <Border UseLayoutRounding="True" Name="PART_BorderMove"
                                            Background="Transparent"
                                            Width="50" Height="70"
                                            BorderThickness="1" BorderBrush="Black">
                                        <Border BorderThickness="1" BorderBrush="White" />
                                    </Border>
                                </Canvas>
                            </Border>

                            <!-- Toolbar (bottom, hover-reveal) -->
                            <Border UseLayoutRounding="True" Name="PART_BorderBottom"
                                    Visibility="{TemplateBinding ShowToolBar, Converter={StaticResource Boolean2VisibilityConverter}}"
                                    Opacity="0" CornerRadius="4,4,0,0"
                                    Grid.Row="1" HorizontalAlignment="Center"
                                    Background="{DynamicResource DarkOpacityBrush}">
                                <StackPanel Margin="16,6" VerticalAlignment="Center" Orientation="Horizontal">
                                    <!-- Save -->
                                    <Button Command="pfcontrol:ControlCommands.Save"
                                            Width="28" Height="28" Margin="2,0"
                                            Foreground="{DynamicResource TextIconBrush}"
                                            Style="{StaticResource ButtonIcon}"
                                            pfcontrol:IconElement.Geometry="{StaticResource SaveGeometry}"
                                            pfcontrol:IconElement.Width="16"
                                            pfcontrol:IconElement.Height="16"
                                            Padding="4" />
                                    <!-- Open in OS -->
                                    <Button Command="pfcontrol:ControlCommands.Open"
                                            Width="28" Height="28" Margin="2,0"
                                            Foreground="{DynamicResource TextIconBrush}"
                                            Style="{StaticResource ButtonIcon}"
                                            pfcontrol:IconElement.Geometry="{StaticResource WindowsGeometry}"
                                            pfcontrol:IconElement.Width="16"
                                            pfcontrol:IconElement.Height="16"
                                            Padding="4" />

                                    <Border Margin="6,4" Background="{DynamicResource ThirdlyTextBrush}"
                                            Style="{StaticResource BorderVerticallySplitter}" />

                                    <!-- Reduce -->
                                    <Button Command="pfcontrol:ControlCommands.Reduce"
                                            Width="28" Height="28" Margin="2,0"
                                            Foreground="{DynamicResource TextIconBrush}"
                                            Style="{StaticResource ButtonIcon}"
                                            pfcontrol:IconElement.Geometry="{StaticResource ReduceGeometry}"
                                            pfcontrol:IconElement.Width="16"
                                            pfcontrol:IconElement.Height="16"
                                            Padding="4" />
                                    <!-- Scale label -->
                                    <TextBlock Margin="4,0" VerticalAlignment="Center" FontSize="11"
                                               Text="{TemplateBinding ScaleStr}"
                                               Foreground="{DynamicResource TextIconBrush}" />
                                    <!-- Enlarge -->
                                    <Button Command="pfcontrol:ControlCommands.Enlarge"
                                            Width="28" Height="28" Margin="2,0"
                                            Foreground="{DynamicResource TextIconBrush}"
                                            Style="{StaticResource ButtonIcon}"
                                            pfcontrol:IconElement.Geometry="{StaticResource EnlargeGeometry}"
                                            pfcontrol:IconElement.Width="16"
                                            pfcontrol:IconElement.Height="16"
                                            Padding="4" />
                                    <!-- 1:1 -->
                                    <Button Command="pfcontrol:ControlCommands.Restore"
                                            Height="28" Margin="2,0"
                                            Background="Transparent"
                                            Style="{StaticResource ButtonCustom}"
                                            Foreground="{DynamicResource TextIconBrush}">
                                        <Border BorderThickness="1" BorderBrush="White" Padding="3,1">
                                            <TextBlock Text="1:1" FontSize="11" Foreground="{DynamicResource TextIconBrush}" />
                                        </Border>
                                    </Button>

                                    <Border Margin="6,4" Background="{DynamicResource ThirdlyTextBrush}"
                                            Style="{StaticResource BorderVerticallySplitter}" />

                                    <!-- Rotate left -->
                                    <Button Command="pfcontrol:ControlCommands.RotateLeft"
                                            Width="28" Height="28" Margin="2,0"
                                            Foreground="{DynamicResource TextIconBrush}"
                                            Style="{StaticResource ButtonIcon}"
                                            pfcontrol:IconElement.Geometry="{StaticResource RotateLeftGeometry}"
                                            pfcontrol:IconElement.Width="16"
                                            pfcontrol:IconElement.Height="16"
                                            Padding="4" />
                                    <!-- Rotate right -->
                                    <Button Command="pfcontrol:ControlCommands.RotateRight"
                                            Width="28" Height="28" Margin="2,0"
                                            Foreground="{DynamicResource TextIconBrush}"
                                            Style="{StaticResource ButtonIcon}"
                                            pfcontrol:IconElement.Geometry="{StaticResource RotateRightGeometry}"
                                            pfcontrol:IconElement.Width="16"
                                            pfcontrol:IconElement.Height="16"
                                            Padding="4" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- TipPlacement → alignment mapping for PART_TipOverlay -->
                        <Trigger Property="pfcontrol:TipElement.Placement" Value="LeftTop">
                            <Setter TargetName="PART_TipOverlay" Property="HorizontalAlignment" Value="Left" />
                            <Setter TargetName="PART_TipOverlay" Property="VerticalAlignment" Value="Top" />
                        </Trigger>
                        <Trigger Property="pfcontrol:TipElement.Placement" Value="Left">
                            <Setter TargetName="PART_TipOverlay" Property="HorizontalAlignment" Value="Left" />
                            <Setter TargetName="PART_TipOverlay" Property="VerticalAlignment" Value="Center" />
                        </Trigger>
                        <Trigger Property="pfcontrol:TipElement.Placement" Value="LeftBottom">
                            <Setter TargetName="PART_TipOverlay" Property="HorizontalAlignment" Value="Left" />
                            <Setter TargetName="PART_TipOverlay" Property="VerticalAlignment" Value="Bottom" />
                        </Trigger>
                        <Trigger Property="pfcontrol:TipElement.Placement" Value="TopLeft">
                            <Setter TargetName="PART_TipOverlay" Property="HorizontalAlignment" Value="Left" />
                            <Setter TargetName="PART_TipOverlay" Property="VerticalAlignment" Value="Top" />
                        </Trigger>
                        <Trigger Property="pfcontrol:TipElement.Placement" Value="Top">
                            <Setter TargetName="PART_TipOverlay" Property="HorizontalAlignment" Value="Center" />
                            <Setter TargetName="PART_TipOverlay" Property="VerticalAlignment" Value="Top" />
                        </Trigger>
                        <Trigger Property="pfcontrol:TipElement.Placement" Value="TopRight">
                            <Setter TargetName="PART_TipOverlay" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="PART_TipOverlay" Property="VerticalAlignment" Value="Top" />
                        </Trigger>
                        <Trigger Property="pfcontrol:TipElement.Placement" Value="RightTop">
                            <Setter TargetName="PART_TipOverlay" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="PART_TipOverlay" Property="VerticalAlignment" Value="Top" />
                        </Trigger>
                        <Trigger Property="pfcontrol:TipElement.Placement" Value="Right">
                            <Setter TargetName="PART_TipOverlay" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="PART_TipOverlay" Property="VerticalAlignment" Value="Center" />
                        </Trigger>
                        <Trigger Property="pfcontrol:TipElement.Placement" Value="RightBottom">
                            <Setter TargetName="PART_TipOverlay" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="PART_TipOverlay" Property="VerticalAlignment" Value="Bottom" />
                        </Trigger>
                        <Trigger Property="pfcontrol:TipElement.Placement" Value="BottomLeft">
                            <Setter TargetName="PART_TipOverlay" Property="HorizontalAlignment" Value="Left" />
                            <Setter TargetName="PART_TipOverlay" Property="VerticalAlignment" Value="Bottom" />
                        </Trigger>
                        <Trigger Property="pfcontrol:TipElement.Placement" Value="Bottom">
                            <Setter TargetName="PART_TipOverlay" Property="HorizontalAlignment" Value="Center" />
                            <Setter TargetName="PART_TipOverlay" Property="VerticalAlignment" Value="Bottom" />
                        </Trigger>
                        <Trigger Property="pfcontrol:TipElement.Placement" Value="BottomRight">
                            <Setter TargetName="PART_TipOverlay" Property="HorizontalAlignment" Value="Right" />
                            <Setter TargetName="PART_TipOverlay" Property="VerticalAlignment" Value="Bottom" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
