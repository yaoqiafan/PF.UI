<UserControl x:Class="PF.UI.Controls.SidebarNavView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:models="clr-namespace:PF.UI.Models"
             x:Name="Root">

    <UserControl.Resources>
        <Style x:Key="ChildItemStyle" TargetType="ListBoxItem">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,1" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ListBoxItem">
                        <Border x:Name="Bd" CornerRadius="6" Padding="10,8"
                                Background="{TemplateBinding Background}"
                                ClipToBounds="True">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource LightPrimaryBrush}" />
                            </Trigger>
                            <MultiTrigger>
                                <MultiTrigger.Conditions>
                                    <Condition Property="IsMouseOver" Value="True" />
                                    <Condition Property="IsSelected" Value="False" />
                                </MultiTrigger.Conditions>
                                <Setter TargetName="Bd" Property="Background"
                                        Value="{DynamicResource SecondaryRegionBrush}" />
                            </MultiTrigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsVisible}" Value="False">
                    <Setter Property="Visibility" Value="Collapsed" />
                    <Setter Property="IsEnabled" Value="False" />
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  Padding="8,6">
        <ItemsControl x:Name="GroupsControl"
                      ItemsSource="{Binding ElementName=Root, Path=Groups}">
            <ItemsControl.ItemTemplate>
                <DataTemplate DataType="{x:Type models:NavGroup}">
                    <StackPanel Margin="0,0,0,2"
                                Visibility="{Binding IsVisible,
                                    Converter={StaticResource Boolean2VisibilityConverter}}">

                        <!-- 分组头 -->
                        <Border Padding="8,6" CornerRadius="6"
                                Cursor="Hand"
                                Background="Transparent"
                                MouseLeftButtonDown="GroupHeader_Click">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>

                                <Border Grid.Column="0" Width="26" Height="26" CornerRadius="6"
                                        Background="{DynamicResource SecondaryRegionBrush}">
                                    <pf:PackIcon Kind="{Binding Icon}"
                                                 Width="15" Height="15"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center"
                                                 Foreground="{DynamicResource SecondaryTextBrush}" />
                                </Border>

                                <TextBlock Grid.Column="1" Text="{Binding Title}"
                                           FontSize="12.5" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}"
                                           Margin="8,0,0,0" VerticalAlignment="Center" />

                                <pf:PackIcon Grid.Column="2" Kind="MenuRight"
                                             Width="12" Height="12"
                                             VerticalAlignment="Center"
                                             Foreground="{DynamicResource ThirdlyTextBrush}">
                                    <pf:PackIcon.Style>
                                        <Style TargetType="pf:PackIcon">
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                    <Setter Property="RenderTransform">
                                                        <Setter.Value>
                                                            <RotateTransform Angle="90" />
                                                        </Setter.Value>
                                                    </Setter>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </pf:PackIcon.Style>
                                </pf:PackIcon>
                            </Grid>
                        </Border>

                        <!-- 子项列表 -->
                        <ListBox ItemsSource="{Binding Children}"
                                 SelectionChanged="ChildListBox_SelectionChanged"
                                 ItemContainerStyle="{StaticResource ChildItemStyle}"
                                 Background="Transparent" BorderThickness="0"
                                 Margin="8,2,0,4">
                            <ListBox.Style>
                                <Style TargetType="ListBox">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ListBox.Style>
                            <ListBox.ItemTemplate>
                                <DataTemplate DataType="{x:Type models:NavItem}">
                                    <Grid Visibility="{Binding IsVisible,
                                          Converter={StaticResource Boolean2VisibilityConverter}}">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Border Grid.Column="0" Width="28" Height="28" CornerRadius="5"
                                                Background="{DynamicResource SecondaryRegionBrush}">
                                            <pf:PackIcon Kind="{Binding Icon}"
                                                         Width="16" Height="16"
                                                         HorizontalAlignment="Center"
                                                         VerticalAlignment="Center"
                                                         Foreground="{DynamicResource PrimaryBrush}" />
                                        </Border>
                                        <StackPanel Grid.Column="1" VerticalAlignment="Center"
                                                    Margin="8,0,0,0">
                                            <TextBlock Text="{Binding Title}"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Description}"
                                                       FontSize="9.5"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>
