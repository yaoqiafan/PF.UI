<UserControl
    x:Class="PF.UI.Controls.DemoCodeBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    x:Name="Root">

    <UserControl.Resources>
        <!--  代码区 DataTemplate：仅首次展开时实例化  -->
        <DataTemplate x:Key="CodeAreaTemplate">
            <ScrollViewer
                MaxHeight="300"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  行号：TextBlock，无需交互  -->
                    <TextBlock
                        Grid.Column="0"
                        Width="30"
                        Margin="0,0,10,0"
                        FontFamily="Consolas"
                        FontSize="12.5"
                        Foreground="#555555"
                        Text="{Binding LineNumbersText}"
                        TextAlignment="Right" />

                    <!--  代码：只读 TextBox，保留鼠标拖选 / Ctrl+A / Ctrl+C  -->
                    <TextBox
                        Grid.Column="1"
                        Style="{x:Null}"
                        AcceptsReturn="True"
                        Background="Transparent"
                        BorderThickness="0"
                        CaretBrush="White"
                        FontFamily="Consolas"
                        FontSize="12.5"
                        Foreground="#D4D4D4"
                        IsReadOnly="True"
                        Padding="0"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        SelectionBrush="#264F78"
                        SelectionOpacity="0.6"
                        Text="{Binding Code}"
                        TextWrapping="NoWrap" />
                </Grid>
            </ScrollViewer>
        </DataTemplate>
    </UserControl.Resources>

    <Border
        Padding="0"
        Background="#1E1E1E"
        BorderBrush="#333333"
        BorderThickness="1"
        CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  头部（始终渲染）  -->
            <Border
                x:Name="HeaderBorder"
                Grid.Row="0"
                Padding="12,8"
                BorderBrush="#333333"
                BorderThickness="0">
                <Grid>
                    <!--  左：语言标签  -->
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Border
                            Padding="6,2"
                            Background="#2D2D2D"
                            CornerRadius="3">
                            <TextBlock
                                x:Name="LanguageLabel"
                                FontFamily="Consolas"
                                FontSize="11"
                                Foreground="#808080"
                                Text="XAML" />
                        </Border>
                    </StackPanel>

                    <!--  右：复制 + 展开/折叠  -->
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <Button
                            x:Name="CopyButton"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="CopyButton_Click"
                            Cursor="Hand"
                            ToolTip="复制全部代码">
                            <StackPanel Orientation="Horizontal">
                                <pf:PackIcon
                                    Width="14"
                                    Height="14"
                                    VerticalAlignment="Center"
                                    Foreground="#808080"
                                    Kind="ContentCopy" />
                                <TextBlock
                                    x:Name="CopyLabel"
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="#808080"
                                    Text="复制" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="ToggleButton"
                            Margin="12,0,0,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="ToggleButton_Click"
                            Cursor="Hand"
                            ToolTip="展开代码">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    x:Name="ToggleLabel"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="#808080"
                                    Text="展开" />
                                <pf:PackIcon
                                    x:Name="ToggleIcon"
                                    Width="12"
                                    Height="12"
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    Foreground="#808080"
                                    Kind="ChevronDown" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!--  代码区：Content 绑定到 Root，DataTemplate 通过 {Binding} 访问其属性  -->
            <ContentControl
                x:Name="CodeContent"
                Grid.Row="1"
                Content="{Binding ElementName=Root}"
                Visibility="Collapsed" />
        </Grid>
    </Border>
</UserControl>
