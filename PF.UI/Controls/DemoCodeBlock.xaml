<UserControl
    x:Class="PF.UI.Controls.DemoCodeBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    x:Name="Root">

    <Border
        Padding="0"
        Background="#1E1E1E"
        BorderBrush="#333333"
        BorderThickness="1"
        CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  标题栏  -->
            <Border
                Grid.Row="0"
                Padding="12,8"
                BorderBrush="#333333"
                BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Border
                            Padding="6,2"
                            Background="#2D2D2D"
                            CornerRadius="3">
                            <TextBlock
                                x:Name="LanguageLabel"
                                FontFamily="Consolas"
                                FontSize="11"
                                Foreground="#808080"
                                Text="XAML" />
                        </Border>
                    </StackPanel>

                    <!--  复制全部按钮  -->
                    <Button
                        x:Name="CopyButton"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="CopyButton_Click"
                        Cursor="Hand"
                        ToolTip="复制全部代码">
                        <StackPanel Orientation="Horizontal">
                            <pf:PackIcon
                                Width="14"
                                Height="14"
                                VerticalAlignment="Center"
                                Foreground="#808080"
                                Kind="ContentCopy" />
                            <TextBlock
                                x:Name="CopyLabel"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#808080"
                                Text="复制" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!--  代码区域 — 逐行渲染，支持单行复制  -->
            <ScrollViewer
                Grid.Row="1"
                MaxHeight="300"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto">
                <ItemsControl x:Name="LinesItemsControl" Padding="8,8,8,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                x:Name="LineRow"
                                Padding="6,2,6,2"
                                Background="Transparent"
                                CornerRadius="2"
                                MouseEnter="LineRow_MouseEnter"
                                MouseLeave="LineRow_MouseLeave">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!--  行号  -->
                                    <TextBlock
                                        Grid.Column="0"
                                        Width="24"
                                        Margin="0,0,8,0"
                                        VerticalAlignment="Center"
                                        FontFamily="Consolas"
                                        FontSize="12"
                                        Foreground="#555555"
                                        Text="{Binding LineNumber, StringFormat='{}{0:D2}'}"
                                        TextAlignment="Right" />

                                    <!--  代码文本  -->
                                    <TextBlock
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        FontFamily="Consolas"
                                        FontSize="12.5"
                                        Foreground="#D4D4D4"
                                        Text="{Binding Text}"
                                        TextWrapping="NoWrap" />

                                    <!--  单行复制按钮（hover 时可见）  -->
                                    <Button
                                        x:Name="LineCopyBtn"
                                        Grid.Column="2"
                                        Width="22"
                                        Height="22"
                                        Padding="0"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        Click="LineCopy_Click"
                                        Cursor="Hand"
                                        Tag="{Binding Text}"
                                        ToolTip="复制此行"
                                        Visibility="Collapsed">
                                        <pf:PackIcon
                                            Width="11"
                                            Height="11"
                                            Foreground="#808080"
                                            Kind="ContentCopy" />
                                    </Button>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Text}" Value="{x:Null}">
                                    <Setter TargetName="LineCopyBtn" Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
