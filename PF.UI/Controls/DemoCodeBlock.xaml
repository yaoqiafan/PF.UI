<UserControl x:Class="PF.UI.Controls.DemoCodeBlock"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             x:Name="Root">

    <Border CornerRadius="8" Padding="0"
            Background="#1E1E1E"
            BorderBrush="#333333" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 标题栏 -->
            <Border Grid.Row="0" Padding="12,8"
                    BorderBrush="#333333" BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border CornerRadius="3" Padding="6,2"
                                Background="#2D2D2D">
                            <TextBlock x:Name="LanguageLabel" Text="XAML"
                                       FontSize="11" Foreground="#808080"
                                       FontFamily="Consolas" />
                        </Border>
                    </StackPanel>

                    <!-- 复制全部按钮 -->
                    <Button x:Name="CopyButton"
                            HorizontalAlignment="Right"
                            Background="Transparent" BorderThickness="0"
                            Cursor="Hand"
                            Click="CopyButton_Click"
                            ToolTip="复制全部代码">
                        <StackPanel Orientation="Horizontal">
                            <pf:PackIcon Kind="ContentCopy" Width="14" Height="14"
                                         Foreground="#808080" VerticalAlignment="Center" />
                            <TextBlock x:Name="CopyLabel" Text="复制"
                                       FontSize="11" Foreground="#808080"
                                       Margin="4,0,0,0" VerticalAlignment="Center" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!-- 代码区域 — 逐行渲染，支持单行复制 -->
            <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto"
                          MaxHeight="300">
                <ItemsControl x:Name="LinesItemsControl"
                              Padding="8,8,8,8">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="LineRow" Padding="6,2,6,2"
                                    CornerRadius="2"
                                    Background="Transparent"
                                    MouseEnter="LineRow_MouseEnter"
                                    MouseLeave="LineRow_MouseLeave">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>

                                    <!-- 行号 -->
                                    <TextBlock Grid.Column="0"
                                               Text="{Binding LineNumber, StringFormat='{}{0:D2}'}"
                                               FontFamily="Consolas" FontSize="12"
                                               Foreground="#555555"
                                               Width="24" Margin="0,0,8,0"
                                               TextAlignment="Right"
                                               VerticalAlignment="Center" />

                                    <!-- 代码文本 -->
                                    <TextBlock Grid.Column="1"
                                               Text="{Binding Text}"
                                               FontFamily="Consolas" FontSize="12.5"
                                               Foreground="#D4D4D4"
                                               TextWrapping="NoWrap"
                                               VerticalAlignment="Center" />

                                    <!-- 单行复制按钮（hover 时可见） -->
                                    <Button Grid.Column="2"
                                            x:Name="LineCopyBtn"
                                            Width="22" Height="22"
                                            Background="Transparent" BorderThickness="0"
                                            Cursor="Hand" Padding="0"
                                            Visibility="Collapsed"
                                            ToolTip="复制此行"
                                            Click="LineCopy_Click"
                                            Tag="{Binding Text}">
                                        <pf:PackIcon Kind="ContentCopy" Width="11" Height="11"
                                                     Foreground="#808080" />
                                    </Button>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <DataTrigger Binding="{Binding Text}" Value="{x:Null}">
                                    <Setter TargetName="LineCopyBtn" Property="Visibility" Value="Collapsed" />
                                </DataTrigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
