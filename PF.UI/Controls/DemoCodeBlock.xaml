<UserControl
    x:Class="PF.UI.Controls.DemoCodeBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    x:Name="Root">

    <Border
        Padding="0"
        Background="#1E1E1E"
        BorderBrush="#333333"
        BorderThickness="1"
        CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!--  标题栏  -->
            <Border
                Grid.Row="0"
                Padding="12,8"
                BorderBrush="#333333"
                BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Border
                            Padding="6,2"
                            Background="#2D2D2D"
                            CornerRadius="3">
                            <TextBlock
                                x:Name="LanguageLabel"
                                FontFamily="Consolas"
                                FontSize="11"
                                Foreground="#808080"
                                Text="XAML" />
                        </Border>
                    </StackPanel>

                    <!--  复制全部按钮  -->
                    <Button
                        x:Name="CopyButton"
                        HorizontalAlignment="Right"
                        Background="Transparent"
                        BorderThickness="0"
                        Click="CopyButton_Click"
                        Cursor="Hand"
                        ToolTip="复制全部代码">
                        <StackPanel Orientation="Horizontal">
                            <pf:PackIcon
                                Width="14"
                                Height="14"
                                VerticalAlignment="Center"
                                Foreground="#808080"
                                Kind="ContentCopy" />
                            <TextBlock
                                x:Name="CopyLabel"
                                Margin="4,0,0,0"
                                VerticalAlignment="Center"
                                FontSize="11"
                                Foreground="#808080"
                                Text="复制" />
                        </StackPanel>
                    </Button>
                </Grid>
            </Border>

            <!--  代码区域 — 支持多行选择、Ctrl+A/C、鼠标拖选  -->
            <ScrollViewer
                Grid.Row="1"
                MaxHeight="300"
                HorizontalScrollBarVisibility="Auto"
                VerticalScrollBarVisibility="Auto">
                <Grid Margin="8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!--  行号（不可交互，与代码区等高字体保证行对齐）  -->
                    <TextBox
                        x:Name="LineNumbersBox"
                        Grid.Column="0"
                        Width="30"
                        Margin="0,0,10,0"
                        Style="{x:Null}"
                        AcceptsReturn="True"
                        Background="Transparent"
                        BorderThickness="0"
                        Focusable="False"
                        FontFamily="Consolas"
                        FontSize="12.5"
                        Foreground="#555555"
                        IsHitTestVisible="False"
                        IsReadOnly="True"
                        IsTabStop="False"
                        Padding="0"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        TextAlignment="Right"
                        TextWrapping="NoWrap" />

                    <!--  代码文本：只读多行 TextBox，支持鼠标拖选、Ctrl+A、Ctrl+C  -->
                    <TextBox
                        x:Name="CodeTextBox"
                        Grid.Column="1"
                        Style="{x:Null}"
                        AcceptsReturn="True"
                        Background="Transparent"
                        BorderThickness="0"
                        CaretBrush="White"
                        FontFamily="Consolas"
                        FontSize="12.5"
                        Foreground="#D4D4D4"
                        IsReadOnly="True"
                        Padding="0"
                        ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                        ScrollViewer.VerticalScrollBarVisibility="Disabled"
                        SelectionBrush="#264F78"
                        SelectionOpacity="0.6"
                        TextWrapping="NoWrap" />
                </Grid>
            </ScrollViewer>
        </Grid>
    </Border>
</UserControl>
