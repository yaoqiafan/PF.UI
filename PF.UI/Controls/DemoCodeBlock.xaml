<UserControl
    x:Class="PF.UI.Controls.DemoCodeBlock"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    x:Name="Root">

    <Border
        Padding="0"
        Background="#1E1E1E"
        BorderBrush="#333333"
        BorderThickness="1"
        CornerRadius="8">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!--  头部（始终渲染）  -->
            <Border
                x:Name="HeaderBorder"
                Grid.Row="0"
                Padding="12,8"
                BorderBrush="#333333"
                BorderThickness="0">
                <Grid>
                    <!--  左：语言标签  -->
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Border
                            Padding="6,2"
                            Background="#2D2D2D"
                            CornerRadius="3">
                            <TextBlock
                                x:Name="LanguageLabel"
                                FontFamily="Consolas"
                                FontSize="11"
                                Foreground="#808080"
                                Text="XAML" />
                        </Border>
                    </StackPanel>

                    <!--  右：复制 + 展开/折叠  -->
                    <StackPanel
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">

                        <Button
                            x:Name="CopyButton"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="CopyButton_Click"
                            Cursor="Hand"
                            ToolTip="复制全部代码">
                            <StackPanel Orientation="Horizontal">
                                <pf:PackIcon
                                    Width="14"
                                    Height="14"
                                    VerticalAlignment="Center"
                                    Foreground="#808080"
                                    Kind="ContentCopy" />
                                <TextBlock
                                    x:Name="CopyLabel"
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="#808080"
                                    Text="复制" />
                            </StackPanel>
                        </Button>

                        <Button
                            x:Name="ToggleButton"
                            Margin="12,0,0,0"
                            Background="Transparent"
                            BorderThickness="0"
                            Click="ToggleButton_Click"
                            Cursor="Hand"
                            ToolTip="展开代码">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    x:Name="ToggleLabel"
                                    VerticalAlignment="Center"
                                    FontSize="11"
                                    Foreground="#808080"
                                    Text="展开" />
                                <pf:PackIcon
                                    x:Name="ToggleIcon"
                                    Width="12"
                                    Height="12"
                                    Margin="4,0,0,0"
                                    VerticalAlignment="Center"
                                    Foreground="#808080"
                                    Kind="ChevronDown" />
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!--  代码区：首次展开时由代码后台填充 Content  -->
            <ContentControl x:Name="CodeContent" Grid.Row="1" Visibility="Collapsed" />
        </Grid>
    </Border>
</UserControl>
