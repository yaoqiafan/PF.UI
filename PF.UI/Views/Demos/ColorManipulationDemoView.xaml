<UserControl x:Class="PF.UI.Views.Demos.ColorManipulationDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,20,24,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <StackPanel>
                <TextBlock Text="ColorManipulation — HSB 色彩工具"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}" />
                <TextBlock Text="HSB 色彩空间转换 · Color ↔ Hsb · HsbToColorConverter · HsbLinearGradientConverter"
                           FontSize="12" Margin="0,4,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
            </StackPanel>
        </Border>

        <!-- 内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <StackPanel MaxWidth="720" HorizontalAlignment="Left">

                <!-- 色彩预览卡片 -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="200" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- 颜色块预览 -->
                    <Border Grid.Column="0" Height="200" CornerRadius="12"
                            Background="{Binding PreviewBrush}">
                        <StackPanel VerticalAlignment="Bottom" Margin="16,0,16,16">
                            <TextBlock Text="{Binding HexCode}"
                                       FontSize="18" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="4" Opacity="0.6" ShadowDepth="1" />
                                </TextBlock.Effect>
                            </TextBlock>
                            <TextBlock Text="{Binding HsbText}"
                                       FontSize="10" Foreground="White" Opacity="0.85"
                                       HorizontalAlignment="Center" Margin="0,4,0,0">
                                <TextBlock.Effect>
                                    <DropShadowEffect BlurRadius="4" Opacity="0.6" ShadowDepth="1" />
                                </TextBlock.Effect>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- 滑块区 -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Center">

                        <!-- Hue 滑块 -->
                        <TextBlock Text="H — 色调（Hue）" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                        <Grid Margin="0,0,0,4">
                            <Grid.Background>
                                <!-- 彩虹渐变 -->
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="#FF0000" Offset="0" />
                                    <GradientStop Color="#FFFF00" Offset="0.167" />
                                    <GradientStop Color="#00FF00" Offset="0.333" />
                                    <GradientStop Color="#00FFFF" Offset="0.5" />
                                    <GradientStop Color="#0000FF" Offset="0.667" />
                                    <GradientStop Color="#FF00FF" Offset="0.833" />
                                    <GradientStop Color="#FF0000" Offset="1" />
                                </LinearGradientBrush>
                            </Grid.Background>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="12" />
                            </Grid.RowDefinitions>
                        </Grid>
                        <Slider Value="{Binding Hue}" Minimum="0" Maximum="360"
                                Margin="0,0,0,16" />

                        <!-- Saturation 滑块 -->
                        <TextBlock Text="S — 饱和度（Saturation）" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                        <Border Margin="0,0,0,4" Height="12" CornerRadius="3">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="White" Offset="0" />
                                    <GradientStop Color="{Binding PreviewColor}" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Slider Value="{Binding Saturation}" Minimum="0" Maximum="1"
                                Margin="0,0,0,16" />

                        <!-- Brightness 滑块 -->
                        <TextBlock Text="B — 亮度（Brightness）" FontSize="12" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                        <Border Margin="0,0,0,4" Height="12" CornerRadius="3">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Color="Black" Offset="0" />
                                    <GradientStop Color="{Binding PreviewColor}" Offset="1" />
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <Slider Value="{Binding Brightness}" Minimum="0" Maximum="1" />
                    </StackPanel>
                </Grid>

                <!-- HsbLinearGradientConverter 演示 -->
                <TextBlock Text="HsbLinearGradientConverter — 色调渐变"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                <Border Height="48" CornerRadius="8" Margin="0,0,0,6"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Border.Background>
                        <Binding Path="HueGradient" />
                    </Border.Background>
                </Border>
                <TextBlock Text="白色 → 当前色调满饱和度色（Saturation=1, Brightness=1）"
                           FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}"
                           Margin="0,0,0,24" />

                <!-- ConvertBack 验证 -->
                <Border Background="{DynamicResource RegionBrush}" CornerRadius="8" Padding="16"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Color → Hsb 反向转换验证（ConvertBack）"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal">
                            <Border Width="32" Height="32" CornerRadius="4"
                                    Background="{Binding PreviewBrush}" Margin="0,0,12,0" />
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="{Binding HexCode, StringFormat='Color: {0}'}"
                                           FontSize="12" Foreground="{DynamicResource PrimaryTextBrush}" />
                                <TextBlock Text="{Binding RoundTripText}"
                                           FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                                           Margin="0,3,0,0" />
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
