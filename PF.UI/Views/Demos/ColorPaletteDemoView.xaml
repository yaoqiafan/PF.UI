<UserControl x:Class="PF.UI.Views.Demos.ColorPaletteDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,20,24,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <StackPanel>
                <TextBlock Text="Material Design 颜色调色板"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}" />
                <TextBlock Text="19种颜色 × 14个色调层级 = 266个色值   ·   ISwatch / SwatchHelper.Lookup"
                           FontSize="12" Margin="0,4,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="16,12">
            <StackPanel>

                <!-- ===== 使用方式卡片 ===== -->
                <Border Margin="0,0,0,20" CornerRadius="10"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                        Padding="20,16">
                    <StackPanel>
                        <TextBlock Text="使用方式" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,14" />

                        <!-- 示例 1：全局查色 -->
                        <Border Background="{DynamicResource SecondaryRegionBrush}"
                                CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="// 1. 全局查色 — 266 个色值一键获取"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                <Border Background="{DynamicResource BackgroundBrush}"
                                        CornerRadius="4" Padding="10,8">
                                    <TextBlock FontFamily="Consolas" FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               TextWrapping="Wrap" LineHeight="22"
                                               Text="using PF.UI.Shared.Data.MaterialColors;&#x0a;&#x0a;Color red500 = SwatchHelper.Lookup[MaterialDesignColor.Red]; // 直接取色&#x0a;Color tealA200 = SwatchHelper.Lookup[MaterialDesignColor.TealA200];" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- 示例 2：遍历调色板 -->
                        <Border Background="{DynamicResource SecondaryRegionBrush}"
                                CornerRadius="6" Padding="14,10" Margin="0,0,0,10">
                            <StackPanel>
                                <TextBlock Text="// 2. 遍历所有 19 种调色板"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                <Border Background="{DynamicResource BackgroundBrush}"
                                        CornerRadius="4" Padding="10,8">
                                    <TextBlock FontFamily="Consolas" FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               TextWrapping="Wrap" LineHeight="22"
                                               Text="foreach (var swatch in SwatchHelper.Swatches)&#x0a;{&#x0a;    Console.WriteLine(swatch.Name); // Red, Blue, Teal ...&#x0a;}" />
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- 示例 3：创建特定调色板 -->
                        <Border Background="{DynamicResource SecondaryRegionBrush}"
                                CornerRadius="6" Padding="14,10">
                            <StackPanel>
                                <TextBlock Text="// 3. 创建特定调色板实例"
                                           FontSize="12" FontWeight="SemiBold"
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                <Border Background="{DynamicResource BackgroundBrush}"
                                        CornerRadius="4" Padding="10,8">
                                    <TextBlock FontFamily="Consolas" FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               TextWrapping="Wrap" LineHeight="22"
                                               Text="var teal = new TealSwatch();&#x0a;Color tealA700 = teal.Lookup[MaterialDesignColor.TealA700];&#x0a;Color teal500  = teal.Lookup[MaterialDesignColor.Teal]; // 别名" />
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </Border>

                <!-- ===== 调色板列表 ===== -->
                <ItemsControl ItemsSource="{Binding Swatches}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate DataType="{x:Type vm:SwatchItem}">
                            <Border Margin="0,0,0,16" CornerRadius="10"
                                    Background="{DynamicResource RegionBrush}"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                    Padding="16,12">

                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>

                                    <!-- 颜色名 + 色样 -->
                                    <StackPanel Grid.Row="0" Orientation="Horizontal"
                                                Margin="0,0,0,10">
                                        <Border Width="40" Height="40" CornerRadius="8"
                                                Background="{Binding SampleBrush}"
                                                VerticalAlignment="Center" />
                                        <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding SampleHex, StringFormat='500 层级  ·  {0}'}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </StackPanel>

                                    <!-- 色调色块列表 -->
                                    <WrapPanel Grid.Row="1">
                                        <ItemsControl ItemsSource="{Binding Hues}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel />
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type vm:HueItem}">
                                                    <Border Width="52" Height="44" Margin="2"
                                                            CornerRadius="4"
                                                            Background="{Binding Brush}"
                                                            ToolTip="{Binding Hex}">
                                                        <StackPanel VerticalAlignment="Center"
                                                                    HorizontalAlignment="Center">
                                                            <TextBlock Text="{Binding Label}"
                                                                       FontSize="7"
                                                                       TextAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsDarkText}" Value="True">
                                                                                <Setter Property="Foreground" Value="White" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsDarkText}" Value="False">
                                                                                <Setter Property="Foreground"
                                                                                        Value="{DynamicResource PrimaryTextBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                            <TextBlock Text="{Binding Hex}"
                                                                       FontSize="6"
                                                                       TextAlignment="Center">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding IsDarkText}" Value="True">
                                                                                <Setter Property="Foreground" Value="#E0FFFFFF" />
                                                                            </DataTrigger>
                                                                            <DataTrigger Binding="{Binding IsDarkText}" Value="False">
                                                                                <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </WrapPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
