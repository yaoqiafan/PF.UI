<UserControl x:Class="PF.UI.Views.Demos.PanelsDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="2800" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:PanelsDemoViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <UserControl.Resources>
        <!-- 演示色块通用样式 -->
        <Style x:Key="DemoBox" TargetType="Border">
            <Setter Property="CornerRadius" Value="4" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="VerticalAlignment" Value="Stretch" />
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="布局面板 Panels" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}" />
                <TextBlock Text="FlexPanel · UniformSpacingPanel · WaterfallPanel · CirclePanel · HoneycombPanel · SimpleStackPanel · ElementGroup · Row/Col · RelativePanel · AxleCanvas"
                           FontSize="12" Margin="0,4,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
            </StackPanel>
        </Border>

        <!-- 主体 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. FlexPanel ═══════════ -->
                    <Border x:Name="Section_FlexPanel" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. FlexPanel" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="CSS Flexbox 风格弹性布局，支持主轴方向、换行、对齐方式、子项 Grow/Shrink"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <TextBlock Text="Row + JustifyContent=SpaceBetween（两端对齐）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:FlexPanel FlexDirection="Row" JustifyContent="SpaceBetween" Margin="0,0,0,12">
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}"    Width="80" Height="40"><TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" /></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource SuccessBrush}"    Width="80" Height="40"><TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" /></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource InfoBrush}"       Width="80" Height="40"><TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" /></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource WarningBrush}"    Width="80" Height="40"><TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" /></Border>
                                    </pf:FlexPanel>

                                    <TextBlock Text="Column + FlexGrow 拉伸填满剩余高度" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:FlexPanel FlexDirection="Column" Height="140" Margin="0,0,0,12">
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}"  Height="36" Margin="0,0,0,4"><TextBlock Text="固定 36px" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11" /></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource SuccessBrush}"
                                                pf:FlexPanel.FlexGrow="1" Margin="0,0,0,4">
                                            <TextBlock Text="FlexGrow=1（占剩余）" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11" />
                                        </Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource DangerBrush}"   Height="36"><TextBlock Text="固定 36px" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11" /></Border>
                                    </pf:FlexPanel>

                                    <TextBlock Text="Row + Wrap 换行 + SpaceAround" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:FlexPanel FlexWrap="Wrap" JustifyContent="SpaceAround" Margin="0,0,0,4">
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}" Width="100" Height="36" Margin="0,0,0,6"><TextBlock Text="A" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" /></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource SuccessBrush}" Width="100" Height="36" Margin="0,0,0,6"><TextBlock Text="B" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" /></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource InfoBrush}"    Width="100" Height="36" Margin="0,0,0,6"><TextBlock Text="C" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" /></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource WarningBrush}" Width="100" Height="36" Margin="0,0,0,6"><TextBlock Text="D" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" /></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource DangerBrush}"  Width="100" Height="36" Margin="0,0,0,6"><TextBlock Text="E" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" /></Border>
                                    </pf:FlexPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:PanelsDemoViewModel.XamlFlexPanel}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. UniformSpacingPanel ═══════════ -->
                    <Border x:Name="Section_UniformSpacingPanel" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. UniformSpacingPanel" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Spacing — 统一间距；HorizontalSpacing/VerticalSpacing — 独立设置；ChildWrapping=True 自动换行"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <TextBlock Text="Horizontal + Spacing=12" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:UniformSpacingPanel Orientation="Horizontal" Spacing="12" Margin="0,0,0,12">
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}" Width="80" Height="40"><TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource SuccessBrush}" Width="80" Height="40"><TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource InfoBrush}"    Width="80" Height="40"><TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource WarningBrush}" Width="80" Height="40"><TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                    </pf:UniformSpacingPanel>

                                    <TextBlock Text="ChildWrapping=True + H/V 独立间距" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:UniformSpacingPanel ChildWrapping="Wrap" HorizontalSpacing="12" VerticalSpacing="8" Margin="0,0,0,4">
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}" Width="100" Height="36"><TextBlock Text="A" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource SuccessBrush}" Width="100" Height="36"><TextBlock Text="B" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource InfoBrush}"    Width="100" Height="36"><TextBlock Text="C" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource WarningBrush}" Width="100" Height="36"><TextBlock Text="D" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource DangerBrush}"  Width="100" Height="36"><TextBlock Text="E" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}" Width="100" Height="36"><TextBlock Text="F" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                    </pf:UniformSpacingPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:PanelsDemoViewModel.XamlUniformSpacingPanel}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. WaterfallPanel ═══════════ -->
                    <Border x:Name="Section_WaterfallPanel" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. WaterfallPanel" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Groups — 列数（纵向模式为行数）；子元素自动填入最短列实现瀑布流效果"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <TextBlock Text="Groups=3（3 列瀑布流）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:WaterfallPanel Groups="3" Margin="0,0,0,4">
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}" Height="80"  Margin="0,0,0,6"><TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource SuccessBrush}" Height="120" Margin="0,0,0,6"><TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource InfoBrush}"    Height="60"  Margin="0,0,0,6"><TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource WarningBrush}" Height="100" Margin="0,0,0,6"><TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource DangerBrush}"  Height="80"  Margin="0,0,0,6"><TextBlock Text="5" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}" Height="90"  Margin="0,0,0,6"><TextBlock Text="6" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource SuccessBrush}" Height="70"  Margin="0,0,0,6"><TextBlock Text="7" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource InfoBrush}"    Height="110" Margin="0,0,0,6"><TextBlock Text="8" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                    </pf:WaterfallPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:PanelsDemoViewModel.XamlWaterfallPanel}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 4. CirclePanel ═══════════ -->
                    <Border x:Name="Section_CirclePanel" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="4. CirclePanel" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Diameter — 圆形直径；OffsetAngle — 第一个元素起始角度；KeepVertical — 子元素保持垂直"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <UniformGrid Columns="2">
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="Diameter=180, OffsetAngle=-90" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                            <pf:CirclePanel Diameter="180" OffsetAngle="-90" HorizontalAlignment="Center">
                                                <Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}" Width="32" Height="32" CornerRadius="16"><TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11" FontWeight="Bold"/></Border>
                                                <Border Style="{StaticResource DemoBox}" Background="{DynamicResource SuccessBrush}" Width="32" Height="32" CornerRadius="16"><TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11" FontWeight="Bold"/></Border>
                                                <Border Style="{StaticResource DemoBox}" Background="{DynamicResource InfoBrush}"    Width="32" Height="32" CornerRadius="16"><TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11" FontWeight="Bold"/></Border>
                                                <Border Style="{StaticResource DemoBox}" Background="{DynamicResource WarningBrush}" Width="32" Height="32" CornerRadius="16"><TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11" FontWeight="Bold"/></Border>
                                                <Border Style="{StaticResource DemoBox}" Background="{DynamicResource DangerBrush}"  Width="32" Height="32" CornerRadius="16"><TextBlock Text="5" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11" FontWeight="Bold"/></Border>
                                                <Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}" Width="32" Height="32" CornerRadius="16"><TextBlock Text="6" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11" FontWeight="Bold"/></Border>
                                            </pf:CirclePanel>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="KeepVertical=True（图标保持垂直）" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                            <pf:CirclePanel Diameter="160" KeepVertical="True" OffsetAngle="-90" HorizontalAlignment="Center">
                                                <pf:PackIcon Kind="Home"    Width="22" Height="22" Foreground="{DynamicResource PrimaryBrush}" />
                                                <pf:PackIcon Kind="Star"    Width="22" Height="22" Foreground="{DynamicResource WarningBrush}" />
                                                <pf:PackIcon Kind="Heart"   Width="22" Height="22" Foreground="{DynamicResource DangerBrush}" />
                                                <pf:PackIcon Kind="Bell"    Width="22" Height="22" Foreground="{DynamicResource InfoBrush}" />
                                                <pf:PackIcon Kind="Account" Width="22" Height="22" Foreground="{DynamicResource SuccessBrush}" />
                                                <pf:PackIcon Kind="Cog"     Width="22" Height="22" Foreground="{DynamicResource PrimaryTextBrush}" />
                                            </pf:CirclePanel>
                                        </StackPanel>
                                    </UniformGrid>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:PanelsDemoViewModel.XamlCirclePanel}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 5. HoneycombPanel ═══════════ -->
                    <Border x:Name="Section_HoneycombPanel" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="5. HoneycombPanel" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="子元素按蜂巢六边形规律自动排列，无需任何附加属性"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <pf:HoneycombPanel HorizontalAlignment="Center" Margin="0,0,0,4">
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}" Width="64" Height="64"><TextBlock Text="1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource SuccessBrush}" Width="64" Height="64"><TextBlock Text="2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource InfoBrush}"    Width="64" Height="64"><TextBlock Text="3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource WarningBrush}" Width="64" Height="64"><TextBlock Text="4" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource DangerBrush}"  Width="64" Height="64"><TextBlock Text="5" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}" Width="64" Height="64"><TextBlock Text="6" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource SuccessBrush}" Width="64" Height="64"><TextBlock Text="7" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                    </pf:HoneycombPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:PanelsDemoViewModel.XamlHoneycombPanel}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 6. SimpleStackPanel ═══════════ -->
                    <Border x:Name="Section_SimpleStackPanel" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="6. SimpleStackPanel" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="轻量版 StackPanel：省略 Margin/Padding 开销，适合库内部使用；用法与标准 StackPanel 相同"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <TextBlock Text="Horizontal" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:SimpleStackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}" Width="70" Height="36" Margin="0,0,8,0"><TextBlock Text="A" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource SuccessBrush}" Width="70" Height="36" Margin="0,0,8,0"><TextBlock Text="B" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource InfoBrush}"    Width="70" Height="36"><TextBlock Text="C" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                    </pf:SimpleStackPanel>

                                    <TextBlock Text="Vertical" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:SimpleStackPanel Orientation="Vertical" HorizontalAlignment="Left" Margin="0,0,0,4">
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}" Width="200" Height="32" Margin="0,0,0,6"><TextBlock Text="行 1" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource SuccessBrush}" Width="200" Height="32" Margin="0,0,0,6"><TextBlock Text="行 2" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                        <Border Style="{StaticResource DemoBox}" Background="{DynamicResource InfoBrush}"    Width="200" Height="32"><TextBlock Text="行 3" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold"/></Border>
                                    </pf:SimpleStackPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:PanelsDemoViewModel.XamlSimpleStackPanel}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 7. ElementGroup ═══════════ -->
                    <Border x:Name="Section_ElementGroup" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="7. ElementGroup" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ItemsControl 子类，Layout=Stack（紧排）或 Uniform（等宽填满），统一管理一组元素"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <TextBlock Text="Layout=Stack（紧排）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:ElementGroup Orientation="Horizontal" Layout="Stack" Margin="0,0,0,12">
                                        <Button Content="剪切" />
                                        <Button Content="复制" />
                                        <Button Content="粘贴" />
                                        <Button Content="撤销" />
                                    </pf:ElementGroup>

                                    <TextBlock Text="Layout=Uniform（等宽填满容器）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:ElementGroup Orientation="Horizontal" Layout="Uniform" Margin="0,0,0,4">
                                        <Button Content="左对齐" />
                                        <Button Content="居中" />
                                        <Button Content="右对齐" />
                                        <Button Content="两端对齐" />
                                    </pf:ElementGroup>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:PanelsDemoViewModel.XamlElementGroup}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 8. Row / Col / ClipGrid ═══════════ -->
                    <Border x:Name="Section_RowCol" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="8. Row / Col / ClipGrid" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Row/Col — 24 列响应式网格（类 Bootstrap），Span 指定列宽，Gutter 设置水平间距"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <TextBlock Text="8+8+8（三等分）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:Row Gutter="12" Margin="0,0,0,10">
                                        <pf:Col Span="8"><Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}" Height="40"><TextBlock Text="Span=8" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11"/></Border></pf:Col>
                                        <pf:Col Span="8"><Border Style="{StaticResource DemoBox}" Background="{DynamicResource SuccessBrush}" Height="40"><TextBlock Text="Span=8" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11"/></Border></pf:Col>
                                        <pf:Col Span="8"><Border Style="{StaticResource DemoBox}" Background="{DynamicResource InfoBrush}"    Height="40"><TextBlock Text="Span=8" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11"/></Border></pf:Col>
                                    </pf:Row>

                                    <TextBlock Text="6+12+6（中间宽）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:Row Gutter="12" Margin="0,0,0,10">
                                        <pf:Col Span="6"> <Border Style="{StaticResource DemoBox}" Background="{DynamicResource WarningBrush}" Height="40"><TextBlock Text="Span=6"  HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11"/></Border></pf:Col>
                                        <pf:Col Span="12"><Border Style="{StaticResource DemoBox}" Background="{DynamicResource PrimaryBrush}" Height="40"><TextBlock Text="Span=12" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11"/></Border></pf:Col>
                                        <pf:Col Span="6"> <Border Style="{StaticResource DemoBox}" Background="{DynamicResource DangerBrush}"  Height="40"><TextBlock Text="Span=6"  HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontSize="11"/></Border></pf:Col>
                                    </pf:Row>

                                    <TextBlock Text="ClipGrid — IsClipEnabled=True 裁剪溢出内容" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <UniformGrid Columns="2" Margin="0,0,0,4">
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="未裁剪（普通 Grid）" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,4" />
                                            <Grid Width="160" Height="60"
                                                  Background="{DynamicResource SecondaryRegionBrush}"
                                                  HorizontalAlignment="Left">
                                                <Border Background="{DynamicResource PrimaryBrush}" Width="200" Height="40"
                                                        CornerRadius="4">
                                                    <TextBlock Text="宽度=200，溢出显示" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" Foreground="White" FontSize="11" />
                                                </Border>
                                            </Grid>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="裁剪（ClipGrid，IsClipEnabled=True）" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,4" />
                                            <pf:ClipGrid IsClipEnabled="True" Width="160" Height="60"
                                                         Background="{DynamicResource SecondaryRegionBrush}"
                                                         HorizontalAlignment="Left">
                                                <Border Background="{DynamicResource DangerBrush}" Width="200" Height="40"
                                                        CornerRadius="4">
                                                    <TextBlock Text="宽度=200，裁剪显示" HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" Foreground="White" FontSize="11" />
                                                </Border>
                                            </pf:ClipGrid>
                                        </StackPanel>
                                    </UniformGrid>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:PanelsDemoViewModel.XamlRowCol}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ RelativePanel ═══════════ -->
                    <Border x:Name="Section_RelativePanel" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="9. RelativePanel" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" TextWrapping="Wrap"
                                               Text="RelativePanel — 以相对其他元素或面板边缘定位子元素。附加属性前缀 pf:RelativePanel.*" />

                                    <pf:RelativePanel Height="200" Background="{DynamicResource SecondaryRegionBrush}"
                                                      Margin="0,0,0,14">
                                        <!-- 左上角对齐面板 -->
                                        <Border x:Name="RP_A" Width="80" Height="40" CornerRadius="6"
                                                Background="{DynamicResource PrimaryBrush}"
                                                pf:RelativePanel.AlignLeftWithPanel="True"
                                                pf:RelativePanel.AlignTopWithPanel="True"
                                                Margin="8">
                                            <TextBlock Text="A (左上)" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="White" FontSize="11" />
                                        </Border>

                                        <!-- 在 A 的右侧 -->
                                        <Border x:Name="RP_B" Width="80" Height="40" CornerRadius="6"
                                                Background="{DynamicResource SuccessBrush}"
                                                pf:RelativePanel.RightOf="RP_A"
                                                pf:RelativePanel.AlignTopWith="RP_A"
                                                Margin="8,8,0,0">
                                            <TextBlock Text="B (A右)" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="White" FontSize="11" />
                                        </Border>

                                        <!-- 在 A 的下方 -->
                                        <Border x:Name="RP_C" Width="80" Height="40" CornerRadius="6"
                                                Background="{DynamicResource WarningBrush}"
                                                pf:RelativePanel.AlignLeftWith="RP_A"
                                                pf:RelativePanel.Below="RP_A"
                                                Margin="8,8,0,0">
                                            <TextBlock Text="C (A下)" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="White" FontSize="11" />
                                        </Border>

                                        <!-- 右下角对齐面板 -->
                                        <Border Width="100" Height="40" CornerRadius="6"
                                                Background="{DynamicResource DangerBrush}"
                                                pf:RelativePanel.AlignRightWithPanel="True"
                                                pf:RelativePanel.AlignBottomWithPanel="True"
                                                Margin="8">
                                            <TextBlock Text="D (右下)" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="White" FontSize="11" />
                                        </Border>

                                        <!-- 面板中央 -->
                                        <Border Width="80" Height="40" CornerRadius="6"
                                                Background="{DynamicResource InfoBrush}"
                                                pf:RelativePanel.AlignHorizontalCenterWithPanel="True"
                                                pf:RelativePanel.AlignVerticalCenterWithPanel="True">
                                            <TextBlock Text="E (居中)" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="White" FontSize="11" />
                                        </Border>
                                    </pf:RelativePanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,0,0,0"
                                        Code="{x:Static vm:PanelsDemoViewModel.XamlRelativePanel}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 10. AxleCanvas ═══════════ -->
                    <Border x:Name="Section_AxleCanvas" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="10. AxleCanvas — 轴向自动居中画布" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" TextWrapping="Wrap"
                                               Text="Canvas 子类。Orientation=Horizontal：子元素在 Y 轴上自动居中，Canvas.Top/Bottom 控制偏移；Orientation=Vertical：子元素在 X 轴上自动居中，Canvas.Left/Right 控制偏移。" />

                                    <!-- Horizontal 模式 -->
                                    <TextBlock Text="Orientation=Horizontal（Y 轴自动居中，Top/Bottom 偏移）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="6"
                                            Padding="0" Margin="0,0,0,14" Height="130">
                                        <pf:AxleCanvas Orientation="Horizontal">
                                            <!-- 贴顶（Canvas.Top=8） -->
                                            <Border Width="80" Height="50" CornerRadius="6" Margin="8,0,0,0"
                                                    Background="{DynamicResource PrimaryBrush}"
                                                    Canvas.Top="8">
                                                <TextBlock Text="Top=8" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="White" FontSize="11" />
                                            </Border>
                                            <!-- 自动居中（无偏移） -->
                                            <Border Width="80" Height="50" CornerRadius="6" Margin="12,0,0,0"
                                                    Background="{DynamicResource SuccessBrush}">
                                                <TextBlock Text="居中" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="White" FontSize="11" />
                                            </Border>
                                            <!-- 贴底（Canvas.Bottom=8） -->
                                            <Border Width="80" Height="50" CornerRadius="6" Margin="12,0,0,0"
                                                    Background="{DynamicResource WarningBrush}"
                                                    Canvas.Bottom="8">
                                                <TextBlock Text="Bottom=8" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="White" FontSize="11" />
                                            </Border>
                                            <!-- 高度不同：自动居中 -->
                                            <Border Width="80" Height="80" CornerRadius="6" Margin="12,0,0,0"
                                                    Background="{DynamicResource InfoBrush}">
                                                <TextBlock Text="H=80&#x0a;居中" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="White" FontSize="11" TextAlignment="Center" />
                                            </Border>
                                        </pf:AxleCanvas>
                                    </Border>

                                    <!-- Vertical 模式 -->
                                    <TextBlock Text="Orientation=Vertical（X 轴自动居中，Left/Right 偏移）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="6"
                                            Padding="0" Margin="0,0,0,4" Width="280" HorizontalAlignment="Left">
                                        <pf:AxleCanvas Orientation="Vertical">
                                            <!-- 贴左（Canvas.Left=8） -->
                                            <Border Width="80" Height="46" CornerRadius="6" Margin="0,8,0,0"
                                                    Background="{DynamicResource DangerBrush}"
                                                    Canvas.Left="8">
                                                <TextBlock Text="Left=8" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="White" FontSize="11" />
                                            </Border>
                                            <!-- 自动居中 -->
                                            <Border Width="80" Height="46" CornerRadius="6" Margin="0,10,0,0"
                                                    Background="{DynamicResource PrimaryBrush}">
                                                <TextBlock Text="居中" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="White" FontSize="11" />
                                            </Border>
                                            <!-- 贴右（Canvas.Right=8） -->
                                            <Border Width="80" Height="46" CornerRadius="6" Margin="0,10,0,0"
                                                    Background="{DynamicResource SuccessBrush}"
                                                    Canvas.Right="8">
                                                <TextBlock Text="Right=8" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" Foreground="White" FontSize="11" />
                                            </Border>
                                        </pf:AxleCanvas>
                                    </Border>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:PanelsDemoViewModel.XamlAxleCanvas}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
