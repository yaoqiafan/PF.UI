<UserControl
    x:Class="PF.UI.Views.Demos.PackIconDemoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PF.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
    d:DataContext="{d:DesignInstance vm:PackIconDemoViewModel,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="800"
    d:DesignWidth="820"
    prism:ViewModelLocator.AutoWireViewModel="True"
    Background="{DynamicResource BackgroundBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!--  页头  -->
        <Border
            Grid.Row="0"
            Padding="24,20,24,16"
            Background="{DynamicResource RegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                    Text="PackIcon 图标库" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="12"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    Text="700+ Material Design 图标，支持任意颜色和尺寸" />
            </StackPanel>
        </Border>

        <!--  工具栏  -->
        <Border
            Grid.Row="1"
            Padding="16,10"
            Background="{DynamicResource RegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!--  搜索框  -->
                <Border
                    Grid.Column="0"
                    MaxWidth="360"
                    Padding="6,0"
                    HorizontalAlignment="Left"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    CornerRadius="6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <pf:PackIcon
                            Grid.Column="0"
                            Width="16"
                            Height="16"
                            Margin="4,0,4,0"
                            VerticalAlignment="Center"
                            Foreground="{DynamicResource ThirdlyTextBrush}"
                            Kind="Magnify" />
                        <TextBox
                            Grid.Column="1"
                            Height="34"
                            VerticalContentAlignment="Center"
                            pf:InfoElement.Placeholder="搜索图标名称..."
                            Background="Transparent"
                            BorderThickness="0"
                            CaretBrush="{DynamicResource PrimaryBrush}"
                            FontSize="13"
                            Foreground="{DynamicResource PrimaryTextBrush}"
                            Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>
                </Border>

                <!--  大小滑块  -->
                <StackPanel
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        Margin="0,0,8,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        Text="大小" />
                    <Slider
                        Width="100"
                        VerticalAlignment="Center"
                        IsSnapToTickEnabled="True"
                        Maximum="64"
                        Minimum="16"
                        TickFrequency="8"
                        Value="{Binding IconSize}" />
                    <TextBlock
                        Width="34"
                        Margin="8,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        Text="{Binding IconSize, StringFormat={}{0}px}" />
                </StackPanel>
            </Grid>
        </Border>

        <!--  图标网格  -->
        <ScrollViewer
            Grid.Row="2"
            Padding="12"
            HorizontalScrollBarVisibility="Disabled"
            VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <ItemsControl ItemsSource="{Binding Icons}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border
                                Width="100"
                                Height="88"
                                Margin="4"
                                Background="{DynamicResource RegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                ClipToBounds="True"
                                CornerRadius="8"
                                ToolTip="{Binding Name}">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <pf:Ripple
                                    HorizontalContentAlignment="Center"
                                    VerticalContentAlignment="Center"
                                    pf:RippleAssist.IsCentered="True">
                                    <StackPanel HorizontalAlignment="Center">
                                        <pf:PackIcon
                                            Width="{Binding DataContext.IconSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            Height="{Binding DataContext.IconSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                            HorizontalAlignment="Center"
                                            Foreground="{DynamicResource PrimaryTextBrush}"
                                            Kind="{Binding Kind}" />
                                        <TextBlock
                                            MaxWidth="90"
                                            Margin="0,6,0,0"
                                            FontSize="9"
                                            Foreground="{DynamicResource SecondaryTextBrush}"
                                            Text="{Binding Name}"
                                            TextAlignment="Center"
                                            TextWrapping="Wrap" />
                                    </StackPanel>
                                </pf:Ripple>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <!--  用法代码示例  -->
                <controls:DemoCodeBlock
                    Margin="0,16,0,8"
                    Code="{x:Static vm:PackIconDemoViewModel.XamlUsage}"
                    CodeLanguage="XAML" />
            </StackPanel>
        </ScrollViewer>

        <!--  分页  -->
        <Border
            Grid.Row="3"
            Padding="12,8"
            Background="{DynamicResource RegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0">
            <pf:Pagination
                Height="{DynamicResource DefaultControlHeight}"
                HorizontalAlignment="Center"
                DataCountPerPage="{Binding ItemsPerPage}"
                IsJumpEnabled="True"
                MaxPageCount="{Binding TotalPages}"
                PageIndex="{Binding CurrentPage, Mode=TwoWay}" />
        </Border>

        <!--  状态栏  -->
        <Border
            Grid.Row="4"
            Padding="16,5"
            Background="{DynamicResource RegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,1,0,0">
            <TextBlock
                FontSize="11"
                Foreground="{DynamicResource ThirdlyTextBrush}"
                Text="{Binding StatusText}" />
        </Border>
    </Grid>
</UserControl>
