<UserControl x:Class="PF.UI.Views.Demos.PackIconDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <!-- 页头 -->
            <RowDefinition Height="Auto" />
            <!-- 工具栏 -->
            <RowDefinition Height="Auto" />
            <!-- 图标网格 -->
            <RowDefinition Height="*" />
            <!-- 状态栏 -->
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,20,24,16"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <StackPanel>
                <TextBlock Text="PackIcon 图标库"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}" />
                <TextBlock Text="700+ Material Design 图标，支持任意颜色和尺寸"
                           FontSize="12" Margin="0,4,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
            </StackPanel>
        </Border>

        <!-- 工具栏 -->
        <Border Grid.Row="1" Padding="16,10"
                Background="{DynamicResource RegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- 搜索框 -->
                <Border Grid.Column="0" MaxWidth="360" HorizontalAlignment="Left"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        CornerRadius="6" Padding="6,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <pf:PackIcon Grid.Column="0" Kind="Magnify"
                                     Width="16" Height="16" Margin="4,0,4,0"
                                     VerticalAlignment="Center"
                                     Foreground="{DynamicResource ThirdlyTextBrush}" />
                        <TextBox Grid.Column="1"
                                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent" BorderThickness="0"
                                 VerticalContentAlignment="Center" Height="34"
                                 FontSize="13"
                                 Foreground="{DynamicResource PrimaryTextBrush}"
                                 CaretBrush="{DynamicResource PrimaryBrush}"
                                 pf:InfoElement.Placeholder="搜索图标名称..." />
                    </Grid>
                </Border>

                <!-- 大小滑块 -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="大小" VerticalAlignment="Center" Margin="0,0,8,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" />
                    <Slider Value="{Binding IconSize}" Minimum="16" Maximum="64"
                            Width="100" VerticalAlignment="Center"
                            TickFrequency="8" IsSnapToTickEnabled="True" />
                    <TextBlock Text="{Binding IconSize, StringFormat={}{0}px}"
                               VerticalAlignment="Center" Margin="8,0,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               FontSize="12" Width="34" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 图标网格 -->
        <ScrollViewer Grid.Row="2"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled"
                      Padding="12">
            <ItemsControl ItemsSource="{Binding Icons}">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="100" Height="88" Margin="4"
                                CornerRadius="8"
                                Background="{DynamicResource RegionBrush}"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1"
                                ClipToBounds="True"
                                ToolTip="{Binding Name}">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Style.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}" />
                                        </Trigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <pf:Ripple HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center"
                                       pf:RippleAssist.IsCentered="True">
                                <StackPanel HorizontalAlignment="Center">
                                    <pf:PackIcon Kind="{Binding Kind}"
                                                 Width="{Binding DataContext.IconSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                 Height="{Binding DataContext.IconSize, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                 HorizontalAlignment="Center"
                                                 Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <TextBlock Text="{Binding Name}"
                                               FontSize="9" TextWrapping="Wrap"
                                               TextAlignment="Center" MaxWidth="90"
                                               Margin="0,6,0,0"
                                               Foreground="{DynamicResource SecondaryTextBrush}" />
                                </StackPanel>
                            </pf:Ripple>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>

        <!-- 状态栏 -->
        <Border Grid.Row="3" Padding="16,6"
                Background="{DynamicResource RegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="0,1,0,0">
            <TextBlock Text="{Binding StatusText}"
                       Foreground="{DynamicResource ThirdlyTextBrush}" FontSize="11" />
        </Border>
    </Grid>
</UserControl>
