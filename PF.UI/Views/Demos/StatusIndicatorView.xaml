<UserControl x:Class="PF.UI.Views.Demos.StatusIndicatorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="1200" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:StatusIndicatorViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="状态标记 Status / Badge" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="Badge · Card · Divider · Empty"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <Border Grid.Column="1" MinWidth="200" MaxWidth="340"
                        CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon Kind="Console" Width="14" Height="14"
                                     Foreground="{DynamicResource ThirdlyTextBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LastResult}" FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. Badge ═══════════ -->
                    <Border x:Name="Section_Badge" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. Badge" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ShowBadge 控制显示；Text（文字角标）/ Dot（圆点）/ Processing（闪烁）"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <TextBlock Text="文字角标 (默认)" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <WrapPanel Margin="0,0,0,12">
                                        <pf:Badge Text="新" ShowBadge="True" BadgeMargin="0,-6,-6,0" Margin="0,0,24,0">
                                            <Button Content="消息通知" />
                                        </pf:Badge>
                                        <pf:Badge Text="99+" ShowBadge="True" Background="{DynamicResource DangerBrush}" BadgeMargin="0,-6,-6,0" Margin="0,0,24,0">
                                            <pf:PackIcon Kind="Bell" Width="20" Height="20" />
                                        </pf:Badge>
                                        <pf:Badge Text="热" ShowBadge="True" Background="{DynamicResource DangerBrush}" BadgeMargin="0,-6,-6,0">
                                            <pf:PackIcon Kind="Tag" Width="20" Height="20" />
                                        </pf:Badge>
                                    </WrapPanel>

                                    <TextBlock Text="数字角标（Maximum 控制封顶值）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <WrapPanel Margin="0,0,0,12">
                                        <pf:Badge Value="3" Maximum="99" ShowBadge="True" BadgeMargin="0,-6,-6,0" Margin="0,0,24,0">
                                            <Button Content="通知" />
                                        </pf:Badge>
                                        <pf:Badge Value="128" Maximum="99" ShowBadge="True"
                                                  Background="{DynamicResource DangerBrush}" BadgeMargin="0,-6,-6,0" Margin="0,0,24,0">
                                            <pf:PackIcon Kind="Heart" Width="20" Height="20" />
                                        </pf:Badge>
                                        <pf:Badge Value="8" Maximum="10" ShowBadge="True" Background="{DynamicResource SuccessBrush}" BadgeMargin="0,-6,-6,0">
                                            <pf:PackIcon Kind="Star" Width="20" Height="20" />
                                        </pf:Badge>
                                    </WrapPanel>

                                    <TextBlock Text="状态圆点 Dot / Processing" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <WrapPanel Margin="0,0,0,4">
                                        <pf:Badge Status="Dot" ShowBadge="True" Background="{DynamicResource SuccessBrush}" BadgeMargin="0,-4,-4,0" Margin="0,0,20,0">
                                            <TextBlock Text="在线" VerticalAlignment="Center" />
                                        </pf:Badge>
                                        <pf:Badge Status="Dot" ShowBadge="True" Background="{DynamicResource DangerBrush}" BadgeMargin="0,-4,-4,0" Margin="0,0,20,0">
                                            <TextBlock Text="离线" VerticalAlignment="Center" />
                                        </pf:Badge>
                                        <pf:Badge Status="Processing" ShowBadge="True" Background="{DynamicResource WarningBrush}" BadgeMargin="0,-4,-4,0" Margin="0,0,20,0">
                                            <TextBlock Text="处理中" VerticalAlignment="Center" />
                                        </pf:Badge>
                                        <pf:Badge Status="Dot" ShowBadge="True" Background="{DynamicResource InfoBrush}" BadgeMargin="0,-4,-4,0">
                                            <TextBlock Text="待审" VerticalAlignment="Center" />
                                        </pf:Badge>
                                    </WrapPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:StatusIndicatorViewModel.XamlBadge}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. Card ═══════════ -->
                    <Border x:Name="Section_Card" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. Card" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Card 继承自 ContentControl，支持 Header 和 Footer"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <UniformGrid Columns="2" Margin="0,0,0,4">
                                        <pf:Card Header="Card Header" Margin="0,0,8,0"
                                                 Background="{DynamicResource RegionBrush}"
                                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                 MinHeight="80">
                                            <StackPanel>
                                                <TextBlock Text="卡片内容区域" Margin="6,4"
                                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                            </StackPanel>
                                        </pf:Card>
                                        <pf:Card Header="标题" Footer="Footer 信息"
                                                 Background="{DynamicResource RegionBrush}"
                                                 BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                 MinHeight="80">
                                            <TextBlock Text="带 Header 和 Footer 的卡片"
                                                       Margin="6,4"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </pf:Card>
                                    </UniformGrid>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:StatusIndicatorViewModel.XamlCard}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. Divider ═══════════ -->
                    <Border x:Name="Section_Divider" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. Divider" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="分割线组件，支持文字、垂直、虚线"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <TextBlock Text="纯线" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:Divider Margin="0,0,0,12" />

                                    <TextBlock Text="带文字" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:Divider Content="分割线文字" Margin="0,0,0,12" />

                                    <TextBlock Text="垂直分割线" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <StackPanel Orientation="Horizontal" Height="40" Margin="0,0,0,12">
                                        <TextBlock Text="左侧内容" VerticalAlignment="Center" Margin="0,0,8,0"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                        <pf:Divider Orientation="Vertical" />
                                        <TextBlock Text="右侧内容" VerticalAlignment="Center" Margin="8,0,0,0"
                                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </StackPanel>

                                    <TextBlock Text="虚线" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:Divider Content="虚线分割" LineStrokeDashArray="4,2" Margin="0,0,0,4" />

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:StatusIndicatorViewModel.XamlDivider}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 4. Empty ═══════════ -->
                    <Border x:Name="Section_Empty" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="4. Empty" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="空状态占位，支持 Description 描述文字和 Logo 自定义图标"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <UniformGrid Columns="2" Margin="0,0,0,4">
                                        <Border Background="{DynamicResource SecondaryRegionBrush}"
                                                CornerRadius="6" MinHeight="100" Margin="0,0,8,0">
                                            <pf:Empty Description="暂无数据" Padding="12">
                                                <Button Content="重新加载" Margin="0,8,0,0"
                                                        HorizontalAlignment="Center" />
                                            </pf:Empty>
                                        </Border>
                                        <Border Background="{DynamicResource SecondaryRegionBrush}"
                                                CornerRadius="6" MinHeight="100">
                                            <pf:Empty Description="没有找到匹配结果" Padding="12">
                                                <Button Content="清除筛选" Margin="0,8,0,0"
                                                        HorizontalAlignment="Center" />
                                            </pf:Empty>
                                        </Border>
                                    </UniformGrid>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:StatusIndicatorViewModel.XamlEmpty}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
