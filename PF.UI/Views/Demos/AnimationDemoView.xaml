<UserControl x:Class="PF.UI.Views.Demos.AnimationDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="1600" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:AnimationDemoViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="过渡动画 Animation" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="TransitioningContentControl · AnimationPath · RunningBlock · ToggleBlock"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <Border Grid.Column="1" MinWidth="200" MaxWidth="340"
                        CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon Kind="Console" Width="14" Height="14"
                                     Foreground="{DynamicResource ThirdlyTextBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LastResult}" FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. TransitioningContentControl ═══════════ -->
                    <Border x:Name="Section_TransitioningContent" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. TransitioningContentControl" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Content 变化时自动播放过渡动画；TransitionMode 指定效果方向"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <TextBlock Text="Right2Left" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:TransitioningContentControl TransitionMode="Right2Left"
                                                                    Content="{Binding ContentA}"
                                                                    MinHeight="48"
                                                                    Margin="0,0,0,10">
                                        <pf:TransitioningContentControl.Template>
                                            <ControlTemplate TargetType="pf:TransitioningContentControl">
                                                <Border CornerRadius="6"
                                                        Background="{DynamicResource SecondaryRegionBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}"
                                                        BorderThickness="1" Padding="12">
                                                    <ContentPresenter />
                                                </Border>
                                            </ControlTemplate>
                                        </pf:TransitioningContentControl.Template>
                                    </pf:TransitioningContentControl>

                                    <UniformGrid Columns="3" Margin="0,0,0,4">
                                        <StackPanel Margin="0,0,6,0">
                                            <TextBlock Text="Fade" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,4" />
                                            <pf:TransitioningContentControl TransitionMode="Fade"
                                                                            Content="{Binding ContentA}"
                                                                            MinHeight="36">
                                                <pf:TransitioningContentControl.Template>
                                                    <ControlTemplate TargetType="pf:TransitioningContentControl">
                                                        <Border CornerRadius="4"
                                                                Background="{DynamicResource SecondaryRegionBrush}"
                                                                Padding="8,6">
                                                            <ContentPresenter />
                                                        </Border>
                                                    </ControlTemplate>
                                                </pf:TransitioningContentControl.Template>
                                            </pf:TransitioningContentControl>
                                        </StackPanel>
                                        <StackPanel Margin="0,0,6,0">
                                            <TextBlock Text="Top2Bottom" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,4" />
                                            <pf:TransitioningContentControl TransitionMode="Top2Bottom"
                                                                            Content="{Binding ContentA}"
                                                                            MinHeight="36">
                                                <pf:TransitioningContentControl.Template>
                                                    <ControlTemplate TargetType="pf:TransitioningContentControl">
                                                        <Border CornerRadius="4"
                                                                Background="{DynamicResource SecondaryRegionBrush}"
                                                                Padding="8,6">
                                                            <ContentPresenter />
                                                        </Border>
                                                    </ControlTemplate>
                                                </pf:TransitioningContentControl.Template>
                                            </pf:TransitioningContentControl>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Left2Right" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,4" />
                                            <pf:TransitioningContentControl TransitionMode="Left2Right"
                                                                            Content="{Binding ContentA}"
                                                                            MinHeight="36">
                                                <pf:TransitioningContentControl.Template>
                                                    <ControlTemplate TargetType="pf:TransitioningContentControl">
                                                        <Border CornerRadius="4"
                                                                Background="{DynamicResource SecondaryRegionBrush}"
                                                                Padding="8,6">
                                                            <ContentPresenter />
                                                        </Border>
                                                    </ControlTemplate>
                                                </pf:TransitioningContentControl.Template>
                                            </pf:TransitioningContentControl>
                                        </StackPanel>
                                    </UniformGrid>

                                    <Button Content="切换内容触发过渡"
                                            Command="{Binding NextModeCommand}"
                                            Style="{StaticResource ButtonPrimary}"
                                            HorizontalAlignment="Left"
                                            Margin="0,8,0,4" />

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:AnimationDemoViewModel.XamlTransitioningContent}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. AnimationPath ═══════════ -->
                    <Border x:Name="Section_AnimationPath" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. AnimationPath" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Shape 子类，沿 Geometry 路径播放描边动画；支持 RepeatBehavior 循环"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <UniformGrid Columns="3" Margin="0,0,0,8">
                                        <pf:AnimationPath Data="{StaticResource SearchGeometry}"
                                                          Duration="0:0:2"
                                                          IsPlaying="{Binding IsPathPlaying}"
                                                          Stroke="{DynamicResource PrimaryBrush}"
                                                          StrokeThickness="2"
                                                          RepeatBehavior="Forever"
                                                          Width="64" Height="64"
                                                          HorizontalAlignment="Center" />
                                        <pf:AnimationPath Data="{StaticResource ClockGeometry}"
                                                          Duration="0:0:3"
                                                          IsPlaying="{Binding IsPathPlaying}"
                                                          Stroke="{DynamicResource SuccessBrush}"
                                                          StrokeThickness="2"
                                                          RepeatBehavior="Forever"
                                                          Width="64" Height="64"
                                                          HorizontalAlignment="Center" />
                                        <pf:AnimationPath Data="{StaticResource DeleteGeometry}"
                                                          Duration="0:0:1.5"
                                                          IsPlaying="{Binding IsPathPlaying}"
                                                          Stroke="{DynamicResource DangerBrush}"
                                                          StrokeThickness="2"
                                                          RepeatBehavior="Forever"
                                                          Width="64" Height="64"
                                                          HorizontalAlignment="Center" />
                                    </UniformGrid>

                                    <Button Command="{Binding TogglePathCommand}"
                                            HorizontalAlignment="Left"
                                            Margin="0,0,0,4">
                                        <Button.Style>
                                            <Style TargetType="Button" BasedOn="{StaticResource ButtonDefault}">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsPathPlaying}" Value="True">
                                                        <Setter Property="Content" Value="暂停动画" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsPathPlaying}" Value="False">
                                                        <Setter Property="Content" Value="播放动画" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Button.Style>
                                    </Button>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:AnimationDemoViewModel.XamlAnimationPath}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. RunningBlock ═══════════ -->
                    <Border x:Name="Section_RunningBlock" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. RunningBlock" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="跑马灯滚动效果；Orientation 方向 / RunningDirection 起止 / Speed 速度 / AutoReverse 反向"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <TextBlock Text="水平滚动 (LeftToRight)" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <Border Background="{DynamicResource SecondaryRegionBrush}"
                                            CornerRadius="4" Padding="0" Margin="0,0,0,12">
                                        <pf:RunningBlock IsRunning="{Binding IsBlockRunning}"
                                                         Speed="60"
                                                         Orientation="Horizontal"
                                                         RunningDirection="StartToEnd"
                                                         Padding="8,4">
                                            <TextBlock Text="这是一条水平滚动的通知消息 — 当前有 3 个任务待处理，请及时查看..."
                                                       FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                        </pf:RunningBlock>
                                    </Border>

                                    <TextBlock Text="垂直滚动 (BottomToTop)" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <Border Background="{DynamicResource SecondaryRegionBrush}"
                                            CornerRadius="4" Padding="0" Height="80" Margin="0,0,0,8">
                                        <pf:RunningBlock IsRunning="{Binding IsBlockRunning}"
                                                         Speed="40"
                                                         Orientation="Vertical"
                                                         RunningDirection="EndToStart"
                                                         Padding="8,4">
                                            <StackPanel>
                                                <TextBlock Text="&#x1F4E2; 系统公告：今晚 22:00 进行维护升级" FontSize="11" Margin="0,0,0,4" />
                                                <TextBlock Text="&#x26A0; 请提前保存未完成的工作" FontSize="11" Margin="0,0,0,4" />
                                                <TextBlock Text="&#x2705; 预计维护时长 2 小时" FontSize="11" />
                                            </StackPanel>
                                        </pf:RunningBlock>
                                    </Border>

                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="4"
                                            Padding="10,6" HorizontalAlignment="Left" Margin="0,0,0,4">
                                        <CheckBox IsChecked="{Binding IsBlockRunning}" Content="滚动中"
                                                  Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </Border>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:AnimationDemoViewModel.XamlRunningBlock}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 4. ToggleBlock ═══════════ -->
                    <Border x:Name="Section_ToggleBlock" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="4. ToggleBlock" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="IsChecked 控制三种状态：CheckedContent / UnCheckedContent / IndeterminateContent"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <UniformGrid Columns="3" Margin="0,0,0,8">
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Checked=true" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       Margin="0,0,0,6" HorizontalAlignment="Center" />
                                            <pf:ToggleBlock IsChecked="True"
                                                            CheckedContent="已开启"
                                                            UnCheckedContent="已关闭"
                                                            HorizontalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Checked=false" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       Margin="0,0,0,6" HorizontalAlignment="Center" />
                                            <pf:ToggleBlock IsChecked="False"
                                                            CheckedContent="已开启"
                                                            UnCheckedContent="已关闭"
                                                            HorizontalAlignment="Center" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <TextBlock Text="Checked=null (Indeterminate)" FontSize="10" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       Margin="0,0,0,6" HorizontalAlignment="Center" />
                                            <pf:ToggleBlock IsChecked="{x:Null}"
                                                            CheckedContent="是"
                                                            UnCheckedContent="否"
                                                            IndeterminateContent="不确定"
                                                            HorizontalAlignment="Center" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <TextBlock Text="带绑定：ToggleButton 控制" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <pf:ToggleBlock IsChecked="{Binding IsToggled, Mode=TwoWay}"
                                                        CheckedContent="已启用"
                                                        UnCheckedContent="已禁用"
                                                        Margin="0,0,16,0" />
                                        <ToggleButton Content="{Binding IsToggled, StringFormat='{}{0}'}"
                                                       IsChecked="{Binding IsToggled, Mode=TwoWay}"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </StackPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:AnimationDemoViewModel.XamlToggleBlock}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
