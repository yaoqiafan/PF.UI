<UserControl x:Class="PF.UI.Views.Demos.TimeDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:TimeDemoViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="时间日历" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="FlipClock · Clock · TimePicker · DateTimePicker · DateTimeSelector"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <Border Grid.Column="1" MinWidth="200" MaxWidth="340"
                        CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon Kind="Console" Width="14" Height="14"
                                     Foreground="{DynamicResource ThirdlyTextBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LastResult}" FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. FlipClock ═══════════ -->
                    <Border x:Name="Section_FlipClock" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. FlipClock" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="内置 DispatcherTimer 每 200ms 自动刷新 DateTime.Now，无需任何配置即可走时"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,16" />
                                    <pf:FlipClock HorizontalAlignment="Left" Margin="0,0,0,6" />
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:TimeDemoViewModel.XamlFlipClock}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. Clock / ListClock ═══════════ -->
                    <Border x:Name="Section_Clock" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. Clock / ListClock" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Clock 圆形表盘 vs ListClock 列表滚动 — 同一 ClockBase 的两种交互风格"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,14" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 圆形 Clock -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="Clock（圆形表盘）" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                    CornerRadius="8" Padding="4">
                                                <pf:Clock Width="240" ShowConfirmButton="True" />
                                            </Border>
                                        </StackPanel>

                                        <!-- 列表 ListClock -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="ListClock（滚动列表）" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                    CornerRadius="8" Padding="4">
                                                <pf:ListClock Width="220" ShowConfirmButton="True" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,14,0,0"
                                        Code="{x:Static vm:TimeDemoViewModel.XamlClock}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. Pickers ═══════════ -->
                    <Border x:Name="Section_Pickers" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. Pickers — 输入框式选择器" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="文本框 + 弹出面板，点击图标展开时钟或日历时钟"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,14" />

                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="16" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="16" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="140" />
                                            <ColumnDefinition Width="240" />
                                        </Grid.ColumnDefinitions>

                                        <!-- TimePicker -->
                                        <TextBlock Grid.Row="0" Grid.Column="0"
                                                   Text="TimePicker" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <pf:TimePicker Grid.Row="0" Grid.Column="1"
                                                       SelectedTime="{Binding PickerTime, Mode=TwoWay}" />

                                        <!-- DateTimePicker -->
                                        <TextBlock Grid.Row="2" Grid.Column="0"
                                                   Text="DateTimePicker" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <pf:DateTimePicker Grid.Row="2" Grid.Column="1"
                                                           SelectedDateTime="{Binding PickerDateTime, Mode=TwoWay}" />

                                        <!-- DatePicker (native + PF theme) -->
                                        <TextBlock Grid.Row="4" Grid.Column="0"
                                                   Text="DatePicker（PF 主题）" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <DatePicker Grid.Row="4" Grid.Column="1" />
                                    </Grid>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,14,0,0"
                                        Code="{x:Static vm:TimeDemoViewModel.XamlPickers}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 4. DateTimeRange ═══════════ -->
                    <Border x:Name="Section_DateTimeRange" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="4. 范围选择" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="DateTimeSelector 时间范围选择 · CalendarWithClock 日历+时钟组合面板"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,14" />

                                    <!-- DateTimeSelector -->
                                    <TextBlock Text="DateTimeSelector（起止范围）" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <pf:DateTimeSelector
                                        StartTime="{Binding StartTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        EndTime="{Binding EndTime, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                        HorizontalAlignment="Left"
                                        Margin="0,0,0,20" />

                                    <!-- CalendarWithClock -->
                                    <TextBlock Text="CalendarWithClock（日历 + 圆形时钟）" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="8" Padding="4" HorizontalAlignment="Left"
                                            Margin="0,0,0,6">
                                        <pf:CalendarWithClock ShowConfirmButton="True"
                                                              SelectedDateTime="{Binding PickerDateTime, Mode=TwoWay}" />
                                    </Border>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:TimeDemoViewModel.XamlDateTimeRange}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 5. CalendarWithListClock ═══════════ -->
                    <Border x:Name="Section_ListClock" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="5. CalendarWithListClock" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="CalendarWithListClock — 日历 + 列表式时钟（无需表盘，更紧凑）；与 CalendarWithClock 共享 DisplayDateTime 接口"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,14" TextWrapping="Wrap" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="32" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="CalendarWithClock（圆形表盘）" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                    CornerRadius="8" Padding="4" HorizontalAlignment="Left">
                                                <pf:CalendarWithClock ShowConfirmButton="True" />
                                            </Border>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="CalendarWithListClock（列表滚动）" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                    CornerRadius="8" Padding="4" HorizontalAlignment="Left">
                                                <pf:CalendarWithListClock />
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,14,0,0"
                                        Code="{x:Static vm:TimeDemoViewModel.XamlListClock}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
