<UserControl x:Class="PF.UI.Views.Demos.TagsRateDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:TagsRateDemoViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Tag &amp; Rate" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="Tag · TagContainer · Rate"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <Border Grid.Column="1" MinWidth="200" MaxWidth="340"
                        CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon Kind="Console" Width="14" Height="14"
                                     Foreground="{DynamicResource ThirdlyTextBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LastResult}" FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. Tag ═══════════ -->
                    <Border x:Name="Section_Tag" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. Tag" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ShowCloseButton / Header / Selectable — 三种核心属性"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <TextBlock Text="基本用法 · ShowCloseButton" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <WrapPanel Margin="0,0,0,14">
                                        <pf:Tag Content="基础标签" Margin="0,0,8,6" />
                                        <pf:Tag Content="主色标签" Margin="0,0,8,6"
                                                Background="{DynamicResource PrimaryBrush}" Foreground="White" />
                                        <pf:Tag Content="成功标签" Margin="0,0,8,6"
                                                Background="{DynamicResource DarkSuccessBrush}" Foreground="White" />
                                        <pf:Tag Content="无关闭按钮" ShowCloseButton="False" Margin="0,0,0,6" />
                                    </WrapPanel>

                                    <TextBlock Text="Header 前缀徽章" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <WrapPanel Margin="0,0,0,14">
                                        <pf:Tag Header="NEW" Content="新功能" Margin="0,0,8,6" />
                                        <pf:Tag Header="HOT" Content="热门内容" Margin="0,0,8,6"
                                                Background="{DynamicResource DangerBrush}" Foreground="White" />
                                        <pf:Tag Header="v2.0" Content="最新版本" Margin="0,0,0,6"
                                                Background="{DynamicResource DarkSuccessBrush}" Foreground="White" />
                                    </WrapPanel>

                                    <TextBlock Text="Selectable=&quot;True&quot; — 点击高亮选中" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <WrapPanel Margin="0,0,0,6">
                                        <pf:Tag Content="选项 A" Selectable="True" ShowCloseButton="False" Margin="0,0,8,6" />
                                        <pf:Tag Content="选项 B" Selectable="True" ShowCloseButton="False" Margin="0,0,8,6" />
                                        <pf:Tag Content="选项 C" Selectable="True" ShowCloseButton="False" Margin="0,0,0,6" />
                                    </WrapPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,8,0,0"
                                        Code="{x:Static vm:TagsRateDemoViewModel.XamlTag}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. TagContainer ═══════════ -->
                    <Border x:Name="Section_TagContainer" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. TagContainer" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ItemsControl 子类，点击 × 自动从集合移除 Tag"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <TextBlock Text="内联子项（点击 × 自动移除）" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <Border Padding="10" CornerRadius="8"
                                            Background="{DynamicResource SecondaryRegionBrush}"
                                            Margin="0,0,0,14">
                                        <pf:TagContainer>
                                            <pf:Tag Content="WPF" />
                                            <pf:Tag Content=".NET 8" />
                                            <pf:Tag Content="MVVM" />
                                            <pf:Tag Content="Prism 9" />
                                            <pf:Tag Content="EF Core" />
                                            <pf:Tag Content="SQLite" />
                                        </pf:TagContainer>
                                    </Border>

                                    <TextBlock Text="ShowCloseButton=False — 全局隐藏关闭按钮" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <Border Padding="10" CornerRadius="8"
                                            Background="{DynamicResource SecondaryRegionBrush}"
                                            Margin="0,0,0,14">
                                        <pf:TagContainer pf:TagContainer.ShowCloseButton="False">
                                            <pf:Tag Content="只读标签 A" />
                                            <pf:Tag Content="只读标签 B" />
                                            <pf:Tag Content="只读标签 C" />
                                        </pf:TagContainer>
                                    </Border>

                                    <TextBlock Text="ItemsSource 绑定（关闭时从集合移除数据项）" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <Border Padding="10" CornerRadius="8"
                                            Background="{DynamicResource SecondaryRegionBrush}"
                                            Margin="0,0,0,6">
                                        <pf:TagContainer ItemsSource="{Binding TagItems}" />
                                    </Border>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:TagsRateDemoViewModel.XamlTagContainer}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. Rate ═══════════ -->
                    <Border x:Name="Section_Rate" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. Rate" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Count / Value / AllowHalf / IsReadOnly / AllowClear / ItemWidth / ItemHeight"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,14" />

                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="基本 5 星" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <pf:Rate Grid.Column="1" Count="5"
                                                 Value="{Binding RateValue, Mode=TwoWay}" />
                                    </Grid>

                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="半星 AllowHalf" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <pf:Rate Grid.Column="1" Count="5" AllowHalf="True"
                                                 Value="{Binding RateValueHalf, Mode=TwoWay}" />
                                    </Grid>

                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="只读 IsReadOnly" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <pf:Rate Grid.Column="1" Count="5" IsReadOnly="True" DefaultValue="3.5" />
                                    </Grid>

                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="10 星 · 不可清零" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <pf:Rate Grid.Column="1" Count="10" AllowClear="False" />
                                    </Grid>

                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="160" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="大图标 32×32" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <pf:Rate Grid.Column="1" Count="5" ItemWidth="32" ItemHeight="32" />
                                    </Grid>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:TagsRateDemoViewModel.XamlRate}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
