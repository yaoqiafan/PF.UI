<UserControl x:Class="PF.UI.Views.Demos.ColorPickerDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,20,24,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <StackPanel>
                <TextBlock Text="ColorPicker 颜色选择器"
                           FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}" />
                <TextBlock Text="HSB 色彩空间拾色器 · 色调 Slider + 2D 饱和度-亮度画布"
                           FontSize="12" Margin="0,4,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
            </StackPanel>
        </Border>

        <!-- 内容 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <StackPanel MaxWidth="760" HorizontalAlignment="Left">

                <!-- 主演示区 -->
                <Grid Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="320" />
                        <ColumnDefinition Width="24" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <!-- ColorPicker 控件 -->
                    <Border Grid.Column="0" CornerRadius="10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Background="{DynamicResource RegionBrush}"
                            Padding="0" ClipToBounds="True">
                        <pf:ColorPicker Color="{Binding SelectedColor, Mode=TwoWay}"
                                        HueSliderPosition="{Binding HueSliderPosition}"
                                        Height="280" />
                    </Border>

                    <!-- 右侧信息面板 -->
                    <StackPanel Grid.Column="2" VerticalAlignment="Top">

                        <!-- 当前颜色预览 -->
                        <TextBlock Text="当前颜色" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                        <Border Height="80" CornerRadius="8"
                                Background="{Binding SelectedBrush}"
                                Margin="0,0,0,12">
                            <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,10">
                                <TextBlock Text="{Binding HexCode}"
                                           FontSize="16" FontWeight="Bold" Foreground="White"
                                           HorizontalAlignment="Center">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="4" Opacity="0.5" ShadowDepth="1" />
                                    </TextBlock.Effect>
                                </TextBlock>
                                <TextBlock Text="{Binding RgbText}"
                                           FontSize="10" Foreground="White" Opacity="0.85"
                                           HorizontalAlignment="Center" Margin="0,2,0,0">
                                    <TextBlock.Effect>
                                        <DropShadowEffect BlurRadius="4" Opacity="0.5" ShadowDepth="1" />
                                    </TextBlock.Effect>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- HueSliderPosition 切换 -->
                        <TextBlock Text="色调 Slider 位置" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                        <UniformGrid Columns="2" Margin="0,0,0,16">
                            <RadioButton Content="Bottom（默认）" IsChecked="True" Margin="0,0,4,4"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         Command="{x:Null}"
                                         Checked="BottomChecked" />
                            <RadioButton Content="Top" Margin="4,0,0,4"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         Checked="TopChecked" />
                            <RadioButton Content="Left" Margin="0,0,4,0"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         Checked="LeftChecked" />
                            <RadioButton Content="Right" Margin="4,0,0,0"
                                         Foreground="{DynamicResource PrimaryTextBrush}"
                                         Checked="RightChecked" />
                        </UniformGrid>

                        <!-- 应用场景示例 -->
                        <TextBlock Text="选中颜色应用示例" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <Border Width="32" Height="32" CornerRadius="16"
                                    Background="{Binding SelectedBrush}" Margin="0,0,8,0" />
                            <Border Width="32" Height="32" CornerRadius="4"
                                    Background="{Binding SelectedBrush}" Margin="0,0,8,0" />
                            <Border Height="32" CornerRadius="4" Padding="12,0"
                                    Background="{Binding SelectedBrush}">
                                <TextBlock Text="按钮" Foreground="White"
                                           VerticalAlignment="Center" FontSize="13" />
                            </Border>
                        </StackPanel>
                        <Border Height="4" CornerRadius="2"
                                Background="{Binding SelectedBrush}" />
                    </StackPanel>
                </Grid>

                <!-- 用法说明 -->
                <Border Background="{DynamicResource RegionBrush}" CornerRadius="8" Padding="16"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="XAML 用法" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8" />
                        <TextBlock FontFamily="Consolas" FontSize="12" TextWrapping="Wrap"
                                   Foreground="{DynamicResource SecondaryTextBrush}" LineHeight="20">
&lt;pf:ColorPicker Color="{Binding SelectedColor, Mode=TwoWay}"
               HueSliderPosition="Bottom"
               Height="280" /&gt;
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
