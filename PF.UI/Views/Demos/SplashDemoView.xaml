<UserControl x:Class="PF.UI.Views.Demos.SplashDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="1200" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:SplashDemoViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="启动屏" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="Splash · 加载动画 · 分步消息 · 初始化失败处理"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <Border Grid.Column="1" MinWidth="200" MaxWidth="380"
                        CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon Kind="Console" Width="14" Height="14"
                                     Foreground="{DynamicResource ThirdlyTextBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LastResult}" FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. 基础用法 ═══════════ -->
                    <Border x:Name="Section_Basic" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. 基础用法" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,14"
                                               Text="Splash 是一个全屏模态启动窗口（900×500，无边框）。设置 WelcomeText / VersionNumber / WelcomeText_small 定制品牌文字，通过 LoadingAction（Func&lt;Task&lt;bool&gt;&gt;）执行异步初始化任务，完成后窗口自动关闭并将返回值作为 DialogResult。" />

                                    <!-- 预览缩略图 -->
                                    <Border Background="#12202C" CornerRadius="8"
                                            Width="340" Height="190" Margin="0,0,0,14"
                                            HorizontalAlignment="Left"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="*" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <StackPanel Grid.Row="0" HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <Border Background="#1E5F8A" Width="90" Height="10"
                                                        CornerRadius="5" Margin="0,0,0,10" HorizontalAlignment="Center" />
                                                <TextBlock Text="PF.UI 工业自动化平台" FontSize="11"
                                                           Foreground="White" TextAlignment="Center" />
                                                <TextBlock Text="v2.5.0" FontSize="10"
                                                           Foreground="White" TextAlignment="Center" Margin="0,4" />
                                                <TextBlock Text="PF AutoFramework — Industrial Control System"
                                                           FontSize="8.5" Foreground="#AAAAAA" TextAlignment="Center" />
                                            </StackPanel>
                                            <TextBlock Grid.Row="1" Text="Loading..." FontSize="9.5"
                                                       Foreground="White" TextAlignment="Center" Margin="0,0,0,4" />
                                            <pf:LoadingLine Grid.Row="2" DotCount="8" DotDiameter="7" DotSpeed="2"
                                                            Foreground="{DynamicResource PrimaryBrush}"
                                                            Style="{StaticResource LoadingLineLarge}"
                                                            Height="16" Margin="0,0,0,8" />
                                        </Grid>
                                    </Border>

                                    <Button Content="打开基础启动屏（2.5 秒）"
                                            Command="{Binding OpenBasicSplashCommand}"
                                            Style="{StaticResource ButtonPrimary}"
                                            HorizontalAlignment="Left" Padding="18,8" Margin="0,0,0,14" />

                                    <controls:DemoCodeBlock CodeLanguage="CSharp" Margin="0,4,0,0"
                                        Code="{x:Static vm:SplashDemoViewModel.CsBasic}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. 分步初始化 ═══════════ -->
                    <Border x:Name="Section_Steps" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. 分步初始化 — UpdateMessage" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,14"
                                               Text="在 LoadingAction 内调用 splash.UpdateMessage(text, MsgType) 逐步更新底部状态文字。MsgType 枚举决定文字颜色：Info=白色，Success=绿色，Error=红色，Fatal=深红色。返回 false 代表初始化失败。" />

                                    <!-- 步骤说明 -->
                                    <WrapPanel Margin="0,0,0,14">
                                        <Border Margin="0,0,8,8" Padding="8,5" CornerRadius="4"
                                                Background="{DynamicResource SecondaryRegionBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="8" Height="8" CornerRadius="4" Margin="0,0,6,0"
                                                        Background="White" VerticalAlignment="Center" />
                                                <TextBlock Text="Info — 白色" FontSize="11"
                                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="0,0,8,8" Padding="8,5" CornerRadius="4"
                                                Background="{DynamicResource SecondaryRegionBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="8" Height="8" CornerRadius="4" Margin="0,0,6,0"
                                                        Background="#4CAF50" VerticalAlignment="Center" />
                                                <TextBlock Text="Success — 绿色" FontSize="11"
                                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="0,0,8,8" Padding="8,5" CornerRadius="4"
                                                Background="{DynamicResource SecondaryRegionBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="8" Height="8" CornerRadius="4" Margin="0,0,6,0"
                                                        Background="#F44336" VerticalAlignment="Center" />
                                                <TextBlock Text="Error — 红色" FontSize="11"
                                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Margin="0,0,8,8" Padding="8,5" CornerRadius="4"
                                                Background="{DynamicResource SecondaryRegionBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                            <StackPanel Orientation="Horizontal">
                                                <Border Width="8" Height="8" CornerRadius="4" Margin="0,0,6,0"
                                                        Background="#B71C1C" VerticalAlignment="Center" />
                                                <TextBlock Text="Fatal — 深红色" FontSize="11"
                                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                            </StackPanel>
                                        </Border>
                                    </WrapPanel>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Button Content="模拟成功初始化（6步）"
                                                Command="{Binding OpenStepsSplashCommand}"
                                                Style="{StaticResource ButtonPrimary}"
                                                Padding="18,8" Margin="0,0,12,0" />
                                        <Button Content="模拟初始化失败"
                                                Command="{Binding OpenFailSplashCommand}"
                                                Style="{StaticResource ButtonDanger}"
                                                Padding="18,8" />
                                    </StackPanel>

                                    <controls:DemoCodeBlock CodeLanguage="CSharp" Margin="0,4,0,0"
                                        Code="{x:Static vm:SplashDemoViewModel.CsSteps}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. 集成说明 ═══════════ -->
                    <Border x:Name="Section_Integrate" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. 在 App 中集成" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,8"
                                               Text="在 App.xaml.cs 的 OnStartup 方法中显示 Splash，将真实初始化逻辑（容器构建、模块加载、硬件连接）放入 LoadingAction。LoadingAction 返回 false 时中止程序启动；返回 true 时正常显示主窗口。" />
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}"
                                               TextWrapping="Wrap" Margin="0,0,0,14"
                                               Text="注意：移除 App.xaml 中的 StartupUri 属性，改为在 OnStartup 中手动 Show() 主窗口，否则主窗口会与启动屏同时弹出。" />

                                    <controls:DemoCodeBlock CodeLanguage="CSharp" Margin="0,4,0,0"
                                        Code="{x:Static vm:SplashDemoViewModel.CsIntegrate}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent" MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
