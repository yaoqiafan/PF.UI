<UserControl x:Class="PF.UI.Views.Demos.DataDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="2400" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:DataDemoViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="数据展示 Data" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="DataGrid · ListBox · ListView · TreeView · Pagination"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <Border Grid.Column="1" MinWidth="220" MaxWidth="340"
                        CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon Kind="Console" Width="14" Height="14"
                                     Foreground="{DynamicResource ThirdlyTextBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LastResult}"
                                   FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Consolas"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 主体 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. DataGrid ═══════════ -->
                    <Border x:Name="Section_DataGrid" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. DataGrid" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="PF.UI 主题自动重绘 DataGrid 外观，支持排序、多列、行选中"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="CanUserSortColumns=True 点击列头排序；GridLinesVisibility 控制网格线"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <DataGrid ItemsSource="{Binding Products}"
                                              AutoGenerateColumns="False"
                                              CanUserSortColumns="True"
                                              GridLinesVisibility="Horizontal"
                                              SelectionMode="Single"
                                              MaxHeight="260"
                                              SelectionChanged="DataGrid_SelectionChanged"
                                              Margin="0,0,0,4">
                                        <DataGrid.Columns>
                                            <DataGridTextColumn Header="ID"   Binding="{Binding Id}"       Width="50" />
                                            <DataGridTextColumn Header="名称" Binding="{Binding Name}"     Width="*" />
                                            <DataGridTextColumn Header="分类" Binding="{Binding Category}" Width="80" />
                                            <DataGridTextColumn Header="单价" Binding="{Binding Price, StringFormat=¥{0:N0}}" Width="110" />
                                            <DataGridCheckBoxColumn Header="库存" Width="60" IsReadOnly="True">
                                                <DataGridCheckBoxColumn.Binding>
                                                    <Binding Path="InStock" Mode="OneWay" />
                                                </DataGridCheckBoxColumn.Binding>
                                            </DataGridCheckBoxColumn>
                                        </DataGrid.Columns>
                                    </DataGrid>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:DataDemoViewModel.XamlDataGrid}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. ListBox ═══════════ -->
                    <Border x:Name="Section_ListBox" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. ListBox" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="SelectionMode — 单选 / 多选 / 扩展多选；支持自定义 ItemTemplate"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <UniformGrid Columns="2" Margin="0,0,0,10">
                                        <!-- 单选 -->
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="单选 (Single)" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                            <ListBox ItemsSource="{Binding Stations}"
                                                     MaxHeight="160"
                                                     SelectionChanged="ListBox_SelectionChanged" />
                                        </StackPanel>
                                        <!-- 多选 -->
                                        <StackPanel>
                                            <TextBlock Text="多选 (Multiple)" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                            <ListBox ItemsSource="{Binding Stations}"
                                                     SelectionMode="Multiple"
                                                     MaxHeight="160" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <TextBlock Text="自定义 ItemTemplate（带图标）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <ListBox ItemsSource="{Binding Stations}" MaxHeight="130"
                                             Margin="0,0,0,4">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="2,2">
                                                    <pf:PackIcon Kind="Factory" Width="14" Height="14"
                                                                 Foreground="{DynamicResource PrimaryBrush}"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0" />
                                                    <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:DataDemoViewModel.XamlListBox}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. ListView ═══════════ -->
                    <Border x:Name="Section_ListView" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. ListView" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <!-- 3a. 带 GridView -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="带 GridView（多列）— 配合 GridView 实现多列列表；列头可点击排序"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <ListView ItemsSource="{Binding Products}"
                                              MaxHeight="220"
                                              SelectionChanged="ListView_SelectionChanged"
                                              Margin="0,0,0,4">
                                        <ListView.View>
                                            <GridView>
                                                <GridViewColumn Header="名称"
                                                                DisplayMemberBinding="{Binding Name}"
                                                                Width="160" />
                                                <GridViewColumn Header="分类"
                                                                DisplayMemberBinding="{Binding Category}"
                                                                Width="80" />
                                                <GridViewColumn Header="单价"
                                                                DisplayMemberBinding="{Binding Price, StringFormat=¥{0:N0}}"
                                                                Width="110" />
                                                <GridViewColumn Header="库存" Width="60">
                                                    <GridViewColumn.CellTemplate>
                                                        <DataTemplate>
                                                            <TextBlock x:Name="txt" Text="有货"
                                                                       Foreground="{DynamicResource SuccessBrush}" />
                                                            <DataTemplate.Triggers>
                                                                <DataTrigger Binding="{Binding InStock}" Value="False">
                                                                    <Setter TargetName="txt" Property="Text" Value="缺货" />
                                                                    <Setter TargetName="txt" Property="Foreground"
                                                                            Value="{DynamicResource DangerBrush}" />
                                                                </DataTrigger>
                                                            </DataTemplate.Triggers>
                                                        </DataTemplate>
                                                    </GridViewColumn.CellTemplate>
                                                </GridViewColumn>
                                            </GridView>
                                        </ListView.View>
                                    </ListView>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:DataDemoViewModel.XamlListView}" />
                                </StackPanel>
                            </Border>

                            <!-- 3b. 无 GridView（纯列表） -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="不带 GridView（纯列表）— 不设置 View 时退化为纯列表，使用 ListViewItem 容器"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <UniformGrid Columns="2" Margin="0,0,0,10">
                                        <!-- 简单字符串列表 -->
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="字符串列表" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                            <ListView ItemsSource="{Binding Stations}"
                                                      MaxHeight="160"
                                                      SelectionChanged="ListView_Plain_SelectionChanged" />
                                        </StackPanel>
                                        <!-- 自定义 ItemTemplate -->
                                        <StackPanel>
                                            <TextBlock Text="自定义 ItemTemplate（带图标）" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                            <ListView ItemsSource="{Binding Stations}" MaxHeight="160">
                                                <ListView.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="2,2">
                                                            <pf:PackIcon Kind="Factory" Width="14" Height="14"
                                                                         Foreground="{DynamicResource PrimaryBrush}"
                                                                         VerticalAlignment="Center" Margin="0,0,8,0" />
                                                            <TextBlock Text="{Binding}" VerticalAlignment="Center" />
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ListView.ItemTemplate>
                                            </ListView>
                                        </StackPanel>
                                    </UniformGrid>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:DataDemoViewModel.XamlListViewSimple}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 4. TreeView ═══════════ -->
                    <Border x:Name="Section_TreeView" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="4. TreeView" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="HierarchicalDataTemplate 递归绑定树形数据；点击节点名回显到日志"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <TreeView ItemsSource="{Binding TreeRoots}"
                                              MaxHeight="260"
                                              SelectedItemChanged="TreeView_SelectedItemChanged"
                                              Margin="0,0,0,4">
                                        <TreeView.ItemTemplate>
                                            <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                                                <StackPanel Orientation="Horizontal">
                                                    <pf:PackIcon Kind="FolderOutline" Width="14" Height="14"
                                                                 Foreground="{DynamicResource PrimaryBrush}"
                                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </HierarchicalDataTemplate>
                                        </TreeView.ItemTemplate>
                                    </TreeView>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:DataDemoViewModel.XamlTreeView}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 5. Pagination ═══════════ -->
                    <Border x:Name="Section_Pagination" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="5. Pagination" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="MaxPageCount — 总条数；DataCountPerPage — 每页条数；IsJumpEnabled — 跳页输入框"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="4"
                                            Padding="10,8" HorizontalAlignment="Left" Margin="0,0,0,8">
                                        <TextBlock FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}">
                                            <Run Text="共 256 条，每页 20 条，当前第 " />
                                            <Run Text="{Binding PageIndex}" FontWeight="Bold"
                                                 Foreground="{DynamicResource PrimaryBrush}" />
                                            <Run Text=" 页" />
                                        </TextBlock>
                                    </Border>

                                    <pf:Pagination MaxPageCount="{Binding TotalCount}"
                                                   DataCountPerPage="{Binding PageSize}"
                                                   PageIndex="{Binding PageIndex, Mode=TwoWay}"
                                                   IsJumpEnabled="True"
                                                   Height="30"
                                                   Margin="0,0,0,12" />

                                    <TextBlock Text="AutoHiding=True（总页数≤1 时自动隐藏）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:Pagination MaxPageCount="15"
                                                   DataCountPerPage="10"
                                                   IsJumpEnabled="False"
                                                   AutoHiding="True"
                                                   Height="30"
                                                   Margin="0,0,0,4" />

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:DataDemoViewModel.XamlPagination}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 6. PropertyGrid ═══════════ -->
                    <Border x:Name="Section_PropertyGrid" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="6. PropertyGrid" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" TextWrapping="Wrap"
                                               Text="PropertyGrid 通过反射读取 SelectedObject 的所有可浏览属性，自动匹配 Editor。可用 [Category] / [DisplayName] / [ReadOnly] / [Browsable] 标注控制显示。" />

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="240" />
                                        </Grid.ColumnDefinitions>

                                        <!-- PropertyGrid 主体 -->
                                        <pf:PropertyGrid Grid.Column="0"
                                                         SelectedObject="{Binding DemoObject}"
                                                         ShowSortButton="True"
                                                         Height="340"
                                                         BorderBrush="{DynamicResource BorderBrush}"
                                                         BorderThickness="1" />

                                        <!-- 右侧说明 -->
                                        <StackPanel Grid.Column="2" VerticalAlignment="Top">
                                            <TextBlock Text="已演示属性类型" FontSize="12" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                            <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="6" Padding="10,8">
                                                <StackPanel>
                                                    <TextBlock FontFamily="Consolas" FontSize="11" LineHeight="22"
                                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                                               Text="string  → TextBox&#x0a;bool    → CheckBox&#x0a;int     → NumericUpDown&#x0a;double  → NumericUpDown&#x0a;Enum    → ComboBox&#x0a;&#x0a;[ReadOnly(true)] → 只读&#x0a;[Browsable(false)] → 隐藏&#x0a;[Category(&quot;...&quot;)] → 分组&#x0a;[DisplayName] → 显示名" />
                                                </StackPanel>
                                            </Border>
                                            <TextBlock Text="ShowSortButton=True" FontSize="11" FontFamily="Consolas"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,10,0,4" />
                                            <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" TextWrapping="Wrap"
                                                       Text="点击表头排序图标可在&quot;按分类&quot;和&quot;按字母&quot;两种视图间切换" />
                                        </StackPanel>
                                    </Grid>

                                    <controls:DemoCodeBlock CodeLanguage="C#" Margin="0,14,0,0"
                                        Code="{x:Static vm:DataDemoViewModel.XamlPropertyGrid}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
