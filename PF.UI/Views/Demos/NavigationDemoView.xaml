<UserControl x:Class="PF.UI.Views.Demos.NavigationDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="2600" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:NavigationDemoViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="导航控件 Navigation" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}" />
                <TextBlock Text="StepBar · SideMenu · TabControl · Drawer · Ribbon"
                           FontSize="12" Margin="0,4,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
            </StackPanel>
        </Border>

        <!-- 主体 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. StepBar ═══════════ -->
                    <Border x:Name="Section_StepBar" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. StepBar" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="StepIndex — 当前步骤（0 起）；IsMouseSelectable=True 支持点击跳步；Dock=Left 切换垂直模式"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <!-- 水平步骤条 -->
                                    <TextBlock Text="水平（Dock=Top，默认）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <pf:StepBar StepIndex="{Binding StepIndex, Mode=TwoWay}"
                                                IsMouseSelectable="True"
                                                Margin="0,0,0,10">
                                        <pf:StepBarItem Content="基本信息" />
                                        <pf:StepBarItem Content="详细配置" />
                                        <pf:StepBarItem Content="确认预览" />
                                        <pf:StepBarItem Content="完成" />
                                    </pf:StepBar>

                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Button Content="← 上一步" Command="{Binding PrevStepCommand}" Margin="0,0,8,0" />
                                        <Button Content="下一步 →" Command="{Binding NextStepCommand}"
                                                Style="{StaticResource ButtonPrimary}" />
                                        <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="4"
                                                Padding="10,0" Margin="12,0,0,0">
                                            <TextBlock VerticalAlignment="Center" FontSize="12"
                                                       Foreground="{DynamicResource SecondaryTextBrush}">
                                                <Run Text="当前步骤: " />
                                                <Run Text="{Binding StepIndex}"
                                                     Foreground="{DynamicResource PrimaryBrush}" FontWeight="Bold" />
                                            </TextBlock>
                                        </Border>
                                    </StackPanel>

                                    <!-- 垂直步骤条 -->
                                    <TextBlock Text="垂直（Dock=Left）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <Grid Margin="0,0,0,10">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <pf:StepBar Grid.Column="0" StepIndex="{Binding StepIndexV, Mode=TwoWay}"
                                                    Dock="Left" IsMouseSelectable="True">
                                            <pf:StepBarItem Content="初始化设备" />
                                            <pf:StepBarItem Content="加载程序" />
                                            <pf:StepBarItem Content="运行测试" />
                                            <pf:StepBarItem Content="输出报告" />
                                        </pf:StepBar>
                                        <StackPanel Grid.Column="1" Margin="24,0,0,0" VerticalAlignment="Center">
                                            <StackPanel Orientation="Horizontal">
                                                <Button Content="← 上一步" Command="{Binding PrevStepVCommand}" Margin="0,0,8,0" />
                                                <Button Content="下一步 →" Command="{Binding NextStepVCommand}"
                                                        Style="{StaticResource ButtonPrimary}" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,4,0,0"
                                        Code="{x:Static vm:NavigationDemoViewModel.XamlStepBar}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. SideMenu ═══════════ -->
                    <Border x:Name="Section_SideMenu" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. SideMenu" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ExpandMode 控制展开行为：ShowOne 手风琴 / Freedom 自由多开"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <UniformGrid Columns="2">
                                        <!-- ShowOne -->
                                        <StackPanel Margin="0,0,8,0">
                                            <TextBlock Text="ShowOne（手风琴，只展开一项）" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                            <pf:SideMenu ExpandMode="ShowOne" MaxHeight="280">
                                                <pf:SideMenuItem Header="产线管理">
                                                    <pf:SideMenuItem Header="产线 A" />
                                                    <pf:SideMenuItem Header="产线 B" />
                                                    <pf:SideMenuItem Header="产线 C" />
                                                </pf:SideMenuItem>
                                                <pf:SideMenuItem Header="设备管理">
                                                    <pf:SideMenuItem Header="PLC 列表" />
                                                    <pf:SideMenuItem Header="传感器" />
                                                    <pf:SideMenuItem Header="相机" />
                                                </pf:SideMenuItem>
                                                <pf:SideMenuItem Header="系统设置">
                                                    <pf:SideMenuItem Header="用户管理" />
                                                    <pf:SideMenuItem Header="参数配置" />
                                                </pf:SideMenuItem>
                                                <pf:SideMenuItem Header="日志" />
                                            </pf:SideMenu>
                                        </StackPanel>

                                        <!-- Freedom -->
                                        <StackPanel>
                                            <TextBlock Text="Freedom（可同时展开多项）" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                            <pf:SideMenu ExpandMode="Freedom" MaxHeight="280">
                                                <pf:SideMenuItem Header="概览" />
                                                <pf:SideMenuItem Header="采集配置">
                                                    <pf:SideMenuItem Header="通道设置" />
                                                    <pf:SideMenuItem Header="采样率" />
                                                </pf:SideMenuItem>
                                                <pf:SideMenuItem Header="报警管理">
                                                    <pf:SideMenuItem Header="报警规则" />
                                                    <pf:SideMenuItem Header="报警历史" />
                                                </pf:SideMenuItem>
                                                <pf:SideMenuItem Header="报告" />
                                            </pf:SideMenu>
                                        </StackPanel>
                                    </UniformGrid>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,12,0,0"
                                        Code="{x:Static vm:NavigationDemoViewModel.XamlSideMenu}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. TabControl ═══════════ -->
                    <Border x:Name="Section_TabControl" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. TabControl" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="PF.UI 为原生 TabControl 提供多种命名样式"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <TextBlock Text="默认样式" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <TabControl Margin="0,0,0,14" MinHeight="80">
                                        <TabItem Header="概览">
                                            <TextBlock Text="概览页内容区" Margin="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </TabItem>
                                        <TabItem Header="详情">
                                            <TextBlock Text="详情页内容区" Margin="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </TabItem>
                                        <TabItem Header="日志">
                                            <TextBlock Text="日志页内容区" Margin="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </TabItem>
                                        <TabItem Header="设置" IsEnabled="False">
                                            <TextBlock Text="禁用" Margin="12" />
                                        </TabItem>
                                    </TabControl>

                                    <TextBlock Text="胶囊样式 (TabControlCapsule)" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <TabControl Style="{StaticResource TabControlCapsule}" Margin="0,0,0,14" MinHeight="60">
                                        <TabItem Header="日">
                                            <TextBlock Text="日视图" Margin="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </TabItem>
                                        <TabItem Header="周">
                                            <TextBlock Text="周视图" Margin="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </TabItem>
                                        <TabItem Header="月">
                                            <TextBlock Text="月视图" Margin="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </TabItem>
                                        <TabItem Header="年">
                                            <TextBlock Text="年视图" Margin="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </TabItem>
                                    </TabControl>

                                    <TextBlock Text="滑动样式 (TabControlSliding)" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <TabControl Style="{StaticResource TabControlSliding}" Margin="0,0,0,4" MinHeight="60">
                                        <TabItem Header="首页">
                                            <TextBlock Text="首页内容" Margin="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </TabItem>
                                        <TabItem Header="产品">
                                            <TextBlock Text="产品列表" Margin="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </TabItem>
                                        <TabItem Header="订单">
                                            <TextBlock Text="订单管理" Margin="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </TabItem>
                                        <TabItem Header="报告">
                                            <TextBlock Text="报告中心" Margin="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </TabItem>
                                    </TabControl>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:NavigationDemoViewModel.XamlTabControl}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 4. Drawer ═══════════ -->
                    <Border x:Name="Section_Drawer" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="4. Drawer" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Dock — 弹出方向；ShowMode — Cover（覆盖）/ Push（推开）/ Press（收缩）；MaskCanClose — 点遮罩关闭"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <!-- Cover 左侧 -->
                                    <TextBlock Text="Dock=Left, ShowMode=Cover（覆盖）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:DrawerContainer Height="160" Margin="0,0,0,12">
                                        <Grid Background="{DynamicResource SecondaryRegionBrush}">
                                            <pf:Drawer IsOpen="{Binding DrawerLeftOpen, Mode=TwoWay}"
                                                       Dock="Left" ShowMode="Cover"
                                                       ShowMask="True" MaskCanClose="True">
                                                <Border Width="180" Background="{DynamicResource RegionBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                                                        Padding="16">
                                                    <StackPanel>
                                                        <TextBlock Text="Left Drawer" FontWeight="Bold"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8" />
                                                        <TextBlock Text="ShowMode=Cover" FontSize="11"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,4" />
                                                        <TextBlock Text="点击遮罩区域关闭" FontSize="11"
                                                                   Foreground="{DynamicResource ThirdlyTextBrush}" />
                                                        <Button Content="关闭" Margin="0,12,0,0"
                                                                Click="CloseLeftDrawer_Click" />
                                                    </StackPanel>
                                                </Border>
                                            </pf:Drawer>
                                            <TextBlock Text="内容区域" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" />
                                            <ToggleButton Content="打开左侧 Drawer"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          IsChecked="{Binding DrawerLeftOpen, Mode=TwoWay}" />
                                        </Grid>
                                    </pf:DrawerContainer>

                                    <!-- Push 右侧 -->
                                    <TextBlock Text="Dock=Right, ShowMode=Push（推开内容区）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:DrawerContainer Height="160" Margin="0,0,0,12">
                                        <Grid Background="{DynamicResource SecondaryRegionBrush}">
                                            <pf:Drawer IsOpen="{Binding DrawerRightOpen, Mode=TwoWay}"
                                                       Dock="Right" ShowMode="Push">
                                                <Border Width="180" Background="{DynamicResource RegionBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                                                        Padding="16">
                                                    <StackPanel>
                                                        <TextBlock Text="Right Drawer" FontWeight="Bold"
                                                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8" />
                                                        <TextBlock Text="ShowMode=Push" FontSize="11"
                                                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                                                    </StackPanel>
                                                </Border>
                                            </pf:Drawer>
                                            <TextBlock Text="内容区域随 Drawer 推移" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" />
                                            <ToggleButton Content="打开右侧 Drawer"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          IsChecked="{Binding DrawerRightOpen, Mode=TwoWay}" />
                                        </Grid>
                                    </pf:DrawerContainer>

                                    <!-- Top -->
                                    <TextBlock Text="Dock=Top, ShowMode=Cover" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:DrawerContainer Height="160" Margin="0,0,0,4">
                                        <Grid Background="{DynamicResource SecondaryRegionBrush}">
                                            <pf:Drawer IsOpen="{Binding DrawerTopOpen, Mode=TwoWay}"
                                                       Dock="Top" ShowMode="Cover"
                                                       ShowMask="True" MaskCanClose="True">
                                                <Border Height="80" Background="{DynamicResource RegionBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                                                        Padding="16,8">
                                                    <TextBlock Text="Top Drawer — 顶部弹出" FontWeight="Bold"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                                </Border>
                                            </pf:Drawer>
                                            <TextBlock Text="内容区域" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" />
                                            <ToggleButton Content="打开顶部 Drawer"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          IsChecked="{Binding DrawerTopOpen, Mode=TwoWay}" />
                                        </Grid>
                                    </pf:DrawerContainer>

                                    <!-- Bottom + Press mode -->
                                    <TextBlock Text="Dock=Bottom, ShowMode=Press（内容收缩）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,6" />
                                    <pf:DrawerContainer Height="160" Margin="0,0,0,14">
                                        <Grid Background="{DynamicResource SecondaryRegionBrush}">
                                            <pf:Drawer IsOpen="{Binding DrawerBottomOpen, Mode=TwoWay}"
                                                       Dock="Bottom" ShowMode="Press"
                                                       ShowMask="True" MaskCanClose="True">
                                                <Border Height="72" Background="{DynamicResource RegionBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                                                        Padding="16,8">
                                                    <TextBlock Text="Bottom Drawer · Press — 内容区向上收缩" FontWeight="Bold"
                                                               VerticalAlignment="Center"
                                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                                </Border>
                                            </pf:Drawer>
                                            <TextBlock Text="内容区域（Press 模式：Drawer 出现时内容被挤压）"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" />
                                            <ToggleButton Content="打开底部 Drawer"
                                                          HorizontalAlignment="Center" VerticalAlignment="Center"
                                                          IsChecked="{Binding DrawerBottomOpen, Mode=TwoWay}" />
                                        </Grid>
                                    </pf:DrawerContainer>

                                    <!-- ShowMask=False -->
                                    <TextBlock Text="ShowMask=False（无遮罩）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:DrawerContainer Height="140" Margin="0,0,0,4">
                                        <Grid Background="{DynamicResource SecondaryRegionBrush}">
                                            <pf:Drawer IsOpen="{Binding DrawerPressOpen, Mode=TwoWay}"
                                                       Dock="Left" ShowMode="Cover"
                                                       ShowMask="False">
                                                <Border Width="140" Background="{DynamicResource RegionBrush}"
                                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,1,0"
                                                        Padding="12,8">
                                                    <TextBlock Text="ShowMask=False&#x0a;点击内容区不自动关闭" FontWeight="Bold"
                                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                                </Border>
                                            </pf:Drawer>
                                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                <ToggleButton Content="切换（无遮罩）"
                                                              IsChecked="{Binding DrawerPressOpen, Mode=TwoWay}" />
                                            </StackPanel>
                                        </Grid>
                                    </pf:DrawerContainer>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:NavigationDemoViewModel.XamlDrawer}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 5. Ribbon ═══════════ -->
                    <Border x:Name="Section_Ribbon" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="5. Ribbon" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Ribbon → RibbonTab → RibbonGroup → 按钮/控件；三层层级结构"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <pf:Ribbon Margin="0,0,0,4">
                                        <pf:RibbonTab Header="文件">
                                            <pf:RibbonGroup Header="操作">
                                                <Button Content="新建" />
                                                <Button Content="打开" />
                                                <Button Content="保存" Style="{StaticResource ButtonPrimary}" />
                                            </pf:RibbonGroup>
                                            <pf:RibbonGroup Header="导出">
                                                <Button Content="导出 PDF" />
                                                <Button Content="导出 Excel" />
                                            </pf:RibbonGroup>
                                            <pf:RibbonGroup Header="历史">
                                                <Button Content="撤销" />
                                                <Button Content="重做" />
                                            </pf:RibbonGroup>
                                        </pf:RibbonTab>
                                        <pf:RibbonTab Header="编辑">
                                            <pf:RibbonGroup Header="剪贴板">
                                                <Button Content="剪切" />
                                                <Button Content="复制" />
                                                <Button Content="粘贴" Style="{StaticResource ButtonPrimary}" />
                                            </pf:RibbonGroup>
                                            <pf:RibbonGroup Header="格式">
                                                <ToggleButton Content="粗体" />
                                                <ToggleButton Content="斜体" />
                                                <ToggleButton Content="下划线" />
                                            </pf:RibbonGroup>
                                        </pf:RibbonTab>
                                        <pf:RibbonTab Header="视图">
                                            <pf:RibbonGroup Header="缩放">
                                                <Button Content="放大" />
                                                <Button Content="缩小" />
                                                <Button Content="100%" />
                                            </pf:RibbonGroup>
                                        </pf:RibbonTab>
                                    </pf:Ribbon>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:NavigationDemoViewModel.XamlRibbon}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
