<UserControl x:Class="PF.UI.Views.Demos.TextInputDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="2200" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:TextInputDemoViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="文本输入 TextInput" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="TextBox · WatermarkTextBox · SearchBar · PasswordBox · PinBox"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <Border Grid.Column="1" MinWidth="220" MaxWidth="340"
                        CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon Kind="Console" Width="14" Height="14"
                                     Foreground="{DynamicResource ThirdlyTextBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LastInputResult}"
                                   FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Consolas"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 主体：内容 + 右侧目录 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. TextBox 基础 ═══════════ -->
                    <Border x:Name="Section_TextBox基础" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. TextBox 基础" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="WatermarkTextBox — 带内置水印占位文字（TextBox 子类）"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="通过 Watermark 属性设置占位文字；注意 pf:IconElement.Geometry 在 WatermarkTextBox 上无效（模板无 Path）"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <UniformGrid Columns="2" Margin="0,0,0,10">
                                        <pf:WatermarkTextBox Watermark="请输入内容..." Margin="0,0,8,8" />
                                        <pf:WatermarkTextBox Watermark="右对齐水印"
                                                             HorizontalContentAlignment="Right"
                                                             Margin="0,0,0,8" />
                                        <TextBox Text="只读文本" IsReadOnly="True" Margin="0,0,8,8" />
                                        <TextBox Text="已禁用" IsEnabled="False" Margin="0,0,0,8" />
                                    </UniformGrid>
                                    <TextBlock Text="小号变体 (TextBox.Small)" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBox Style="{StaticResource TextBox.Small}"
                                             pf:InfoElement.Placeholder="小号输入框..."
                                             HorizontalAlignment="Left" Width="200" Margin="0,0,0,2" />
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:TextInputDemoViewModel.XamlTextBoxBasic}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. TextBox 扩展 ═══════════ -->
                    <Border x:Name="Section_TextBox扩展" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. TextBox 扩展 (TextBoxExtend)" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="pf:TitleElement.Title — 浮动标签；TitlePlacement — 标签位置"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />

                                    <TextBlock Text="默认布局 (Left)" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBox Style="{StaticResource TextBoxExtend}"
                                             pf:TitleElement.Title="用户名"
                                             pf:InfoElement.Placeholder="请输入用户名"
                                             Margin="0,0,0,12" />

                                    <TextBlock Text="Top 布局" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBox Style="{StaticResource TextBoxExtend}"
                                             pf:TitleElement.Title="邮箱"
                                             pf:TitleElement.TitlePlacement="Top"
                                             pf:InfoElement.Placeholder="user@example.com"
                                             Margin="0,0,0,12" />

                                    <TextBlock Text="Left 布局（显式指定）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBox Style="{StaticResource TextBoxExtend}"
                                             pf:TitleElement.Title="备注"
                                             pf:TitleElement.TitlePlacement="Left"
                                             pf:InfoElement.Placeholder="请输入备注内容"
                                             Margin="0,0,0,4" />

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:TextInputDemoViewModel.XamlTextBoxExtend}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. SearchBar ═══════════ -->
                    <Border x:Name="Section_SearchBar" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. SearchBar" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="TextBox 子类，按 Enter 或点击搜索图标触发 Command；IsRealTime=True 每次输入立即触发"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <TextBlock Text="普通搜索（回车触发）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:SearchBar pf:InfoElement.Placeholder="输入关键字按 Enter 搜索..."
                                                  Command="{Binding SearchCommand}"
                                                  CommandParameter="{Binding Text, RelativeSource={RelativeSource Self}}"
                                                  Margin="0,0,0,12" />

                                    <TextBlock Text="实时搜索（IsRealTime=True）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:SearchBar pf:InfoElement.Placeholder="每次输入立即触发..."
                                                  IsRealTime="True"
                                                  Command="{Binding SearchCommand}"
                                                  CommandParameter="{Binding Text, RelativeSource={RelativeSource Self}}"
                                                  Margin="0,0,0,12" />

                                    <TextBlock Text="扩展样式 · TitlePlacement=Top（上方标题）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:SearchBar Style="{StaticResource SearchBarExtend}"
                                                  pf:TitleElement.Title="搜索"
                                                  pf:TitleElement.TitlePlacement="Top"
                                                  pf:InfoElement.Placeholder="关键字..."
                                                  Command="{Binding SearchCommand}"
                                                  CommandParameter="{Binding Text, RelativeSource={RelativeSource Self}}"
                                                  Margin="0,0,0,12" />

                                    <TextBlock Text="扩展样式 · TitlePlacement=Left（左侧标题）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:SearchBar Style="{StaticResource SearchBarExtend}"
                                                  pf:TitleElement.Title="搜索"
                                                  pf:TitleElement.TitlePlacement="Left"
                                                  pf:TitleElement.TitleWidth="56"
                                                  pf:InfoElement.Placeholder="横向标题布局..."
                                                  Command="{Binding SearchCommand}"
                                                  CommandParameter="{Binding Text, RelativeSource={RelativeSource Self}}"
                                                  Margin="0,0,0,12" />

                                    <TextBlock Text="小号变体（SearchBar.Small）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:SearchBar Style="{StaticResource SearchBar.Small}"
                                                  pf:InfoElement.Placeholder="小号搜索框..."
                                                  Command="{Binding SearchCommand}"
                                                  CommandParameter="{Binding Text, RelativeSource={RelativeSource Self}}"
                                                  Margin="0,0,0,4" />

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:TextInputDemoViewModel.XamlSearchBar}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 4. PasswordBox ═══════════ -->
                    <Border x:Name="Section_PasswordBox" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="4. PasswordBox" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ShowEyeButton — 显示/隐藏密码；IsSafeEnabled=False 可绑定 UnsafePassword"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <TextBlock Text="带眼睛图标" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:PasswordBox pf:InfoElement.Placeholder="请输入密码"
                                                    ShowEyeButton="True"
                                                    Margin="0,0,0,12" />

                                    <TextBlock Text="关闭安全模式（可绑定密码）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:PasswordBox pf:InfoElement.Placeholder="可绑定 UnsafePassword"
                                                    IsSafeEnabled="False"
                                                    ShowEyeButton="True"
                                                    Margin="0,0,0,12" />

                                    <TextBlock Text="小号变体 (PasswordBoxPlus.Small)" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:PasswordBox Style="{StaticResource PasswordBoxPlus.Small}"
                                                    pf:InfoElement.Placeholder="小号密码框"
                                                    ShowEyeButton="True"
                                                    HorizontalAlignment="Left" Width="240"
                                                    Margin="0,0,0,4" />

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:TextInputDemoViewModel.XamlPasswordBox}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 5. PinBox ═══════════ -->
                    <Border x:Name="Section_PinBox" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="5. PinBox" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="验证码 / PIN 分格输入，Length 控制位数"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <TextBlock Text="6 位验证码" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:PinBox Length="6" Margin="0,0,0,12" />

                                    <TextBlock Text="4 位 PIN（密码模式）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:PinBox Length="4" PasswordChar="●" Margin="0,0,0,4" />

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:TextInputDemoViewModel.XamlPinBox}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 6. 多行文本 ═══════════ -->
                    <Border x:Name="Section_MultiLine" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="6. 多行文本" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="AcceptsReturn=True + TextWrapping=Wrap 启用多行，VerticalScrollBarVisibility 控制滚动条"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <TextBlock Text="多行 TextBox" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBox AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             Height="90"
                                             VerticalScrollBarVisibility="Auto"
                                             pf:InfoElement.Placeholder="请输入多行文本..."
                                             Margin="0,0,0,10" />

                                    <TextBlock Text="多行 WatermarkTextBox" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <pf:WatermarkTextBox AcceptsReturn="True"
                                                         TextWrapping="Wrap"
                                                         Height="90"
                                                         VerticalScrollBarVisibility="Auto"
                                                         Watermark="支持多行的水印文本框..."
                                                         Margin="0,0,0,4" />

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:TextInputDemoViewModel.XamlMultiLine}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
