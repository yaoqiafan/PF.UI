<UserControl x:Class="PF.UI.Views.Demos.ProgressLoadingView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="1200" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:ProgressLoadingViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="加载与进度 Progress / Loading" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="LoadingCircle · LoadingLine · ProgressBar · CircleProgress · WaveProgress · ConfettiCannon"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <Border Grid.Column="1" MinWidth="200" MaxWidth="340"
                        CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon Kind="Console" Width="14" Height="14"
                                     Foreground="{DynamicResource ThirdlyTextBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LastResult}" FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. LoadingCircle ═══════════ -->
                    <Border x:Name="Section_LoadingCircle" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. LoadingCircle" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="IsRunning 控制动画启停；Foreground 控制颜色"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <!-- 默认 / 颜色 / Large / Light / LargeLight -->
                                    <UniformGrid Columns="5" Margin="0,0,0,4">
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:LoadingCircle IsRunning="{Binding IsRunning}" HorizontalAlignment="Center" />
                                            <TextBlock Text="默认" FontSize="9" HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:LoadingCircle IsRunning="{Binding IsRunning}"
                                                              Foreground="{DynamicResource SuccessBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Text="颜色" FontSize="9" HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:LoadingCircle IsRunning="{Binding IsRunning}"
                                                              Style="{StaticResource LoadingCircleLarge}" HorizontalAlignment="Center" />
                                            <TextBlock Text="Large" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="6" Padding="8" HorizontalAlignment="Center">
                                                <pf:LoadingCircle IsRunning="{Binding IsRunning}"
                                                                  Style="{StaticResource LoadingCircleLight}" />
                                            </Border>
                                            <TextBlock Text="Light" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="6" Padding="8" HorizontalAlignment="Center">
                                                <pf:LoadingCircle IsRunning="{Binding IsRunning}"
                                                                  Style="{StaticResource LoadingCircleLargeLight}" />
                                            </Border>
                                            <TextBlock Text="LargeLight" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="4"
                                            Padding="10,6" HorizontalAlignment="Left" Margin="0,8,0,4">
                                        <CheckBox IsChecked="{Binding IsRunning}" Content="运行中"
                                                  Foreground="{DynamicResource PrimaryTextBrush}" />
                                    </Border>
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:ProgressLoadingViewModel.XamlLoadingCircle}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. LoadingLine ═══════════ -->
                    <Border x:Name="Section_LoadingLine" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. LoadingLine" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="线性加载动画，常驻或 IsRunning 控制"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <pf:LoadingLine IsRunning="{Binding IsRunning}" Margin="0,0,0,6" />
                                    <TextBlock Text="Large" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,6" />
                                    <pf:LoadingLine IsRunning="{Binding IsRunning}" Style="{StaticResource LoadingLineLarge}" Margin="0,0,0,6" />
                                    <TextBlock Text="LargeLight（深色背景）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,6" />
                                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="6" Padding="8,6" Margin="0,0,0,4">
                                        <pf:LoadingLine IsRunning="{Binding IsRunning}" Style="{StaticResource LoadingLineLargeLight}" />
                                    </Border>
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:ProgressLoadingViewModel.XamlLoadingLine}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. ProgressBar ═══════════ -->
                    <Border x:Name="Section_ProgressBar" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. ProgressBar" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="原生 ProgressBar + PF.UI ProgressBarFlat 样式；拖动滑块调节值"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <TextBlock Text="Value: {Binding ProgressValue, StringFormat={}{0:F0}}" FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <Slider Minimum="0" Maximum="100" Value="{Binding ProgressValue, Mode=TwoWay}"
                                            Margin="0,0,0,10" />

                                    <TextBlock Text="默认样式" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <ProgressBar Value="{Binding ProgressValue}" Height="8" Margin="0,0,0,14" />

                                    <TextBlock Text="ProgressBarFlat 样式" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <ProgressBar Style="{StaticResource ProgressBarFlat}" Value="{Binding ProgressValue}"
                                                 Height="8" Margin="0,0,0,4" />

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:ProgressLoadingViewModel.XamlProgressBar}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 4. CircleProgress ═══════════ -->
                    <Border x:Name="Section_CircleProgress" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="4. CircleProgressBar" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="圆形百分比进度；调节上方 ProgressBar 的滑块查看效果"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <!-- 4 种状态色 Style -->
                                    <TextBlock Text="状态色 Style" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <UniformGrid Columns="5" Margin="0,0,0,14">
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:CircleProgressBar Value="{Binding ProgressValue}" Width="72" Height="72" HorizontalAlignment="Center" />
                                            <TextBlock Text="Default" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:CircleProgressBar Value="{Binding ProgressValue}" Width="72" Height="72"
                                                                  Style="{StaticResource ProgressBarSuccessCircle}" HorizontalAlignment="Center" />
                                            <TextBlock Text="Success" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:CircleProgressBar Value="{Binding ProgressValue}" Width="72" Height="72"
                                                                  Style="{StaticResource ProgressBarInfoCircle}" HorizontalAlignment="Center" />
                                            <TextBlock Text="Info" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:CircleProgressBar Value="{Binding ProgressValue}" Width="72" Height="72"
                                                                  Style="{StaticResource ProgressBarWarningCircle}" HorizontalAlignment="Center" />
                                            <TextBlock Text="Warning" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:CircleProgressBar Value="{Binding ProgressValue}" Width="72" Height="72"
                                                                  Style="{StaticResource ProgressBarDangerCircle}" HorizontalAlignment="Center" />
                                            <TextBlock Text="Danger" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <!-- IsIndeterminate + ArcThickness + ShowText=False -->
                                    <TextBlock Text="IsIndeterminate · ArcThickness · ShowText" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <UniformGrid Columns="4" Margin="0,0,0,4">
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:CircleProgressBar IsIndeterminate="True" Width="72" Height="72" HorizontalAlignment="Center" />
                                            <TextBlock Text="IsIndeterminate" FontSize="9" FontFamily="Consolas" TextWrapping="Wrap"
                                                       TextAlignment="Center" HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:CircleProgressBar Value="{Binding ProgressValue}" Width="72" Height="72"
                                                                  ArcThickness="12" HorizontalAlignment="Center" />
                                            <TextBlock Text="ArcThickness=12" FontSize="9" FontFamily="Consolas" TextWrapping="Wrap"
                                                       TextAlignment="Center" HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:CircleProgressBar Value="{Binding ProgressValue}" Width="72" Height="72"
                                                                  ShowText="False" HorizontalAlignment="Center" />
                                            <TextBlock Text="ShowText=False" FontSize="9" FontFamily="Consolas" TextWrapping="Wrap"
                                                       TextAlignment="Center" HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:CircleProgressBar Value="{Binding ProgressValue}" Width="72" Height="72"
                                                                  Style="{StaticResource ProgressBarSuccessCircle}"
                                                                  ArcThickness="6" ShowText="True"
                                                                  Text="{Binding ProgressValue, StringFormat={}{0:F0}%}"
                                                                  HorizontalAlignment="Center" />
                                            <TextBlock Text="自定义 Text" FontSize="9" FontFamily="Consolas" TextWrapping="Wrap"
                                                       TextAlignment="Center" HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:ProgressLoadingViewModel.XamlCircleProgress}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 5. WaveProgress ═══════════ -->
                    <Border x:Name="Section_WaveProgress" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="5. WaveProgressBar" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="波浪百分比进度动画；调节上方 ProgressBar 的滑块查看效果"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <!-- 4 种状态色 Style -->
                                    <TextBlock Text="状态色 Style" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <UniformGrid Columns="5" Margin="0,0,0,14">
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:WaveProgressBar Value="{Binding ProgressValue}" Width="72" Height="72" HorizontalAlignment="Center" />
                                            <TextBlock Text="Default" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:WaveProgressBar Value="{Binding ProgressValue}" Width="72" Height="72"
                                                                Style="{StaticResource ProgressBarSuccessWave}" HorizontalAlignment="Center" />
                                            <TextBlock Text="Success" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:WaveProgressBar Value="{Binding ProgressValue}" Width="72" Height="72"
                                                                Style="{StaticResource ProgressBarInfoWave}" HorizontalAlignment="Center" />
                                            <TextBlock Text="Info" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:WaveProgressBar Value="{Binding ProgressValue}" Width="72" Height="72"
                                                                Style="{StaticResource ProgressBarWarningWave}" HorizontalAlignment="Center" />
                                            <TextBlock Text="Warning" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:WaveProgressBar Value="{Binding ProgressValue}" Width="72" Height="72"
                                                                Style="{StaticResource ProgressBarDangerWave}" HorizontalAlignment="Center" />
                                            <TextBlock Text="Danger" FontSize="9" FontFamily="Consolas" HorizontalAlignment="Center" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </UniformGrid>

                                    <!-- WaveThickness + WaveStroke + WaveFill + ShowText -->
                                    <TextBlock Text="WaveThickness · WaveStroke · WaveFill · ShowText" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <UniformGrid Columns="4" Margin="0,0,0,4">
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:WaveProgressBar Value="{Binding ProgressValue}" Width="72" Height="72"
                                                                WaveThickness="6" HorizontalAlignment="Center" />
                                            <TextBlock Text="WaveThickness=6" FontSize="9" FontFamily="Consolas" TextWrapping="Wrap"
                                                       TextAlignment="Center" HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:WaveProgressBar Value="{Binding ProgressValue}" Width="72" Height="72"
                                                                WaveStroke="{DynamicResource DangerBrush}" HorizontalAlignment="Center" />
                                            <TextBlock Text="WaveStroke" FontSize="9" FontFamily="Consolas" TextWrapping="Wrap"
                                                       TextAlignment="Center" HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:WaveProgressBar Value="{Binding ProgressValue}" Width="72" Height="72"
                                                                HorizontalAlignment="Center">
                                                <pf:WaveProgressBar.WaveFill>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="{DynamicResource PrimaryColor}" Offset="0" />
                                                        <GradientStop Color="{DynamicResource InfoColor}" Offset="1" />
                                                    </LinearGradientBrush>
                                                </pf:WaveProgressBar.WaveFill>
                                            </pf:WaveProgressBar>
                                            <TextBlock Text="WaveFill渐变" FontSize="9" FontFamily="Consolas" TextWrapping="Wrap"
                                                       TextAlignment="Center" HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                        <StackPanel HorizontalAlignment="Center">
                                            <pf:WaveProgressBar Value="{Binding ProgressValue}" Width="72" Height="72"
                                                                ShowText="False" HorizontalAlignment="Center" />
                                            <TextBlock Text="ShowText=False" FontSize="9" FontFamily="Consolas" TextWrapping="Wrap"
                                                       TextAlignment="Center" HorizontalAlignment="Center"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,6,0,0" />
                                        </StackPanel>
                                    </UniformGrid>
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:ProgressLoadingViewModel.XamlWaveProgress}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 6. ConfettiCannon ═══════════ -->
                    <Border x:Name="Section_Confetti" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="6. ConfettiCannon" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" TextWrapping="Wrap"
                                               Text="静态方法 ConfettiCannon.Fire(options) 在 AdornerLayer 播放彩纸动画。ConfettiCannonContainer（AdornerDecorator）提供本地 AdornerLayer。" />

                                    <!-- 效果选择 + 触发按钮 -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <TextBlock Text="效果预设：" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" Margin="0,0,8,0" />
                                        <ComboBox ItemsSource="{Binding ConfettiPresets}"
                                                  DisplayMemberPath="Name"
                                                  SelectedIndex="{Binding SelectedPresetIndex, Mode=TwoWay}"
                                                  Width="140" VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <Button Content="🎊 发射！" Command="{Binding FireCommand}"
                                                Style="{StaticResource ButtonPrimary}"
                                                Height="32" Padding="16,0" VerticalAlignment="Center" />
                                    </StackPanel>

                                    <pf:ConfettiCannonContainer Height="180">
                                        <Border Background="{DynamicResource SecondaryRegionBrush}"
                                                CornerRadius="6">
                                            <Grid>
                                                <TextBlock Text="彩纸将在此区域内的 AdornerLayer 中播放" HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"
                                                           Foreground="{DynamicResource ThirdlyTextBrush}" FontSize="11" />
                                            </Grid>
                                        </Border>
                                    </pf:ConfettiCannonContainer>
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:ProgressLoadingViewModel.XamlConfetti}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
