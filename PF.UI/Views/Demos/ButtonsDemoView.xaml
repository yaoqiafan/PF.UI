<UserControl x:Class="PF.UI.Views.Demos.ButtonsDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
              d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:ButtonsDemoViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头：左标题 + 右交互日志 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="按钮 Button" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="Button · ToggleButton · RadioButton · RepeatButton · ProgressButton · SplitButton · Shield · ButtonGroup"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <Border Grid.Column="1" MinWidth="220" MaxWidth="340"
                        CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon Kind="Console" Width="14" Height="14"
                                     Foreground="{DynamicResource ThirdlyTextBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LastClickResult}"
                                   FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Consolas"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 主体：内容 + 右侧目录 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. 基础按钮 Button ═══════════ -->
                    <Border x:Name="Section_基础按钮" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. 基础按钮 (Button)" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <!-- 实心 6 色 -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="实心按钮 (Solid) — 6 种语义色" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="ButtonDefault / Primary / Success / Info / Warning / Danger"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,8">
                                        <Button Style="{StaticResource ButtonDefault}" Content="默认" Margin="0,0,10,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="默认按钮" />
                                        <Button Style="{StaticResource ButtonPrimary}" Content="主要" Margin="0,0,10,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="主要按钮" />
                                        <Button Style="{StaticResource ButtonSuccess}" Content="成功" Margin="0,0,10,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="成功按钮" />
                                        <Button Style="{StaticResource ButtonInfo}" Content="信息" Margin="0,0,10,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="信息按钮" />
                                        <Button Style="{StaticResource ButtonWarning}" Content="警告" Margin="0,0,10,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="警告按钮" />
                                        <Button Style="{StaticResource ButtonDanger}" Content="危险" Margin="0,0,10,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="危险按钮" />
                                    </WrapPanel>

                                    <!-- 小号 -->
                                    <TextBlock Text="小号变体 (.Small)" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <WrapPanel Margin="0,0,0,8">
                                        <Button Style="{StaticResource ButtonDefault.Small}" Content="默认" Margin="0,0,8,4" />
                                        <Button Style="{StaticResource ButtonPrimary.Small}" Content="主要" Margin="0,0,8,4" />
                                        <Button Style="{StaticResource ButtonSuccess.Small}" Content="成功" Margin="0,0,8,4" />
                                        <Button Style="{StaticResource ButtonInfo.Small}" Content="信息" Margin="0,0,8,4" />
                                        <Button Style="{StaticResource ButtonWarning.Small}" Content="警告" Margin="0,0,8,4" />
                                        <Button Style="{StaticResource ButtonDanger.Small}" Content="危险" Margin="0,0,8,4" />
                                    </WrapPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlButtonSolid}" />
                                </StackPanel>
                            </Border>

                            <!-- 虚线 6 色 -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="虚线按钮 (Dashed) — 6 种语义色" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="ButtonDashed / DashedPrimary / DashedSuccess / DashedInfo / DashedWarning / DashedDanger"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,6">
                                        <Button Style="{StaticResource ButtonDashed}" Content="默认" Margin="0,0,10,6" />
                                        <Button Style="{StaticResource ButtonDashedPrimary}" Content="主要" Margin="0,0,10,6" />
                                        <Button Style="{StaticResource ButtonDashedSuccess}" Content="成功" Margin="0,0,10,6" />
                                        <Button Style="{StaticResource ButtonDashedInfo}" Content="信息" Margin="0,0,10,6" />
                                        <Button Style="{StaticResource ButtonDashedWarning}" Content="警告" Margin="0,0,10,6" />
                                        <Button Style="{StaticResource ButtonDashedDanger}" Content="危险" Margin="0,0,10,6" />
                                    </WrapPanel>
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,8,0,0"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlButtonDashed}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. 图标按钮 ButtonIcon ═══════════ -->
                    <Border x:Name="Section_图标按钮" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. 图标按钮 (ButtonIcon)" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="方形图标 (ButtonIcon) + 圆形图标 (ButtonIconCircular)"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,8">
                                        <Button Style="{StaticResource ButtonIcon}" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="收藏">
                                            <pf:PackIcon Kind="Heart" Width="16" Height="16" />
                                        </Button>
                                        <Button Style="{StaticResource ButtonIcon}" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="评分">
                                            <pf:PackIcon Kind="Star" Width="16" Height="16" />
                                        </Button>
                                        <Button Style="{StaticResource ButtonIcon}" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="点赞">
                                            <pf:PackIcon Kind="ThumbUp" Width="16" Height="16" />
                                        </Button>
                                        <Button Style="{StaticResource ButtonIcon}" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="分享">
                                            <pf:PackIcon Kind="ShareVariant" Width="16" Height="16" />
                                        </Button>
                                    </WrapPanel>

                                    <TextBlock Text="圆形 (Circular)" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <WrapPanel Margin="0,0,0,10">
                                        <Button Style="{StaticResource ButtonIconCircular}" Width="40" Height="40" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="播放">
                                            <pf:PackIcon Kind="Play" Width="18" Height="18" />
                                        </Button>
                                        <Button Style="{StaticResource ButtonIconCircular}" Width="40" Height="40" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="暂停">
                                            <pf:PackIcon Kind="Pause" Width="18" Height="18" />
                                        </Button>
                                        <Button Style="{StaticResource ButtonIconCircular}" Width="40" Height="40" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="停止">
                                            <pf:PackIcon Kind="Stop" Width="18" Height="18" />
                                        </Button>
                                    </WrapPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlIconButtons}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. ToggleButton 切换按钮 ═══════════ -->
                    <Border x:Name="Section_切换按钮" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. 切换按钮 (ToggleButton)" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <!-- ToggleButton 实心 -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="实心切换 (ToggleButton Solid)" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="ToggleButtonDefault / Primary / Success / Info / Warning / Danger — 所有 .Small 变体"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,8">
                                        <ToggleButton Style="{StaticResource ToggleButtonDefault}" Content="默认" Margin="0,0,8,8" />
                                        <ToggleButton Style="{StaticResource ToggleButtonPrimary}" Content="主要" Margin="0,0,8,8" />
                                        <ToggleButton Style="{StaticResource ToggleButtonSuccess}" Content="成功" Margin="0,0,8,8" />
                                        <ToggleButton Style="{StaticResource ToggleButtonInfo}" Content="信息" Margin="0,0,8,8" />
                                        <ToggleButton Style="{StaticResource ToggleButtonWarning}" Content="警告" Margin="0,0,8,8" />
                                        <ToggleButton Style="{StaticResource ToggleButtonDanger}" Content="危险" Margin="0,0,8,8" />
                                    </WrapPanel>

                                    <!-- 带双向绑定的 ToggleButton -->
                                    <Border CornerRadius="4" Padding="10,8"
                                            Background="{DynamicResource SecondaryRegionBrush}" Margin="0,4,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <ToggleButton Content="点击切换状态"
                                                          IsChecked="{Binding ToggleChecked, Mode=TwoWay}"
                                                          VerticalAlignment="Center" Margin="0,0,12,0" />
                                            <TextBlock Text="{Binding ToggleLabel}" FontSize="12" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                        </StackPanel>
                                    </Border>

                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlToggleSolid}" />
                                </StackPanel>
                            </Border>

                            <!-- ToggleButtonIcon -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="图标切换 (ToggleButtonIcon)" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="通过 pf:IconSwitchElement.Geometry / GeometrySelected 设置未选中/选中态图标，点击可切换"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,8">
                                        <ToggleButton Style="{StaticResource ToggleButtonIcon}" Margin="0,0,6,8"
                                                      pf:IconSwitchElement.Geometry="{StaticResource EyeOpenGeometry}"
                                                      pf:IconSwitchElement.GeometrySelected="{StaticResource EyeCloseGeometry}" />
                                        <ToggleButton Style="{StaticResource ToggleButtonIconPrimary}" Margin="0,0,6,8"
                                                      pf:IconSwitchElement.Geometry="{StaticResource FullScreenGeometry}"
                                                      pf:IconSwitchElement.GeometrySelected="{StaticResource FullScreenReturnGeometry}" />
                                        <ToggleButton Style="{StaticResource ToggleButtonIconSuccess}" Margin="0,0,6,8"
                                                      pf:IconSwitchElement.Geometry="{StaticResource EnlargeGeometry}"
                                                      pf:IconSwitchElement.GeometrySelected="{StaticResource ReduceGeometry}" />
                                        <ToggleButton Style="{StaticResource ToggleButtonIconInfo}" Margin="0,0,6,8"
                                                      pf:IconSwitchElement.Geometry="{StaticResource DownGeometry}"
                                                      pf:IconSwitchElement.GeometrySelected="{StaticResource UpGeometry}" />
                                        <ToggleButton Style="{StaticResource ToggleButtonIconWarning}" Margin="0,0,6,8"
                                                      pf:IconSwitchElement.Geometry="{StaticResource RotateLeftGeometry}"
                                                      pf:IconSwitchElement.GeometrySelected="{StaticResource RotateRightGeometry}" />
                                        <ToggleButton Style="{StaticResource ToggleButtonIconDanger}" Margin="0,0,6,8"
                                                      pf:IconSwitchElement.Geometry="{StaticResource DeleteGeometry}"
                                                      pf:IconSwitchElement.GeometrySelected="{StaticResource CloseGeometry}" />
                                    </WrapPanel>

                                    <TextBlock Text="透明背景 (ToggleButtonIconTransparent)" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <WrapPanel Margin="0,0,0,8">
                                        <ToggleButton Style="{StaticResource ToggleButtonIconTransparent}" Margin="0,0,6,8"
                                                      pf:IconSwitchElement.Geometry="{StaticResource LeftGeometry}"
                                                      pf:IconSwitchElement.GeometrySelected="{StaticResource RightGeometry}" />
                                        <ToggleButton Style="{StaticResource ToggleButtonIconTransparent}" Margin="0,0,6,8"
                                                      pf:IconSwitchElement.Geometry="{StaticResource UpGeometry}"
                                                      pf:IconSwitchElement.GeometrySelected="{StaticResource DownGeometry}" />
                                        <ToggleButton Style="{StaticResource ToggleButtonIconTransparent}" Margin="0,0,6,8"
                                                      pf:IconSwitchElement.Geometry="{StaticResource SearchGeometry}"
                                                      pf:IconSwitchElement.GeometrySelected="{StaticResource CloseGeometry}" />
                                    </WrapPanel>
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,8,0,0"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlToggleIcon}" />
                                </StackPanel>
                            </Border>

                            <!-- ToggleButtonSwitch + ToggleButtonFlip + ToggleButtonLoading -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="开关 (Switch) · 翻转 (Flip) · 加载中 (Loading)"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />

                                    <TextBlock Text="ToggleButtonSwitch — 开关样式" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <ToggleButton Style="{StaticResource ToggleButtonSwitch}" Content="开关" Margin="0,0,12,0" />
                                        <ToggleButton Style="{StaticResource ToggleButtonSwitch.Small}" Content="小开关" />
                                    </StackPanel>

                                    <TextBlock Text="ToggleButtonFlip — 翻转样式" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                        <ToggleButton Style="{StaticResource ToggleButtonFlip}" Content="翻转" Margin="0,0,12,0" />
                                        <ToggleButton Style="{StaticResource ToggleButtonFlip.Small}" Content="小翻转" />
                                    </StackPanel>

                                    <TextBlock Text="ToggleButtonLoading — 加载中切换" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <WrapPanel Margin="0,0,0,8">
                                        <ToggleButton Style="{StaticResource ToggleButtonLoading}" Content="加载" Margin="0,0,8,6" />
                                        <ToggleButton Style="{StaticResource ToggleButtonLoadingPrimary}" Content="主要" Margin="0,0,8,6" />
                                        <ToggleButton Style="{StaticResource ToggleButtonLoadingSuccess}" Content="成功" Margin="0,0,8,6" />
                                        <ToggleButton Style="{StaticResource ToggleButtonLoadingInfo}" Content="信息" Margin="0,0,8,6" />
                                        <ToggleButton Style="{StaticResource ToggleButtonLoadingWarning}" Content="警告" Margin="0,0,8,6" />
                                        <ToggleButton Style="{StaticResource ToggleButtonLoadingDanger}" Content="危险" Margin="0,0,8,6" />
                                    </WrapPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlToggleSwitch}" />
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,8,0,0"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlToggleLoading}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 4. RadioButton 单选按钮 ═══════════ -->
                    <Border x:Name="Section_单选按钮" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="4. 单选按钮 (RadioButton)" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <!-- RadioButtonSameAsButton -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="按钮风格单选 (RadioButtonSameAsButton)" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="外观与普通按钮相同，但具有 RadioButton 互斥行为"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,8">
                                        <RadioButton Style="{StaticResource RadioButtonSameAsButtonDefault}" Content="默认"
                                                     GroupName="DemoGrp1" Margin="0,0,8,6"
                                                     Command="{Binding RadioCheckedCommand}" CommandParameter="默认" />
                                        <RadioButton Style="{StaticResource RadioButtonSameAsButtonPrimary}" Content="主要"
                                                     GroupName="DemoGrp1" Margin="0,0,8,6"
                                                     Command="{Binding RadioCheckedCommand}" CommandParameter="主要" />
                                        <RadioButton Style="{StaticResource RadioButtonSameAsButtonSuccess}" Content="成功"
                                                     GroupName="DemoGrp1" Margin="0,0,8,6"
                                                     Command="{Binding RadioCheckedCommand}" CommandParameter="成功" />
                                        <RadioButton Style="{StaticResource RadioButtonSameAsButtonInfo}" Content="信息"
                                                     GroupName="DemoGrp1" Margin="0,0,8,6"
                                                     Command="{Binding RadioCheckedCommand}" CommandParameter="信息" />
                                        <RadioButton Style="{StaticResource RadioButtonSameAsButtonWarning}" Content="警告"
                                                     GroupName="DemoGrp1" Margin="0,0,8,6"
                                                     Command="{Binding RadioCheckedCommand}" CommandParameter="警告" />
                                        <RadioButton Style="{StaticResource RadioButtonSameAsButtonDanger}" Content="危险"
                                                     GroupName="DemoGrp1" Margin="0,0,8,6"
                                                     Command="{Binding RadioCheckedCommand}" CommandParameter="危险" />
                                    </WrapPanel>
                                    <TextBlock Text="{Binding SelectedRadio, StringFormat='当前选中: {0}'}"
                                               FontSize="12"
                                               Foreground="{DynamicResource SecondaryTextBrush}"
                                               Margin="0,0,0,8" />
                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlRadioSameAsButton}" />
                                </StackPanel>
                            </Border>

                            <!-- RadioButtonIcon -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="图标单选 (RadioButtonIcon)" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,8">
                                        <RadioButton Style="{StaticResource RadioButtonIcon}" GroupName="AlignGrp" Margin="0,0,6,8">
                                            <pf:PackIcon Kind="FormatAlignLeft" Width="16" Height="16" />
                                        </RadioButton>
                                        <RadioButton Style="{StaticResource RadioButtonIcon}" GroupName="AlignGrp" Margin="0,0,6,8">
                                            <pf:PackIcon Kind="FormatAlignCenter" Width="16" Height="16" />
                                        </RadioButton>
                                        <RadioButton Style="{StaticResource RadioButtonIcon}" GroupName="AlignGrp" Margin="0,0,6,8">
                                            <pf:PackIcon Kind="FormatAlignRight" Width="16" Height="16" />
                                        </RadioButton>
                                        <RadioButton Style="{StaticResource RadioButtonIcon}" GroupName="AlignGrp" Margin="0,0,6,8">
                                            <pf:PackIcon Kind="FormatAlignJustify" Width="16" Height="16" />
                                        </RadioButton>
                                    </WrapPanel>
                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlRadioIcon}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 5. RepeatButton 长按按钮 ═══════════ -->
                    <Border x:Name="Section_长按重复" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="5. 长按按钮 (RepeatButton)" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <!-- RepeatButton Solid -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="实心 RepeatButton + 长按计数器" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="RepeatButtonDefault / Primary / Success / Info / Warning / Danger"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,8">
                                        <RepeatButton Style="{StaticResource RepeatButtonDefault}" Content="默认" Margin="0,0,8,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                        <RepeatButton Style="{StaticResource RepeatButtonPrimary}" Content="主要" Margin="0,0,8,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                        <RepeatButton Style="{StaticResource RepeatButtonSuccess}" Content="成功" Margin="0,0,8,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                        <RepeatButton Style="{StaticResource RepeatButtonInfo}" Content="信息" Margin="0,0,8,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                        <RepeatButton Style="{StaticResource RepeatButtonWarning}" Content="警告" Margin="0,0,8,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                        <RepeatButton Style="{StaticResource RepeatButtonDanger}" Content="危险" Margin="0,0,8,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                    </WrapPanel>

                                    <!-- 长按计数器展示 -->
                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="4"
                                            Padding="10,8" HorizontalAlignment="Left" Margin="0,0,0,8">
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="长按任意 RepeatButton 递增 → " FontSize="12"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center" />
                                            <TextBlock Text="{Binding RepeatCount}" FontSize="18" FontWeight="Bold"
                                                       Foreground="{DynamicResource PrimaryBrush}" VerticalAlignment="Center"
                                                       Margin="4,0" />
                                            <TextBlock Text="{Binding RepeatLabel, StringFormat='({0})'}" FontSize="12"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlRepeat}" />
                                </StackPanel>
                            </Border>

                            <!-- RepeatButton Dashed -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="虚线 RepeatButton (Dashed) — 6 色" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="RepeatButtonDashed / DashedPrimary / DashedSuccess / DashedInfo / DashedWarning / DashedDanger"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,4">
                                        <RepeatButton Style="{StaticResource RepeatButtonDashed}" Content="默认" Margin="0,0,8,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                        <RepeatButton Style="{StaticResource RepeatButtonDashedPrimary}" Content="主要" Margin="0,0,8,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                        <RepeatButton Style="{StaticResource RepeatButtonDashedSuccess}" Content="成功" Margin="0,0,8,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                        <RepeatButton Style="{StaticResource RepeatButtonDashedInfo}" Content="信息" Margin="0,0,8,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                        <RepeatButton Style="{StaticResource RepeatButtonDashedWarning}" Content="警告" Margin="0,0,8,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                        <RepeatButton Style="{StaticResource RepeatButtonDashedDanger}" Content="危险" Margin="0,0,8,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- RepeatButtonIcon / Circular -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="图标 RepeatButton — RepeatButtonIcon / RepeatButtonIconCircular"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="支持 Content (PackIcon) 或 pf:IconElement.Geometry 两种方式指定图标"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />

                                    <TextBlock Text="方形图标 (RepeatButtonIcon)" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <WrapPanel Margin="0,0,0,10">
                                        <RepeatButton Style="{StaticResource RepeatButtonIcon}" Margin="0,0,6,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}">
                                            <pf:PackIcon Kind="Plus" Width="14" Height="14" />
                                        </RepeatButton>
                                        <RepeatButton Style="{StaticResource RepeatButtonIcon}" Margin="0,0,6,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}">
                                            <pf:PackIcon Kind="Minus" Width="14" Height="14" />
                                        </RepeatButton>
                                        <RepeatButton Style="{StaticResource RepeatButtonIcon}" Margin="0,0,6,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}">
                                            <pf:PackIcon Kind="ChevronLeft" Width="14" Height="14" />
                                        </RepeatButton>
                                        <RepeatButton Style="{StaticResource RepeatButtonIcon}" Margin="0,0,6,6"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}">
                                            <pf:PackIcon Kind="ChevronRight" Width="14" Height="14" />
                                        </RepeatButton>
                                    </WrapPanel>

                                    <TextBlock Text="圆形图标 (RepeatButtonIconCircular)" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                    <WrapPanel Margin="0,0,0,8">
                                        <RepeatButton Style="{StaticResource RepeatButtonIconCircular}" Width="36" Height="36" Margin="0,0,6,6"
                                                      pf:IconElement.Geometry="{StaticResource UpGeometry}"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                        <RepeatButton Style="{StaticResource RepeatButtonIconCircular}" Width="36" Height="36" Margin="0,0,6,6"
                                                      pf:IconElement.Geometry="{StaticResource DownGeometry}"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                        <RepeatButton Style="{StaticResource RepeatButtonIconCircular}" Width="36" Height="36" Margin="0,0,6,6"
                                                      pf:IconElement.Geometry="{StaticResource LeftGeometry}"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                        <RepeatButton Style="{StaticResource RepeatButtonIconCircular}" Width="36" Height="36" Margin="0,0,6,6"
                                                      pf:IconElement.Geometry="{StaticResource RightGeometry}"
                                                      Delay="500" Interval="100" Command="{Binding IncrementRepeatCommand}" />
                                    </WrapPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlRepeatIcon}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 6. ProgressButton 进度按钮 ═══════════ -->
                    <Border x:Name="Section_进度按钮" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="6. 进度按钮 (ProgressButton)" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="带进度条的按钮" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="ProgressButtonPrimary / Success / Info / Warning / Danger"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <pf:ProgressButton Content="点击开始上传" Width="160"
                                                      IsChecked="{Binding IsBusy}"
                                                      Progress="{Binding ProgressValue}"
                                                      Command="{Binding StartProgressCommand}"
                                                      Margin="0,0,0,8" />
                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="4"
                                            Padding="8,4" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding ProgressValue, StringFormat='进度: {0:F0}%'}"
                                                   FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </Border>
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,12,0,0"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlProgressButton}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 7. SplitButton 分割按钮 ═══════════ -->
                    <Border x:Name="Section_分割按钮" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="7. 分割按钮 (SplitButton)" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="SplitButton 6 色" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="SplitButtonDefault / Primary / Success / Info / Warning / Danger"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,10">
                                        <pf:SplitButton Content="默认" Width="110" Style="{StaticResource SplitButtonDefault}"
                                                        Margin="0,0,8,6" />
                                        <pf:SplitButton Content="主要" Width="110" Style="{StaticResource SplitButtonPrimary}"
                                                        Margin="0,0,8,6" />
                                        <pf:SplitButton Content="成功" Width="110" Style="{StaticResource SplitButtonSuccess}"
                                                        Margin="0,0,8,6" />
                                        <pf:SplitButton Content="信息" Width="110" Style="{StaticResource SplitButtonInfo}"
                                                        Margin="0,0,8,6" />
                                        <pf:SplitButton Content="警告" Width="110" Style="{StaticResource SplitButtonWarning}"
                                                        Margin="0,0,8,6" />
                                        <pf:SplitButton Content="危险" Width="110" Style="{StaticResource SplitButtonDanger}"
                                                        Margin="0,0,8,6" />
                                    </WrapPanel>

                                    <TextBlock Text="带下拉菜单 (点击箭头展开)" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <pf:SplitButton Content="保存" Width="140"
                                                    Style="{StaticResource SplitButtonPrimary}"
                                                    Margin="0,0,0,8">
                                        <pf:SplitButton.DropDownContent>
                                            <Border Padding="8" MinWidth="130">
                                                <StackPanel>
                                                    <Button Content="保存" Style="{StaticResource ButtonDefault}" Margin="0,0,0,4" />
                                                    <Button Content="另存为..." Style="{StaticResource ButtonDefault}" Margin="0,0,0,4" />
                                                    <Separator Margin="0,2" />
                                                    <Button Content="全部保存" Style="{StaticResource ButtonDefault}" />
                                                </StackPanel>
                                            </Border>
                                        </pf:SplitButton.DropDownContent>
                                    </pf:SplitButton>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,8,0,0"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlSplitButton}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 8. 复合按钮 ═══════════ -->
                    <Border x:Name="Section_复合按钮" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="8. 复合按钮" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <!-- ContextMenuButton -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ContextMenuButton — 点击弹出右键菜单"
                                               FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                    <pf:ContextMenuButton Content="更多操作 ▲" Width="130" Margin="0,0,0,6">
                                        <pf:ContextMenuButton.Menu>
                                            <ContextMenu>
                                                <MenuItem Header="新建项目" />
                                                <MenuItem Header="导入文件" />
                                                <Separator />
                                                <MenuItem Header="设置" />
                                            </ContextMenu>
                                        </pf:ContextMenuButton.Menu>
                                    </pf:ContextMenuButton>
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,8,0,0"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlContextMenu}" />
                                </StackPanel>
                            </Border>

                            <!-- Shield -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Shield — 状态徽章按钮" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,12">
                                        <pf:Shield Subject="设备" Status="在线" Color="{DynamicResource DarkSuccessBrush}"
                                                   Margin="0,0,10,6"
                                                   Command="{Binding ButtonClickCommand}" CommandParameter="Shield: 设备-在线" />
                                        <pf:Shield Subject="告警" Status="3条" Color="{DynamicResource DarkWarningBrush}"
                                                   Margin="0,0,10,6"
                                                   Command="{Binding ButtonClickCommand}" CommandParameter="Shield: 告警" />
                                        <pf:Shield Subject="错误" Status="5" Color="{DynamicResource DangerBrush}"
                                                   Margin="0,0,10,6"
                                                   Command="{Binding ButtonClickCommand}" CommandParameter="Shield: 错误" />
                                        <pf:Shield Subject="状态" Status="离线" Color="{DynamicResource SecondaryTextBrush}"
                                                   Margin="0,0,10,6"
                                                   Command="{Binding ButtonClickCommand}" CommandParameter="Shield: 离线" />
                                        <pf:Shield Subject="信息" Status="12" Color="{DynamicResource PrimaryBrush}"
                                                   Margin="0,0,10,6"
                                                   Command="{Binding ButtonClickCommand}" CommandParameter="Shield: 信息" />
                                    </WrapPanel>
                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlShield}" />
                                </StackPanel>
                            </Border>

                            <!-- ButtonGroup -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ButtonGroup — 按钮组" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                    <TextBlock Text="横向排列（默认）" FontSize="11"
                                               Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,6" />
                                    <pf:ButtonGroup Orientation="Horizontal" Margin="0,0,0,12">
                                        <Button Content="剪切" Command="{Binding ButtonClickCommand}" CommandParameter="ButtonGroup: 剪切" />
                                        <Button Content="复制" Command="{Binding ButtonClickCommand}" CommandParameter="ButtonGroup: 复制" />
                                        <Button Content="粘贴" Command="{Binding ButtonClickCommand}" CommandParameter="ButtonGroup: 粘贴" />
                                    </pf:ButtonGroup>
                                    <TextBlock Text="竖向排列 (RadioButton 互斥)" FontSize="11"
                                               Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,6" />
                                    <pf:ButtonGroup Orientation="Vertical" Margin="0,0,0,12">
                                        <RadioButton Content="左对齐" IsChecked="True" GroupName="AlignGrpV" />
                                        <RadioButton Content="居中" GroupName="AlignGrpV" />
                                        <RadioButton Content="右对齐" GroupName="AlignGrpV" />
                                        <RadioButton Content="两端对齐" GroupName="AlignGrpV" />
                                    </pf:ButtonGroup>
                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlButtonGroup}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- ═══════════ 右侧目录 ═══════════ -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background"
                                                                Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background"
                                                                Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
