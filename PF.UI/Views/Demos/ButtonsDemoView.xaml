<UserControl x:Class="PF.UI.Views.Demos.ButtonsDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头：左标题 + 右交互日志 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="按钮 Button" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="Button 命名样式 · ToggleButton · ProgressButton · SplitButton · ButtonGroup · Shield"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <!-- 交互日志固定在页头右侧 -->
                <Border Grid.Column="1" MinWidth="220" MaxWidth="340"
                        CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon Kind="Console" Width="14" Height="14"
                                     Foreground="{DynamicResource ThirdlyTextBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LastClickResult}"
                                   FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Consolas"
                                   TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- 主体：内容 + 右侧目录 -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 左侧滚动内容 -->
            <ScrollViewer Grid.Column="0"
                          x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 第 1 节: 基础按钮 ═══════════ -->
                    <Border x:Name="Section_基础按钮" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. 基础按钮样式" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <!-- 实心按钮 -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="实心按钮" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,12">
                                        <Button Style="{StaticResource ButtonDefault}" Content="默认" Margin="0,0,10,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="默认按钮" />
                                        <Button Style="{StaticResource ButtonPrimary}" Content="主要" Margin="0,0,10,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="主要按钮" />
                                        <Button Style="{StaticResource ButtonSuccess}" Content="成功" Margin="0,0,10,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="成功按钮" />
                                        <Button Style="{StaticResource ButtonInfo}" Content="信息" Margin="0,0,10,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="信息按钮" />
                                        <Button Style="{StaticResource ButtonWarning}" Content="警告" Margin="0,0,10,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="警告按钮" />
                                        <Button Style="{StaticResource ButtonDanger}" Content="危险" Margin="0,0,10,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="危险按钮" />
                                    </WrapPanel>
                                    <controls:DemoCodeBlock Language="XAML"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlButtonStyles}" />
                                </StackPanel>
                            </Border>

                            <!-- 小号按钮 -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="小号按钮 (.Small 变体)" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,6">
                                        <Button Style="{StaticResource ButtonDefault.Small}" Content="默认" Margin="0,0,8,4" />
                                        <Button Style="{StaticResource ButtonPrimary.Small}" Content="主要" Margin="0,0,8,4" />
                                        <Button Style="{StaticResource ButtonSuccess.Small}" Content="成功" Margin="0,0,8,4" />
                                        <Button Style="{StaticResource ButtonInfo.Small}" Content="信息" Margin="0,0,8,4" />
                                        <Button Style="{StaticResource ButtonWarning.Small}" Content="警告" Margin="0,0,8,4" />
                                        <Button Style="{StaticResource ButtonDanger.Small}" Content="危险" Margin="0,0,8,4" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <!-- 虚线按钮 -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="虚线按钮 (Dashed)" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,6">
                                        <Button Style="{StaticResource ButtonDashed}" Content="默认" Margin="0,0,10,6" />
                                        <Button Style="{StaticResource ButtonDashedPrimary}" Content="主要" Margin="0,0,10,6" />
                                        <Button Style="{StaticResource ButtonDashedSuccess}" Content="成功" Margin="0,0,10,6" />
                                        <Button Style="{StaticResource ButtonDashedInfo}" Content="信息" Margin="0,0,10,6" />
                                        <Button Style="{StaticResource ButtonDashedWarning}" Content="警告" Margin="0,0,10,6" />
                                        <Button Style="{StaticResource ButtonDashedDanger}" Content="危险" Margin="0,0,10,6" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 第 2 节: 图标按钮 ═══════════ -->
                    <Border x:Name="Section_图标按钮" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. 图标按钮" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ButtonIcon / ButtonIconCircular" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,12">
                                        <Button Style="{StaticResource ButtonIcon}" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="收藏">
                                            <pf:PackIcon Kind="Heart" Width="16" Height="16" />
                                        </Button>
                                        <Button Style="{StaticResource ButtonIcon}" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="评分">
                                            <pf:PackIcon Kind="Star" Width="16" Height="16" />
                                        </Button>
                                        <Button Style="{StaticResource ButtonIcon}" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="点赞">
                                            <pf:PackIcon Kind="ThumbUp" Width="16" Height="16" />
                                        </Button>
                                        <Button Style="{StaticResource ButtonIcon}" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="分享">
                                            <pf:PackIcon Kind="ShareVariant" Width="16" Height="16" />
                                        </Button>
                                        <Button Style="{StaticResource ButtonIcon}" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="更多">
                                            <pf:PackIcon Kind="DotsHorizontal" Width="16" Height="16" />
                                        </Button>
                                    </WrapPanel>

                                    <TextBlock Text="圆形图标按钮 (ButtonIconCircular)" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <WrapPanel Margin="0,0,0,12">
                                        <Button Style="{StaticResource ButtonIconCircular}" Width="40" Height="40" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="播放">
                                            <pf:PackIcon Kind="Play" Width="18" Height="18" />
                                        </Button>
                                        <Button Style="{StaticResource ButtonIconCircular}" Width="40" Height="40" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="暂停">
                                            <pf:PackIcon Kind="Pause" Width="18" Height="18" />
                                        </Button>
                                        <Button Style="{StaticResource ButtonIconCircular}" Width="40" Height="40" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="停止">
                                            <pf:PackIcon Kind="Stop" Width="18" Height="18" />
                                        </Button>
                                        <Button Style="{StaticResource ButtonIconCircular}" Width="40" Height="40" Margin="0,0,8,8"
                                                Command="{Binding ButtonClickCommand}" CommandParameter="下一首">
                                            <pf:PackIcon Kind="SkipNext" Width="18" Height="18" />
                                        </Button>
                                    </WrapPanel>

                                    <controls:DemoCodeBlock Language="XAML"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlIconButtons}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 第 3 节: 切换按钮 ═══════════ -->
                    <Border x:Name="Section_切换按钮" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. 切换按钮" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <!-- ToggleButton -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ToggleButton — 开关切换" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                        <ToggleButton Content="点击切换"
                                                      IsChecked="{Binding ToggleChecked, Mode=TwoWay}"
                                                      VerticalAlignment="Center" Margin="0,0,12,0" />
                                        <Border CornerRadius="4" Padding="10,6"
                                                Background="{DynamicResource SecondaryRegionBrush}" VerticalAlignment="Center">
                                            <TextBlock Text="{Binding ToggleLabel}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- RepeatButton -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="RepeatButton — 长按持续触发" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                                    <TextBlock Text="按住下方按钮持续递增计数器，松开停止"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <RepeatButton Content="+ 长按递增" Width="120" Height="36"
                                                  Delay="500" Interval="100" Margin="0,0,0,4" />
                                </StackPanel>
                            </Border>

                            <!-- ProgressButton -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ProgressButton — 带进度条的按钮" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                    <pf:ProgressButton Content="点击开始上传" Width="160"
                                                      IsChecked="{Binding IsBusy}"
                                                      Progress="{Binding ProgressValue}"
                                                      Command="{Binding StartProgressCommand}"
                                                      Margin="0,0,0,8" />
                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="4"
                                            Padding="8,4" HorizontalAlignment="Left">
                                        <TextBlock Text="{Binding ProgressValue, StringFormat='进度: {0:F0}%'}"
                                                   FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </Border>
                                    <controls:DemoCodeBlock Language="XAML" Margin="0,12,0,0"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlProgressButton}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 第 4 节: 复合按钮 ═══════════ -->
                    <Border x:Name="Section_复合按钮" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="4. 复合按钮" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                            <!-- SplitButton -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="SplitButton — 主操作 + 下拉菜单" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                    <pf:SplitButton Content="保存" Width="140"
                                                    Style="{StaticResource SplitButtonPrimary}"
                                                    Command="{Binding SplitButtonActionCommand}"
                                                    CommandParameter="保存文件"
                                                    Margin="0,0,0,8">
                                        <pf:SplitButton.DropDownContent>
                                            <Border Padding="8" MinWidth="130">
                                                <StackPanel>
                                                    <Button Content="保存" Style="{StaticResource ButtonDefault}" Margin="0,0,0,4" />
                                                    <Button Content="另存为..." Style="{StaticResource ButtonDefault}" Margin="0,0,0,4" />
                                                    <Separator Margin="0,2" />
                                                    <Button Content="全部保存" Style="{StaticResource ButtonDefault}" />
                                                </StackPanel>
                                            </Border>
                                        </pf:SplitButton.DropDownContent>
                                    </pf:SplitButton>
                                    <controls:DemoCodeBlock Language="XAML" Margin="0,8,0,0"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlSplitButton}" />
                                </StackPanel>
                            </Border>

                            <!-- ContextMenuButton -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ContextMenuButton — 点击弹出菜单" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                    <pf:ContextMenuButton Content="更多操作 ▲" Width="120" Margin="0,0,0,6">
                                        <pf:ContextMenuButton.Menu>
                                            <ContextMenu>
                                                <MenuItem Header="新建项目" />
                                                <MenuItem Header="导入文件" />
                                                <Separator />
                                                <MenuItem Header="设置" />
                                            </ContextMenu>
                                        </pf:ContextMenuButton.Menu>
                                    </pf:ContextMenuButton>
                                    <controls:DemoCodeBlock Language="XAML" Margin="0,8,0,0"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlContextMenu}" />
                                </StackPanel>
                            </Border>

                            <!-- Shield -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Shield — 状态徽章按钮" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,12">
                                        <pf:Shield Subject="设备" Status="在线" Color="{DynamicResource DarkSuccessBrush}" Margin="0,0,10,6"
                                                   Command="{Binding ButtonClickCommand}" CommandParameter="Shield: 设备-在线" />
                                        <pf:Shield Subject="告警" Status="3条" Color="{DynamicResource DarkWarningBrush}" Margin="0,0,10,6"
                                                   Command="{Binding ButtonClickCommand}" CommandParameter="Shield: 告警" />
                                        <pf:Shield Subject="错误" Status="5" Color="{DynamicResource DangerBrush}" Margin="0,0,10,6"
                                                   Command="{Binding ButtonClickCommand}" CommandParameter="Shield: 错误" />
                                        <pf:Shield Subject="状态" Status="离线" Color="{DynamicResource SecondaryTextBrush}" Margin="0,0,10,6"
                                                   Command="{Binding ButtonClickCommand}" CommandParameter="Shield: 离线" />
                                        <pf:Shield Subject="信息" Status="12" Color="{DynamicResource PrimaryBrush}" Margin="0,0,10,6"
                                                   Command="{Binding ButtonClickCommand}" CommandParameter="Shield: 信息" />
                                    </WrapPanel>
                                    <controls:DemoCodeBlock Language="XAML"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlShield}" />
                                </StackPanel>
                            </Border>

                            <!-- ButtonGroup -->
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ButtonGroup — 按钮组" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                                    <TextBlock Text="横向排列（默认）" FontSize="11"
                                               Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,6" />
                                    <pf:ButtonGroup Orientation="Horizontal" Margin="0,0,0,12">
                                        <Button Content="剪切" Command="{Binding ButtonClickCommand}" CommandParameter="ButtonGroup: 剪切" />
                                        <Button Content="复制" Command="{Binding ButtonClickCommand}" CommandParameter="ButtonGroup: 复制" />
                                        <Button Content="粘贴" Command="{Binding ButtonClickCommand}" CommandParameter="ButtonGroup: 粘贴" />
                                    </pf:ButtonGroup>
                                    <TextBlock Text="竖向排列" FontSize="11"
                                               Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,6" />
                                    <pf:ButtonGroup Orientation="Vertical" Margin="0,0,0,12">
                                        <ToggleButton Content="左对齐" IsChecked="True" />
                                        <ToggleButton Content="居中" />
                                        <ToggleButton Content="右对齐" />
                                        <ToggleButton Content="两端对齐" />
                                    </pf:ButtonGroup>
                                    <controls:DemoCodeBlock Language="XAML"
                                        Code="{x:Static vm:ButtonsDemoViewModel.XamlButtonGroup}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>


                </StackPanel>
            </ScrollViewer>

            <!-- ═══════════ 右侧目录 ═══════════ -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <!-- 目录标题 -->
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>

                    <!-- 目录项 -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}"
                                      Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5"
                                            Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background"
                                                                Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background"
                                                                Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
