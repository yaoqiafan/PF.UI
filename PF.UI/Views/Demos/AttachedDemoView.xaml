<UserControl x:Class="PF.UI.Views.Demos.AttachedDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:AttachedDemoViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="附加属性" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="InfoElement · IconElement · BorderElement · WindowAttach · ScrollViewerAttach"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <Border Grid.Column="1" MinWidth="200" MaxWidth="340"
                        CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon Kind="Console" Width="14" Height="14"
                                     Foreground="{DynamicResource ThirdlyTextBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LastResult}" FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. InfoElement / TitleElement ═══════════ -->
                    <Border x:Name="Section_InfoTitle" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. InfoElement · TitleElement" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,16"
                                               Text="为 TextBox / ComboBox 等输入控件附加标题、占位符、必填标记等表单装饰，属性支持 Inherits 向子树传递" />

                                    <!-- TitlePlacement=Top（默认） -->
                                    <TextBlock Text="TitlePlacement = Top（默认）" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MaxWidth="260" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" MaxWidth="260" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBox pf:InfoElement.Title="用户名"
                                                     pf:InfoElement.Placeholder="请输入用户名"
                                                     pf:InfoElement.Necessary="True"
                                                     pf:InfoElement.ShowClearButton="True"
                                                     Margin="0,0,0,10" />
                                            <TextBox pf:InfoElement.Title="备注"
                                                     pf:InfoElement.Placeholder="选填"
                                                     pf:InfoElement.ContentHeight="60"
                                                     AcceptsReturn="True" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="2">
                                            <ComboBox pf:InfoElement.Title="角色"
                                                      pf:InfoElement.Placeholder="请选择角色"
                                                      pf:InfoElement.Necessary="True"
                                                      Margin="0,0,0,10">
                                                <ComboBoxItem Content="管理员" />
                                                <ComboBoxItem Content="操作员" />
                                                <ComboBoxItem Content="访客" />
                                            </ComboBox>
                                            <TextBox pf:InfoElement.Title="正则校验"
                                                     pf:InfoElement.Placeholder="仅数字"
                                                     pf:InfoElement.RegexPattern="^\d*$" />
                                        </StackPanel>
                                    </Grid>

                                    <Separator Margin="0,0,0,16" />

                                    <!-- TitlePlacement=Left -->
                                    <TextBlock Text="TitlePlacement = Left（父容器统一设置，子控件继承）" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                    <StackPanel pf:TitleElement.TitlePlacement="Left"
                                                pf:TitleElement.TitleWidth="80"
                                                MaxWidth="400" HorizontalAlignment="Left">
                                        <TextBox pf:InfoElement.Title="账号"
                                                 pf:InfoElement.Placeholder="输入账号"
                                                 pf:InfoElement.Necessary="True"
                                                 Margin="0,0,0,10" />
                                        <TextBox pf:InfoElement.Title="密码"
                                                 pf:InfoElement.Placeholder="输入密码"
                                                 Margin="0,0,0,10" />
                                        <ComboBox pf:InfoElement.Title="部门"
                                                  pf:InfoElement.Placeholder="选择部门">
                                            <ComboBoxItem Content="研发部" />
                                            <ComboBoxItem Content="品质部" />
                                        </ComboBox>
                                    </StackPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,16,0,0"
                                        Code="{x:Static vm:AttachedDemoViewModel.XamlInfoTitle}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. IconElement / BorderElement ═══════════ -->
                    <Border x:Name="Section_Icon" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. IconElement · BorderElement" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,16"
                                               Text="IconElement 向控件模板注入自定义 Geometry 图标；BorderElement.CornerRadius 可通过 Inherits 向子树传播，Circular 让 Border 自动变正圆" />

                                    <!-- IconElement -->
                                    <TextBlock Text="IconElement — Geometry 图标注入" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,16">
                                        <Button Style="{StaticResource ButtonPrimary}" Content="搜索"
                                                pf:IconElement.Geometry="{StaticResource SearchGeometry}"
                                                Margin="0,0,8,8" />
                                        <Button Style="{StaticResource ButtonDefault}" Content="添加"
                                                pf:IconElement.Geometry="{StaticResource AddGeometry}"
                                                Margin="0,0,8,8" />
                                        <Button Style="{StaticResource ButtonDanger}" Content="删除"
                                                pf:IconElement.Geometry="{StaticResource DeleteGeometry}"
                                                Margin="0,0,8,8" />
                                        <Button Style="{StaticResource ButtonSuccess}" Content="保存"
                                                pf:IconElement.Geometry="{StaticResource SaveGeometry}"
                                                Margin="0,0,8,8" />
                                    </WrapPanel>

                                    <Separator Margin="0,0,0,16" />

                                    <!-- BorderElement.CornerRadius 继承 -->
                                    <TextBlock Text="BorderElement.CornerRadius — 子树继承" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="40" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="未设置（CornerRadius=0）" FontSize="11"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,6" />
                                            <StackPanel>
                                                <Button Style="{StaticResource ButtonDefault}" Content="Button" Width="120" Margin="0,0,0,6" />
                                                <TextBox Width="120" Text="TextBox" />
                                            </StackPanel>
                                        </StackPanel>
                                        <StackPanel Grid.Column="2" pf:BorderElement.CornerRadius="10">
                                            <TextBlock Text="父级设置 CornerRadius=10" FontSize="11"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,6" />
                                            <StackPanel>
                                                <Button Style="{StaticResource ButtonDefault}" Content="Button" Width="120" Margin="0,0,0,6" />
                                                <TextBox Width="120" Text="TextBox" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>

                                    <!-- BorderElement.Circular -->
                                    <TextBlock Text="BorderElement.Circular — 自动正圆" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,4">
                                        <Border Width="56" Height="56" Margin="0,0,12,0"
                                                Background="{DynamicResource PrimaryBrush}"
                                                pf:BorderElement.Circular="True">
                                            <TextBlock Text="A" Foreground="White" FontSize="20" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Border Width="56" Height="56" Margin="0,0,12,0"
                                                Background="{DynamicResource SuccessBrush}"
                                                pf:BorderElement.Circular="True">
                                            <pf:PackIcon Kind="Check" Foreground="White" Width="24" Height="24"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Border Width="56" Height="56" Margin="0,0,12,0"
                                                Background="{DynamicResource DangerBrush}"
                                                pf:BorderElement.Circular="True">
                                            <pf:PackIcon Kind="Close" Foreground="White" Width="24" Height="24"
                                                         HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                        <Border Width="56" Height="56"
                                                Background="{DynamicResource SecondaryRegionBrush}"
                                                BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2"
                                                pf:BorderElement.Circular="True">
                                            <TextBlock Text="?" Foreground="{DynamicResource PrimaryBrush}"
                                                       FontSize="22" FontWeight="Bold"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>
                                    </WrapPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,16,0,4"
                                        Code="{x:Static vm:AttachedDemoViewModel.XamlIcon}" />
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,8,0,0"
                                        Code="{x:Static vm:AttachedDemoViewModel.XamlBorder}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. WindowAttach ═══════════ -->
                    <Border x:Name="Section_Window" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. WindowAttach" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,16"
                                               Text="通过附加属性为 Window 添加行为，无需子类化。所有属性在 OnChanged 回调中订阅/解绑事件，无内存泄漏风险" />

                                    <!-- IsDragElement 演示 -->
                                    <TextBlock Text="IsDragElement — 任意元素拖动所在窗口" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                    <Border Background="{DynamicResource SecondaryRegionBrush}"
                                            CornerRadius="8" Height="48" Cursor="SizeAll"
                                            pf:WindowAttach.IsDragElement="True"
                                            Margin="0,0,0,16">
                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Center"
                                                    VerticalAlignment="Center">
                                            <pf:PackIcon Kind="DragVariant" Width="16" Height="16"
                                                         VerticalAlignment="Center" Margin="0,0,8,0"
                                                         Foreground="{DynamicResource ThirdlyTextBrush}" />
                                            <TextBlock Text="拖动此区域可移动整个窗口" FontSize="12"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Border>

                                    <!-- 属性速查 -->
                                    <TextBlock Text="其他 WindowAttach 属性" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="6" Padding="12,10" Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="180" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="IgnoreAltF4" FontFamily="Consolas" FontSize="11"
                                                       Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" FontSize="11" Margin="0,0,0,8"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="阻止 Alt+F4 关闭（强制操作流程场景）" />
                                            <TextBlock Grid.Row="1" Grid.Column="0" Text="HideWhenClosing" FontFamily="Consolas" FontSize="11"
                                                       Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" FontSize="11" Margin="0,0,0,8"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="关闭 → 隐藏（托盘应用场景）" />
                                            <TextBlock Grid.Row="2" Grid.Column="0" Text="ShowInTaskManager" FontFamily="Consolas" FontSize="11"
                                                       Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" FontSize="11" Margin="0,0,0,8"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="控制是否在任务栏/任务管理器中出现" />
                                            <TextBlock Grid.Row="3" Grid.Column="0" Text="ExtendToNonClient" FontFamily="Consolas" FontSize="11"
                                                       Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" FontSize="11"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       Text="内容延伸至非客户区（标题栏后面）" />
                                        </Grid>
                                    </Border>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,0,0,0"
                                        Code="{x:Static vm:AttachedDemoViewModel.XamlWindow}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 4. ScrollViewerAttach ═══════════ -->
                    <Border x:Name="Section_Scroll" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="4. ScrollViewerAttach" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,16"
                                               Text="控制 ScrollViewer 的滚动条自动隐藏、滚轮方向、穿透阻止等行为" />

                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- AutoHide=True（默认） -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="AutoHide = True（默认，悬停显示）" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                    CornerRadius="6" Height="120">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                              pf:ScrollViewerAttach.AutoHide="True">
                                                    <StackPanel Margin="8">
                                                        <TextBlock Text="Item 1" Margin="0,3" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="Item 2" Margin="0,3" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="Item 3" Margin="0,3" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="Item 4" Margin="0,3" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="Item 5" Margin="0,3" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="Item 6" Margin="0,3" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </Border>
                                        </StackPanel>

                                        <!-- AutoHide=False -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="AutoHide = False（始终显示）" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                            <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                    CornerRadius="6" Height="120">
                                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                                              pf:ScrollViewerAttach.AutoHide="False">
                                                    <StackPanel Margin="8">
                                                        <TextBlock Text="Item 1" Margin="0,3" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="Item 2" Margin="0,3" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="Item 3" Margin="0,3" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="Item 4" Margin="0,3" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="Item 5" Margin="0,3" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                        <TextBlock Text="Item 6" Margin="0,3" Foreground="{DynamicResource SecondaryTextBrush}" />
                                                    </StackPanel>
                                                </ScrollViewer>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <!-- IsDisabled 说明 -->
                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="6" Padding="12,10" Margin="0,0,0,14">
                                        <StackPanel>
                                            <TextBlock Text="IsDisabled — 防止滚动事件穿透" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                            <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" TextWrapping="Wrap">
                                                嵌套 ScrollViewer 场景下，内层 ListBox 滚动到顶/底后事件会穿透至外层。
                                                设置 pf:ScrollViewerAttach.IsDisabled="True" 可阻止穿透，保持内层独立滚动。
                                            </TextBlock>
                                        </StackPanel>
                                    </Border>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,0,0,0"
                                        Code="{x:Static vm:AttachedDemoViewModel.XamlScroll}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 5. 速查参考 ═══════════ -->
                    <Border x:Name="Section_Reference" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="5. 其余附加属性速查" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,14"
                                               Text="以下附加属性主要供 PF.UI.Resources 控件模板内部使用，也可在自定义模板中引用" />

                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="6" Padding="12,10">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="160" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- 表头 -->
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="类名" FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="核心属性" FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8" />
                                            <TextBlock Grid.Row="0" Grid.Column="2" Text="说明" FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8" />

                                            <!-- 数据行 -->
                                            <TextBlock Grid.Row="1" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="DataGridAttach" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="ApplyDefaultStyle" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="1" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="DataGrid 列自动应用 PF 主题样式" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="2" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="TextBlockAttach" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="LineHeight / Leading" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="2" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="TextBlock 行高与首行缩进控制" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="3" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="PasswordBoxAttach" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="Password / IsMonitoring" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="3" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="密码双向绑定 + 显示切换" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="4" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="ToggleButtonAttach" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="4" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="IsCheckedBackground" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="4" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="ToggleButton 选中态背景定制" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="5" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="ComboBoxAttach" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="5" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="IsMonitoring" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="5" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="ComboBox 内容变更监听" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="6" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="ListBoxAttach" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="6" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="IsVirtualizing" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="6" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="ListBox 虚拟化与自动滚动" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="7" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="GridAttach" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="7" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="Row / Column / Span" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="7" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="声明式 Grid 布局附加属性" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="8" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="GridViewAttach" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="8" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="IsShowSortArrow" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="8" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="ListView GridView 排序箭头控制" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="9" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="MenuAttach" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="9" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="BackgroundColor" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="9" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="Menu 背景/分隔线颜色" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="10" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="MenuItemAttach" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="10" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="IconWidth / IconHeight" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="10" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="MenuItem 图标区尺寸控制" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="11" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="RectangleAttach" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="11" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="RadiusX / RadiusY" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="11" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="Rectangle 圆角绑定辅助" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="12" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="ImageAttach" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="12" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="PressedSource / HoverSource" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="12" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="Button 内 Image 多态图源切换" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="13" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="TipElement" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="13" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="Placement / TipContent" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="13" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="ToolTip 位置与内容注入" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="14" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="PanelElement" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="14" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="FluidMoveDuration" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="14" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="Panel 子元素布局动画时长" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="15" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="EdgeElement" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="15" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="Status / Position" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="15" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="控件边缘状态色条" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="16" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="DropDownElement" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="16" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="ConsistencyPlacement" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="16" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="下拉框弹出方向一致性" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="17" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="VisualElement" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="17" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="HighlightBackground" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="17" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="控件高亮/焦点视觉状态颜色" Foreground="{DynamicResource ThirdlyTextBrush}" />

                                            <TextBlock Grid.Row="18" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="BackgroundSwitch" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="18" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="MouseOverBackground" Foreground="{DynamicResource SecondaryTextBrush}" />
                                            <TextBlock Grid.Row="18" Grid.Column="2" FontSize="10.5" Margin="0,3"
                                                       Text="悬停/按下/选中态背景色注入" Foreground="{DynamicResource ThirdlyTextBrush}" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
