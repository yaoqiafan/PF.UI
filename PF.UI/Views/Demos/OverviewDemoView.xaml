<UserControl
    x:Class="PF.UI.Views.Demos.OverviewDemoView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:PF.UI.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
    xmlns:prism="http://prismlibrary.com/"
    xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
    d:DataContext="{d:DesignInstance vm:OverviewDemoViewModel,
                                     IsDesignTimeCreatable=False}"
    d:DesignHeight="800"
    d:DesignWidth="820"
    prism:ViewModelLocator.AutoWireViewModel="True"
    Background="{DynamicResource BackgroundBrush}"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!--  页头  -->
        <Border
            Grid.Row="0"
            Padding="24,20,24,16"
            Background="{DynamicResource RegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,0,1">
            <StackPanel>
                <TextBlock
                    FontSize="20"
                    FontWeight="Bold"
                    Foreground="{DynamicResource PrimaryTextBrush}"
                    Text="PF.UI 控件演示库" />
                <TextBlock
                    Margin="0,4,0,0"
                    FontSize="12"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    Text="企业级 WPF 自定义控件库 — 涵盖按钮、输入、布局、导航、反馈、图表等 90+ 控件" />
            </StackPanel>
        </Border>

        <!--  主体：内容 + 右侧目录  -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer
                x:Name="ContentScroll"
                Grid.Column="0"
                ScrollChanged="ContentScroll_ScrollChanged"
                VerticalScrollBarVisibility="Auto">
                <StackPanel MaxWidth="800" Margin="24,16,16,24">

                    <!--  ═══ 关于 PF.UI ═══  -->
                    <Border x:Name="Section_About" Padding="0,0,0,4">
                        <Border
                            Margin="0,0,0,16"
                            Padding="20,18"
                            Background="{DynamicResource RegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,10"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource PrimaryTextBrush}"
                                    Text="关于 PF.UI" />
                                <TextBlock
                                    FontSize="13"
                                    Foreground="{DynamicResource SecondaryTextBrush}"
                                    LineHeight="22"
                                    Text="PF.UI 是一套面向 WPF (net8.0-windows) 的企业级 UI 组件库，提供丰富的自定义控件、完整的深色/浅色主题、以及 700+ Material Design 图标。所有控件遵循 MVVM 模式，与 Prism 9 深度集成。"
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>
                    </Border>

                    <!--  ═══ 快速开始 ═══  -->
                    <Border x:Name="Section_QuickStart" Padding="0,4,0,4">
                        <Border
                            Margin="0,0,0,16"
                            Padding="20,18"
                            Background="{DynamicResource RegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,10"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource PrimaryTextBrush}"
                                    Text="快速开始" />

                                <TextBlock
                                    Margin="0,0,0,6"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource PrimaryTextBrush}"
                                    Text="1. 安装 NuGet 包" />
                                <controls:DemoCodeBlock Margin="0,0,0,12" CodeLanguage="Shell">
                                    <controls:DemoCodeBlock.Code>
                                        dotnet add package PF.UI.Controls
                                        dotnet add package PF.UI.Resources
                                        dotnet add package PF.UI.Shared
                                    </controls:DemoCodeBlock.Code>
                                </controls:DemoCodeBlock>

                                <TextBlock
                                    Margin="0,0,0,6"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource PrimaryTextBrush}"
                                    Text="2. 在 App.xaml 中引入主题" />
                                <controls:DemoCodeBlock Margin="0,0,0,12" CodeLanguage="XAML">
                                    <controls:DemoCodeBlock.Code>
                                        &lt;Application.Resources&gt;
                                        &lt;ResourceDictionary&gt;
                                        &lt;ResourceDictionary.MergedDictionaries&gt;
                                        &lt;ResourceDictionary Source="/PF.UI.Resources;component/Themes/Default.xaml"/&gt;
                                        &lt;ResourceDictionary Source="/PF.UI.Resources;component/Colors/Default.xaml"/&gt;
                                        &lt;/ResourceDictionary.MergedDictionaries&gt;
                                        &lt;/ResourceDictionary&gt;
                                        &lt;/Application.Resources&gt;
                                    </controls:DemoCodeBlock.Code>
                                </controls:DemoCodeBlock>

                                <TextBlock
                                    Margin="0,0,0,6"
                                    FontSize="13"
                                    FontWeight="SemiBold"
                                    Foreground="{DynamicResource PrimaryTextBrush}"
                                    Text="3. 使用控件" />
                                <controls:DemoCodeBlock Margin="0,0,0,12" CodeLanguage="XAML">
                                    <controls:DemoCodeBlock.Code>
                                        &lt;Window xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"&gt;
                                        &lt;StackPanel&gt;
                                        &lt;pf:PackIcon Kind="Heart" Width="32" Height="32"
                                        Foreground="{DynamicResource PrimaryBrush}" /&gt;
                                        &lt;pf:Badge Content="99+" Status="Error" /&gt;
                                        &lt;pf:Chip Content="可删除标签" IsDeletable="True" /&gt;
                                        &lt;/StackPanel&gt;
                                        &lt;/Window&gt;
                                    </controls:DemoCodeBlock.Code>
                                </controls:DemoCodeBlock>
                            </StackPanel>
                        </Border>
                    </Border>

                    <!--  ═══ 项目架构 ═══  -->
                    <Border x:Name="Section_Architecture" Padding="0,4,0,4">
                        <Border
                            Margin="0,0,0,16"
                            Padding="20,18"
                            Background="{DynamicResource RegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,10"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource PrimaryTextBrush}"
                                    Text="项目架构" />
                                <Border
                                    Padding="14,10"
                                    Background="{DynamicResource SecondaryRegionBrush}"
                                    CornerRadius="6">
                                    <TextBlock
                                        FontFamily="Consolas"
                                        FontSize="12"
                                        Foreground="{DynamicResource SecondaryTextBrush}"
                                        LineHeight="22"
                                        TextWrapping="Wrap">
                                        <Run Text="PF.UI                  → 演示 Shell (Prism Bootstrapper)" /><LineBreak />
                                        <Run Text="PF.UI.Controls         → 自定义控件库 (90+ 控件)" /><LineBreak />
                                        <Run Text="PF.UI.Resources        → 主题资源 (深色/浅色 + 字体 + 图标)" /><LineBreak />
                                        <Run Text="PF.UI.Shared           → 共享工具 (转换器 / 钩子 / Interop / 颜色)" />
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </Border>
                    </Border>

                    <!--  ═══ 控件统计 ═══  -->
                    <Border x:Name="Section_Stats" Padding="0,4,0,4">
                        <Border
                            Margin="0,0,0,16"
                            Padding="20,18"
                            Background="{DynamicResource RegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,12"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource PrimaryTextBrush}"
                                    Text="控件统计" />
                                <WrapPanel>
                                    <Border
                                        Width="155"
                                        Margin="0,0,8,8"
                                        Padding="14,10"
                                        Background="{DynamicResource SecondaryRegionBrush}"
                                        CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="24"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource PrimaryBrush}"
                                                Text="90+" />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource ThirdlyTextBrush}"
                                                Text="自定义控件" />
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        Width="155"
                                        Margin="0,0,8,8"
                                        Padding="14,10"
                                        Background="{DynamicResource SecondaryRegionBrush}"
                                        CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="24"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource DarkSuccessBrush}"
                                                Text="32" />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource ThirdlyTextBrush}"
                                                Text="原生控件样式重写" />
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        Width="155"
                                        Margin="0,0,8,8"
                                        Padding="14,10"
                                        Background="{DynamicResource SecondaryRegionBrush}"
                                        CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="24"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource DarkWarningBrush}"
                                                Text="29" />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource ThirdlyTextBrush}"
                                                Text="附加属性/Element" />
                                        </StackPanel>
                                    </Border>
                                    <Border
                                        Width="155"
                                        Margin="0,0,8,8"
                                        Padding="14,10"
                                        Background="{DynamicResource SecondaryRegionBrush}"
                                        CornerRadius="6">
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="24"
                                                FontWeight="Bold"
                                                Foreground="{DynamicResource DangerBrush}"
                                                Text="33" />
                                            <TextBlock
                                                FontSize="11"
                                                Foreground="{DynamicResource ThirdlyTextBrush}"
                                                Text="值转换器" />
                                        </StackPanel>
                                    </Border>
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </Border>

                    <!--  ═══ 使用本演示 ═══  -->
                    <Border x:Name="Section_Usage" Padding="0,4,0,4">
                        <Border
                            Padding="20,18"
                            Background="{DynamicResource RegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,10"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource PrimaryTextBrush}"
                                    Text="使用本演示" />
                                <TextBlock
                                    FontSize="13"
                                    Foreground="{DynamicResource SecondaryTextBrush}"
                                    LineHeight="22"
                                    TextWrapping="Wrap">
                                    点击左侧菜单栏 ☰ 展开导航分组。每个演示页面包含实时交互示例和可复制的 XAML / C# 代码块。点击代码块右上角的 📋 按钮即可复制到剪贴板。
                                </TextBlock>
                            </StackPanel>
                        </Border>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!--  右侧目录  -->
            <Border
                Grid.Column="1"
                Width="170"
                Padding="0,12,0,0"
                Background="{DynamicResource RegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border
                        Grid.Row="0"
                        Padding="12,6,12,10"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                        <TextBlock
                            FontSize="12"
                            FontWeight="Bold"
                            Foreground="{DynamicResource PrimaryTextBrush}"
                            Text="📑 目录" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl Margin="4,6,4,20" ItemsSource="{Binding TocItems}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border
                                        Padding="10,6"
                                        Background="Transparent"
                                        CornerRadius="5"
                                        Cursor="Hand"
                                        MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock
                                                FontSize="12"
                                                Foreground="{DynamicResource PrimaryTextBrush}"
                                                Text="{Binding Title}" />
                                            <TextBlock
                                                Margin="0,2,0,0"
                                                FontSize="10"
                                                Foreground="{DynamicResource ThirdlyTextBrush}"
                                                Text="{Binding Sub}"
                                                TextTrimming="CharacterEllipsis" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
