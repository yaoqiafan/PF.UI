<UserControl x:Class="PF.UI.Views.Demos.OverviewDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,20,24,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <StackPanel>
                <TextBlock Text="PF.UI 控件演示库" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}" />
                <TextBlock Text="企业级 WPF 自定义控件库 — 涵盖按钮、输入、布局、导航、反馈、图表等 90+ 控件"
                           FontSize="12" Margin="0,4,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
            </StackPanel>
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="24,20">
            <StackPanel MaxWidth="800" HorizontalAlignment="Left">

                <!-- 简介卡片 -->
                <Border Background="{DynamicResource RegionBrush}" CornerRadius="10" Padding="20,18"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="关于 PF.UI" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                        <TextBlock Text="PF.UI 是一套面向 WPF (net8.0-windows) 的企业级 UI 组件库，提供丰富的自定义控件、完整的深色/浅色主题、以及 700+ Material Design 图标。所有控件遵循 MVVM 模式，与 Prism 9 深度集成。"
                                   FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" LineHeight="22" />
                    </StackPanel>
                </Border>

                <!-- 快速开始 -->
                <Border Background="{DynamicResource RegionBrush}" CornerRadius="10" Padding="20,18"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="快速开始" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />

                        <TextBlock Text="1. 安装 NuGet 包" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                        <controls:DemoCodeBlock Language="Shell" Margin="0,0,0,12">
                            <controls:DemoCodeBlock.Code>
dotnet add package PF.UI.Controls
dotnet add package PF.UI.Resources
dotnet add package PF.UI.Shared
                            </controls:DemoCodeBlock.Code>
                        </controls:DemoCodeBlock>

                        <TextBlock Text="2. 在 App.xaml 中引入主题" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                        <controls:DemoCodeBlock Language="XAML" Margin="0,0,0,12">
                            <controls:DemoCodeBlock.Code>&lt;Application.Resources&gt;
    &lt;ResourceDictionary&gt;
        &lt;ResourceDictionary.MergedDictionaries&gt;
            &lt;ResourceDictionary Source="/PF.UI.Resources;component/Themes/Default.xaml"/&gt;
            &lt;ResourceDictionary Source="/PF.UI.Resources;component/Colors/Default.xaml"/&gt;
        &lt;/ResourceDictionary.MergedDictionaries&gt;
    &lt;/ResourceDictionary&gt;
&lt;/Application.Resources&gt;</controls:DemoCodeBlock.Code>
                        </controls:DemoCodeBlock>

                        <TextBlock Text="3. 使用控件" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,6" />
                        <controls:DemoCodeBlock Language="XAML" Margin="0,0,0,12">
                            <controls:DemoCodeBlock.Code>&lt;Window xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"&gt;
    &lt;StackPanel&gt;
        &lt;pf:PackIcon Kind="Heart" Width="32" Height="32"
                      Foreground="{DynamicResource PrimaryBrush}" /&gt;
        &lt;pf:Badge Content="99+" Status="Error" /&gt;
        &lt;pf:Chip Content="可删除标签" IsDeletable="True" /&gt;
    &lt;/StackPanel&gt;
&lt;/Window&gt;</controls:DemoCodeBlock.Code>
                        </controls:DemoCodeBlock>
                    </StackPanel>
                </Border>

                <!-- 项目结构 -->
                <Border Background="{DynamicResource RegionBrush}" CornerRadius="10" Padding="20,18"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="项目架构" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />

                        <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="6" Padding="14,10">
                            <TextBlock FontFamily="Consolas" FontSize="12"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       TextWrapping="Wrap" LineHeight="22">
                                <Run Text="PF.UI                  → 演示 Shell (Prism Bootstrapper)" /><LineBreak />
                                <Run Text="PF.UI.Controls         → 自定义控件库 (90+ 控件)" /><LineBreak />
                                <Run Text="PF.UI.Resources        → 主题资源 (深色/浅色 + 字体 + 图标)" /><LineBreak />
                                <Run Text="PF.UI.Shared           → 共享工具 (转换器 / 钩子 / Interop / 颜色)" />
                            </TextBlock>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- 控件数量统计 -->
                <Border Background="{DynamicResource RegionBrush}" CornerRadius="10" Padding="20,18"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="控件统计" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                        <WrapPanel>
                            <Border Width="155" Padding="14,10" Margin="0,0,8,8"
                                    CornerRadius="6" Background="{DynamicResource SecondaryRegionBrush}">
                                <StackPanel>
                                    <TextBlock Text="90+" FontSize="24" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryBrush}" />
                                    <TextBlock Text="自定义控件" FontSize="11"
                                               Foreground="{DynamicResource ThirdlyTextBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Width="155" Padding="14,10" Margin="0,0,8,8"
                                    CornerRadius="6" Background="{DynamicResource SecondaryRegionBrush}">
                                <StackPanel>
                                    <TextBlock Text="32" FontSize="24" FontWeight="Bold"
                                               Foreground="{DynamicResource DarkSuccessBrush}" />
                                    <TextBlock Text="原生控件样式重写" FontSize="11"
                                               Foreground="{DynamicResource ThirdlyTextBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Width="155" Padding="14,10" Margin="0,0,8,8"
                                    CornerRadius="6" Background="{DynamicResource SecondaryRegionBrush}">
                                <StackPanel>
                                    <TextBlock Text="29" FontSize="24" FontWeight="Bold"
                                               Foreground="{DynamicResource DarkWarningBrush}" />
                                    <TextBlock Text="附加属性/Element" FontSize="11"
                                               Foreground="{DynamicResource ThirdlyTextBrush}" />
                                </StackPanel>
                            </Border>
                            <Border Width="155" Padding="14,10" Margin="0,0,8,8"
                                    CornerRadius="6" Background="{DynamicResource SecondaryRegionBrush}">
                                <StackPanel>
                                    <TextBlock Text="33" FontSize="24" FontWeight="Bold"
                                               Foreground="{DynamicResource DangerBrush}" />
                                    <TextBlock Text="值转换器" FontSize="11"
                                               Foreground="{DynamicResource ThirdlyTextBrush}" />
                                </StackPanel>
                            </Border>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- 使用本演示程序 -->
                <Border Background="{DynamicResource RegionBrush}" CornerRadius="10" Padding="20,18"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="使用本演示" FontSize="16" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,10" />
                        <TextBlock FontSize="13" Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap" LineHeight="22">
                            点击左侧菜单栏 ☰ 展开导航分组。每个演示页面包含实时交互示例和可复制的 XAML / C# 代码块。点击代码块右上角的 📋 按钮即可复制到剪贴板。
                        </TextBlock>
                    </StackPanel>
                </Border>

            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
