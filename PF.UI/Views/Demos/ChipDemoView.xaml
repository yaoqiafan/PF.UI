<UserControl x:Class="PF.UI.Views.Demos.ChipDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:ChipDemoViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="Chip 标签控件" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="Chip · Filled · Outlined · Icon · IsDeletable"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <Border Grid.Column="1" MinWidth="200" MaxWidth="340"
                        CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon Kind="Console" Width="14" Height="14"
                                     Foreground="{DynamicResource ThirdlyTextBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LastResult}" FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. Filled ═══════════ -->
                    <Border x:Name="Section_Filled" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. Filled — 实色填充" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="通过命名样式切换颜色主题：ChipPrimary / ChipSuccess / ChipDanger / ChipWarning"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />
                                    <WrapPanel>
                                        <pf:Chip Content="默认" Margin="0,0,8,8" />
                                        <pf:Chip Content="主色" Style="{StaticResource ChipPrimary}" Margin="0,0,8,8" />
                                        <pf:Chip Content="成功" Style="{StaticResource ChipSuccess}" Margin="0,0,8,8" />
                                        <pf:Chip Content="危险" Style="{StaticResource ChipDanger}" Margin="0,0,8,8" />
                                        <pf:Chip Content="警告" Style="{StaticResource ChipWarning}" Margin="0,0,0,8" />
                                    </WrapPanel>
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,6,0,0"
                                        Code="{x:Static vm:ChipDemoViewModel.XamlFilled}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. Outlined ═══════════ -->
                    <Border x:Name="Section_Outlined" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. Outlined — 描边轮廓" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="ChipOutlined / ChipOutlinedPrimary — 透明背景 + 描边边框"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />
                                    <WrapPanel>
                                        <pf:Chip Content="描边默认" Style="{StaticResource ChipOutlined}" Margin="0,0,8,8" />
                                        <pf:Chip Content="描边主色" Style="{StaticResource ChipOutlinedPrimary}" Margin="0,0,0,8" />
                                    </WrapPanel>
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,6,0,0"
                                        Code="{x:Static vm:ChipDemoViewModel.XamlOutlined}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. 带图标 ═══════════ -->
                    <Border x:Name="Section_Icon" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. 带图标" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Icon 属性接受任意 UIElement，显示在文字左侧的圆形区域内"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />
                                    <WrapPanel>
                                        <pf:Chip Content="用户" Margin="0,0,8,8">
                                            <pf:Chip.Icon>
                                                <pf:PackIcon Kind="Account" Width="18" Height="18" Foreground="White" />
                                            </pf:Chip.Icon>
                                        </pf:Chip>
                                        <pf:Chip Content="收藏" Style="{StaticResource ChipPrimary}" Margin="0,0,8,8">
                                            <pf:Chip.Icon>
                                                <pf:PackIcon Kind="Star" Width="18" Height="18" Foreground="White" />
                                            </pf:Chip.Icon>
                                        </pf:Chip>
                                        <pf:Chip Content="定位" Style="{StaticResource ChipSuccess}" Margin="0,0,8,8">
                                            <pf:Chip.Icon>
                                                <pf:PackIcon Kind="MapMarker" Width="18" Height="18"
                                                             Foreground="{DynamicResource DarkSuccessBrush}" />
                                            </pf:Chip.Icon>
                                        </pf:Chip>
                                        <pf:Chip Content="描边+图标" Style="{StaticResource ChipOutlinedPrimary}" Margin="0,0,0,8">
                                            <pf:Chip.Icon>
                                                <pf:PackIcon Kind="Tag" Width="18" Height="18"
                                                             Foreground="{DynamicResource PrimaryBrush}" />
                                            </pf:Chip.Icon>
                                        </pf:Chip>
                                    </WrapPanel>
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,6,0,0"
                                        Code="{x:Static vm:ChipDemoViewModel.XamlIcon}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 4. 可删除 ═══════════ -->
                    <Border x:Name="Section_Deletable" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="4. 可删除 &amp; 标签云" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="IsDeletable=&quot;True&quot; — 显示右侧 × 按钮，DeleteCommand 绑定删除逻辑"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" />
                                    <WrapPanel Margin="0,0,0,12">
                                        <pf:Chip Content="可删除" IsDeletable="True" Margin="0,0,8,8" />
                                        <pf:Chip Content="主色可删除" IsDeletable="True"
                                                 Style="{StaticResource ChipPrimary}" Margin="0,0,8,8" />
                                        <pf:Chip Content="带图标可删除" IsDeletable="True"
                                                 DeleteToolTip="点击删除此标签" Margin="0,0,0,8">
                                            <pf:Chip.Icon>
                                                <pf:PackIcon Kind="Tag" Width="18" Height="18" Foreground="White" />
                                            </pf:Chip.Icon>
                                        </pf:Chip>
                                    </WrapPanel>
                                    <TextBlock Text="标签云场景" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8" />
                                    <Border Padding="12" CornerRadius="8"
                                            Background="{DynamicResource SecondaryRegionBrush}"
                                            Margin="0,0,0,10">
                                        <WrapPanel>
                                            <pf:Chip Content="WPF" IsDeletable="True" Margin="0,0,6,6" />
                                            <pf:Chip Content=".NET 8" IsDeletable="True"
                                                     Style="{StaticResource ChipPrimary}" Margin="0,0,6,6" />
                                            <pf:Chip Content="MVVM" IsDeletable="True"
                                                     Style="{StaticResource ChipOutlinedPrimary}" Margin="0,0,6,6" />
                                            <pf:Chip Content="Material Design" IsDeletable="True" Margin="0,0,6,6" />
                                            <pf:Chip Content="Prism" IsDeletable="True"
                                                     Style="{StaticResource ChipSuccess}" Margin="0,0,6,6" />
                                            <pf:Chip Content="DryIoc" IsDeletable="True" Margin="0,0,6,6" />
                                            <pf:Chip Content="EF Core" IsDeletable="True"
                                                     Style="{StaticResource ChipOutlined}" Margin="0,0,6,6" />
                                            <pf:Chip Content="SQLite" IsDeletable="True"
                                                     Style="{StaticResource ChipWarning}" Margin="0,0,0,6" />
                                        </WrapPanel>
                                    </Border>
                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:ChipDemoViewModel.XamlDeletable}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
