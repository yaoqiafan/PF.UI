<UserControl x:Class="PF.UI.Views.Demos.MiscDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="1600" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:MiscDemoViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="24,20,24,16"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <StackPanel>
                <TextBlock Text="杂项控件" FontSize="20" FontWeight="Bold"
                           Foreground="{DynamicResource PrimaryTextBrush}" />
                <TextBlock Text="Watermark · DashedBorder · BlendEffectBox · GotoTop · ChatBubble · Magnifier"
                           FontSize="12" Margin="0,4,0,0"
                           Foreground="{DynamicResource SecondaryTextBrush}" />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. Watermark ═══════════ -->
                    <Border x:Name="Section_Watermark" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. Watermark — 水印覆盖层" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12"
                                               Text="Control 子类，以内容承载控件为子级，在其上覆盖半透明水印文本/图形。Content=水印内容，Angle=旋转角度，MarkBrush=颜色。" />

                                    <WrapPanel Margin="0,0,0,14">
                                        <!-- 内层内容不设背景，水印 DrawingBrush 从 PART_Root.Background 透出 -->
                                        <pf:Watermark Mark="PF.UI DEMO" Angle="45" MarkBrush="{DynamicResource DangerBrush}" MarkMargin="20"
                                                      Width="300" Height="140" HorizontalAlignment="Left" Margin="0,0,16,0">
                                            <Grid Width="300" Height="140">
                                                <TextBlock Text="45° 旋转 · 红色水印" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold" />
                                            </Grid>
                                        </pf:Watermark>

                                        <pf:Watermark Mark="仅预览" Angle="-30" MarkBrush="{DynamicResource PrimaryBrush}" MarkMargin="16"
                                                      Width="200" Height="140" HorizontalAlignment="Left">
                                            <Grid Width="200" Height="140">
                                                <TextBlock Text="-30° 主题色" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                           Foreground="{DynamicResource PrimaryTextBrush}" FontSize="13" FontWeight="SemiBold" />
                                            </Grid>
                                        </pf:Watermark>
                                    </WrapPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:MiscDemoViewModel.XamlWatermark}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. DashedBorder ═══════════ -->
                    <Border x:Name="Section_DashedBorder" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. DashedBorder — 虚线边框" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12"
                                               Text="Decorator 子类。BorderDashArray=虚线间隔，CornerRadius=圆角，BorderDashCap=线帽（Flat/ Square/ Round），BorderDashThickness=虚线线粗。" />

                                    <WrapPanel Margin="0,0,0,8">
                                        <pf:DashedBorder BorderBrush="{DynamicResource PrimaryBrush}" BorderThickness="2"
                                                               BorderDashArray="4,2" CornerRadius="8" Padding="16,8"
                                                               Margin="0,0,12,8">
                                            <TextBlock Text="4,2 · Round" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12" />
                                        </pf:DashedBorder>
                                        <pf:DashedBorder BorderBrush="{DynamicResource DangerBrush}" BorderThickness="2"
                                                               BorderDashArray="8,4" CornerRadius="12"
                                                               BorderDashCap="Round" Padding="16,8"
                                                               Margin="0,0,12,8">
                                            <TextBlock Text="8,4 · Round" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12" />
                                        </pf:DashedBorder>
                                        <pf:DashedBorder BorderBrush="{DynamicResource WarningBrush}" BorderThickness="2"
                                                               BorderDashArray="2,4" CornerRadius="6"
                                                               BorderDashThickness="3" Padding="16,8"
                                                               Margin="0,0,12,8">
                                            <TextBlock Text="2,4 · Thick=3" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12" />
                                        </pf:DashedBorder>
                                        <pf:DashedBorder BorderBrush="{DynamicResource SuccessBrush}" BorderThickness="2"
                                                               BorderDashArray="6,3,2,3" CornerRadius="8" Padding="16,8"
                                                               Margin="0,0,0,8">
                                            <TextBlock Text="6,3,2,3 复合" Foreground="{DynamicResource PrimaryTextBrush}" FontSize="12" />
                                        </pf:DashedBorder>
                                    </WrapPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:MiscDemoViewModel.XamlDashedBorder}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. BlendEffectBox ═══════════ -->
                    <Border x:Name="Section_BlendEffect" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. BlendEffectBox — 多层混合效果" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" TextWrapping="Wrap"
                                               Text="Content 为底层原始内容，Effects 集合中的 WPF Effect 从外到内依次叠加（DropShadowEffect / BlurEffect / 自定义 Effect），实现多重视觉混合。" />

                                    <!-- 示例一：主题色阴影 + 无模糊 -->
                                    <TextBlock Text="主题色外发光（DropShadowEffect）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="6"
                                            Padding="16,12" Margin="0,0,0,14" HorizontalAlignment="Left">
                                        <pf:BlendEffectBox>
                                            <pf:BlendEffectBox.Effects>
                                                <DropShadowEffect Color="#1565C0" BlurRadius="24"
                                                                  ShadowDepth="0" Opacity="0.75" />
                                            </pf:BlendEffectBox.Effects>
                                            <pf:BlendEffectBox.Content>
                                                <Border Width="200" Height="70" CornerRadius="8"
                                                        Background="{DynamicResource PrimaryBrush}">
                                                    <TextBlock Text="主题色外发光" FontSize="14" FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                            </pf:BlendEffectBox.Content>
                                        </pf:BlendEffectBox>
                                    </Border>

                                    <!-- 示例二：危险色阴影 -->
                                    <TextBlock Text="危险色阴影（DangerBrush）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="6"
                                            Padding="16,12" Margin="0,0,0,14" HorizontalAlignment="Left">
                                        <pf:BlendEffectBox>
                                            <pf:BlendEffectBox.Effects>
                                                <DropShadowEffect Color="#C62828" BlurRadius="20"
                                                                  ShadowDepth="0" Opacity="0.8" />
                                            </pf:BlendEffectBox.Effects>
                                            <pf:BlendEffectBox.Content>
                                                <Border Width="200" Height="70" CornerRadius="8"
                                                        Background="{DynamicResource DangerBrush}">
                                                    <TextBlock Text="危险色外发光" FontSize="14" FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                            </pf:BlendEffectBox.Content>
                                        </pf:BlendEffectBox>
                                    </Border>

                                    <!-- 示例三：模糊效果 -->
                                    <TextBlock Text="模糊效果（BlurEffect，Radius=6）" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="6"
                                            Padding="16,12" Margin="0,0,0,4" HorizontalAlignment="Left">
                                        <pf:BlendEffectBox>
                                            <pf:BlendEffectBox.Effects>
                                                <BlurEffect Radius="6" />
                                            </pf:BlendEffectBox.Effects>
                                            <pf:BlendEffectBox.Content>
                                                <Border Width="200" Height="70" CornerRadius="8"
                                                        Background="{DynamicResource SuccessBrush}">
                                                    <TextBlock Text="模糊处理内容" FontSize="14" FontWeight="Bold"
                                                               Foreground="White"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center" />
                                                </Border>
                                            </pf:BlendEffectBox.Content>
                                        </pf:BlendEffectBox>
                                    </Border>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:MiscDemoViewModel.XamlBlendEffect}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 4. GotoTop ═══════════ -->
                    <Border x:Name="Section_GotoTop" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="4. GotoTop — 返回顶部" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" TextWrapping="Wrap"
                                               Text="Button 子类，绑定 ScrollViewer Target，滚动超过 HidingHeight 时自动浮现在右下角。Animated=True 启用惯性滚动动画。" />

                                    <!-- SimplePanel 叠加容器；Target 直接绑 ScrollViewer 自身 -->
                                    <pf:SimplePanel Height="220" Margin="0,0,0,8">
                                        <pf:ScrollViewer x:Name="GotoTopScroll"
                                                         VerticalScrollBarVisibility="Auto"
                                                         IsInertiaEnabled="True"
                                                         BorderBrush="{DynamicResource BorderBrush}"
                                                         BorderThickness="1">
                                            <Border Height="800">
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0.5,0" EndPoint="0.5,1">
                                                        <GradientStop Color="{DynamicResource PrimaryColor}" Offset="0" />
                                                        <GradientStop Color="{DynamicResource SecondaryRegionColor}" Offset="0.5" />
                                                        <GradientStop Color="{DynamicResource DangerColor}" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <TextBlock Text="向下滚动，右下角将出现返回顶部按钮"
                                                           HorizontalAlignment="Center" VerticalAlignment="Top"
                                                           Margin="0,12,0,0" FontSize="11"
                                                           Foreground="White" Opacity="0.8" />
                                            </Border>
                                        </pf:ScrollViewer>
                                        <pf:GotoTop Target="{Binding ElementName=GotoTopScroll}"
                                                    HidingHeight="60"
                                                    AutoHiding="True"
                                                    Animated="True"
                                                    AnimationTime="400"
                                                    HorizontalAlignment="Right"
                                                    VerticalAlignment="Bottom"
                                                    Margin="0,0,16,16"
                                                    Width="36" Height="36"
                                                    Style="{StaticResource ButtonPrimary}" />
                                    </pf:SimplePanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,4,0,0"
                                        Code="{x:Static vm:MiscDemoViewModel.XamlGotoTop}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 5. ChatBubble ═══════════ -->
                    <Border x:Name="Section_ChatBubble" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="5. ChatBubble — 聊天气泡" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" TextWrapping="Wrap"
                                               Text="SelectableItem 子类。Role=Sender（发送者/靠右）| Receiver（接收者/靠左），Type=String | Image | Audio | Custom。容器必须是 StackPanel（Stretch 宽度），ChatBubble 的 HorizontalAlignment 才能生效。" />

                                    <!-- StackPanel 作为容器：拉伸宽度，Role 对齐才能生效 -->
                                    <Border Background="{DynamicResource SecondaryRegionBrush}"
                                            CornerRadius="6" Padding="12,8" Margin="0,0,0,4">
                                        <StackPanel>
                                            <pf:ChatBubble Role="Receiver" Type="String"
                                                           Content="你好，这是接收到的消息"
                                                           IsRead="True" Margin="0,0,0,8" />
                                            <pf:ChatBubble Role="Sender" Type="String"
                                                           Content="你好！这是发送的消息"
                                                           IsRead="True" Margin="0,0,0,8" />
                                            <!-- Type=Image 的 Content 需为 ImageSource；此处用 Custom 展示图片占位视觉 -->
                                            <pf:ChatBubble Role="Receiver" Type="Custom" IsRead="False" Margin="0,0,0,8">
                                                <Border Width="140" Height="90" CornerRadius="8" ClipToBounds="True">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#4CAF50" Offset="0" />
                                                            <GradientStop Color="#1565C0" Offset="1" />
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                        <pf:PackIcon Kind="ImageOutline" Width="28" Height="28"
                                                                     Foreground="White" HorizontalAlignment="Center" />
                                                        <TextBlock Text="图片消息" Foreground="White" FontSize="11"
                                                                   HorizontalAlignment="Center" Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </pf:ChatBubble>
                                            <pf:ChatBubble Role="Sender" Type="Audio"
                                                           Content="语音 03:12"
                                                           IsRead="True" Margin="0,0,0,8" />
                                            <pf:ChatBubble Role="Receiver" Type="Custom" IsRead="False">
                                                <StackPanel Orientation="Horizontal">
                                                    <pf:PackIcon Kind="FileDocument" Width="16" Height="16"
                                                                 Foreground="{DynamicResource PrimaryBrush}"
                                                                 VerticalAlignment="Center" Margin="0,0,6,0" />
                                                    <TextBlock Text="自定义消息.pdf" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </pf:ChatBubble>
                                        </StackPanel>
                                    </Border>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:MiscDemoViewModel.XamlChatBubble}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 6. Magnifier ═══════════ -->
                    <Border x:Name="Section_Magnifier" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="6. Magnifier — 鼠标放大镜" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,12" TextWrapping="Wrap"
                                               Text="AdornerElement 子类，鼠标悬停到 Target 元素上时，在 AdornerLayer 自动显示放大镜浮层。Scale=放大倍数（默认 5.0），HorizontalOffset/VerticalOffset=镜头位置偏移。" />

                                    <TextBlock Text="将鼠标移入下方文本区，放大镜将跟随鼠标显示" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />

                                    <!-- Magnifier 通过 pf:AdornerElement.Instance 挂载到 Target，不放入可视树 -->
                                    <Border Background="{DynamicResource SecondaryRegionBrush}"
                                            CornerRadius="8" Padding="20,16" Margin="0,0,0,4"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <pf:AdornerElement.Instance>
                                            <pf:Magnifier Scale="3" Width="120" Height="120"
                                                          HorizontalOffset="20" VerticalOffset="20" />
                                        </pf:AdornerElement.Instance>
                                        <StackPanel>
                                            <TextBlock Text="PF.UI 控件库 — 企业级工业桌面 UI 组件"
                                                       FontSize="15" FontWeight="Bold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}"
                                                       Margin="0,0,0,6" />
                                            <TextBlock Text="基于 WPF + .NET 8 构建，提供 100+ 高质量自定义控件。"
                                                       FontSize="12"
                                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                                       TextWrapping="Wrap" Margin="0,0,0,4" />
                                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                                <pf:PackIcon Kind="Chip" Width="16" Height="16"
                                                             Foreground="{DynamicResource PrimaryBrush}"
                                                             VerticalAlignment="Center" Margin="0,0,6,0" />
                                                <TextBlock Text="鼠标悬停此区域，放大镜在 AdornerLayer 浮现并跟随"
                                                           FontSize="11"
                                                           Foreground="{DynamicResource ThirdlyTextBrush}"
                                                           VerticalAlignment="Center" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,4,0,0"
                                        Code="{x:Static vm:MiscDemoViewModel.XamlMagnifier}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent" MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
