<UserControl x:Class="PF.UI.Views.Demos.InteractivityDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:InteractivityDemoViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="交互与行为" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="EventToCommand · RoutedEventTrigger · ControlCommands · MouseDragElementBehavior · FluidMoveBehavior"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <Border Grid.Column="1" MinWidth="200" MaxWidth="340"
                        CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon Kind="Console" Width="14" Height="14"
                                     Foreground="{DynamicResource ThirdlyTextBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LastResult}" FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. EventToCommand ═══════════ -->
                    <Border x:Name="Section_EventToCommand" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. EventToCommand · RoutedEventTrigger" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,16"
                                               Text="将任意 CLR 事件桥接到 ViewModel 命令，适用于无 Command 属性的控件。RoutedEventTrigger 额外支持 WPF 路由事件（冒泡/隧道）" />

                                    <!-- 基础事件绑定 -->
                                    <TextBlock Text="基础事件绑定（无 Command 属性的控件）" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                    <WrapPanel Margin="0,0,0,16">
                                        <!-- MouseEnter 事件 -->
                                        <Border Width="160" Height="44" CornerRadius="8" Cursor="Hand"
                                                Background="{DynamicResource SecondaryRegionBrush}"
                                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                                Margin="0,0,8,8">
                                            <pf:Interaction.Triggers>
                                                <pf:EventTrigger EventName="MouseEnter">
                                                    <pf:EventToCommand Command="{Binding LogMouseEnterCommand}" />
                                                </pf:EventTrigger>
                                            </pf:Interaction.Triggers>
                                            <TextBlock Text="悬停触发 MouseEnter" FontSize="11"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </Border>

                                        <!-- LostFocus 事件 -->
                                        <TextBox Width="160" Height="44" Margin="0,0,8,8"
                                                 pf:InfoElement.Placeholder="点击后移焦点触发">
                                            <pf:Interaction.Triggers>
                                                <pf:EventTrigger EventName="LostFocus">
                                                    <pf:EventToCommand Command="{Binding LogLostFocusCommand}" />
                                                </pf:EventTrigger>
                                            </pf:Interaction.Triggers>
                                        </TextBox>

                                        <!-- SelectionChanged 事件 -->
                                        <ListBox Width="160" Height="80" Margin="0,0,8,8">
                                            <pf:Interaction.Triggers>
                                                <pf:EventTrigger EventName="SelectionChanged">
                                                    <pf:EventToCommand Command="{Binding LogSelectionChangedCommand}" />
                                                </pf:EventTrigger>
                                            </pf:Interaction.Triggers>
                                            <ListBoxItem Content="选项 A" />
                                            <ListBoxItem Content="选项 B" />
                                            <ListBoxItem Content="选项 C" />
                                        </ListBox>
                                    </WrapPanel>

                                    <Separator Margin="0,0,0,14" />

                                    <!-- MustToggleIsEnabled -->
                                    <TextBlock Text="MustToggleIsEnabled — CanExecute 联动控件启/禁用" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <CheckBox Content="IsCommandEnabled" IsChecked="{Binding IsCommandEnabled}"
                                                  VerticalAlignment="Center" Margin="0,0,20,0" />
                                        <Button Content="Submit（MustToggleIsEnabled=True）" Height="34">
                                            <pf:Interaction.Triggers>
                                                <pf:EventTrigger EventName="Click">
                                                    <pf:EventToCommand Command="{Binding SubmitCommand}"
                                                                       MustToggleIsEnabled="True" />
                                                </pf:EventTrigger>
                                            </pf:Interaction.Triggers>
                                        </Button>
                                    </StackPanel>

                                    <Separator Margin="0,0,0,14" />

                                    <!-- RoutedEventTrigger -->
                                    <TextBlock Text="RoutedEventTrigger — 路由事件（PreviewMouseDown 隧道）" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                    <Border Height="44" CornerRadius="8" Cursor="Hand" Margin="0,0,0,14"
                                            Background="{DynamicResource SecondaryRegionBrush}"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <pf:Interaction.Triggers>
                                            <pf:RoutedEventTrigger RoutedEvent="{x:Static UIElement.PreviewMouseDownEvent}">
                                                <pf:EventToCommand Command="{Binding LogPreviewClickCommand}" />
                                            </pf:RoutedEventTrigger>
                                        </pf:Interaction.Triggers>
                                        <TextBlock Text="点击任意位置 → PreviewMouseDown 路由事件触发" FontSize="11"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                                    </Border>

                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:InteractivityDemoViewModel.XamlEventToCommand}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. 内置命令 ═══════════ -->
                    <Border x:Name="Section_Commands" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. 内置命令 — ControlCommands" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,14"
                                               Text="ControlCommands 提供 5 个全局 ICommand 单例（可直接绑定）+ 30+ 个 RoutedCommand（需在 CommandBindings 中注册处理逻辑）" />

                                    <!-- ICommand 速查 -->
                                    <TextBlock Text="全局 ICommand（直接 x:Static 绑定，无需注册）" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="6"
                                            Padding="12,10" Margin="0,0,0,14">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="190" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Grid.Row="0" Grid.Column="0" Text="命令" FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>
                                            <TextBlock Grid.Row="0" Grid.Column="1" Text="说明 / CommandParameter" FontSize="11" FontWeight="Bold"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8"/>

                                            <TextBlock Grid.Row="1" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="CloseWindow" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="向上查找 Window 并 Close()，参数：任意子控件 Self" Foreground="{DynamicResource SecondaryTextBrush}" />

                                            <TextBlock Grid.Row="2" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="ShutdownApp" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="2" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="Application.Current.Shutdown()，无需参数" Foreground="{DynamicResource SecondaryTextBrush}" />

                                            <TextBlock Grid.Row="3" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="PushMainWindow2Top" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="3" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="Application.MainWindow 激活置顶" Foreground="{DynamicResource SecondaryTextBrush}" />

                                            <TextBlock Grid.Row="4" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="OpenLink" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="4" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="Shell 打开 URL，参数：string URL" Foreground="{DynamicResource SecondaryTextBrush}" />

                                            <TextBlock Grid.Row="5" Grid.Column="0" FontFamily="Consolas" FontSize="10.5" Margin="0,3"
                                                       Text="StartScreenshot" Foreground="{DynamicResource PrimaryBrush}" />
                                            <TextBlock Grid.Row="5" Grid.Column="1" FontSize="10.5" Margin="0,3"
                                                       Text="启动 Screenshot 截图控件流程" Foreground="{DynamicResource SecondaryTextBrush}" />
                                        </Grid>
                                    </Border>

                                    <!-- RoutedCommand 列表 -->
                                    <TextBlock Text="RoutedCommand 速查（需 CommandBindings 注册）" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="6"
                                            Padding="12,10" Margin="0,0,0,14">
                                        <TextBlock FontFamily="Consolas" FontSize="10.5"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   TextWrapping="Wrap" LineHeight="20">
                                            <Run Text="Search · Clear · Switch · Open · Save · Selected · Close · Cancel · Confirm" />
                                            <LineBreak />
                                            <Run Text="Yes · No · CloseAll · CloseOther · Prev · Next · Jump · More · Toggle" />
                                            <LineBreak />
                                            <Run Text="RotateLeft · RotateRight · Reduce · Enlarge · Restore" />
                                            <LineBreak />
                                            <Run Text="Am · Pm · Sure · HourChange · MinuteChange · SecondChange · MouseMove" />
                                            <LineBreak />
                                            <Run Text="SortByCategory · SortByName" />
                                        </TextBlock>
                                    </Border>

                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:InteractivityDemoViewModel.XamlCommands}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. MouseDragElementBehavior ═══════════ -->
                    <Border x:Name="Section_DragBehavior" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. MouseDragElementBehavior — 鼠标拖拽" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,14"
                                               Text="通过修改元素的 RenderTransform（TranslateTransform）实现拖拽，支持限制在父容器范围内" />

                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="16" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>

                                        <!-- 自由拖拽 -->
                                        <StackPanel Grid.Column="0">
                                            <TextBlock Text="ConstrainToParentBounds = False（默认）" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                            <Border Height="160" CornerRadius="6" ClipToBounds="False"
                                                    Background="{DynamicResource SecondaryRegionBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                <Canvas>
                                                    <Border Width="72" Height="72" CornerRadius="8" Cursor="SizeAll"
                                                            Canvas.Left="30" Canvas.Top="44"
                                                            Background="{DynamicResource PrimaryBrush}">
                                                        <pf:Interaction.Behaviors>
                                                            <pf:MouseDragElementBehavior />
                                                        </pf:Interaction.Behaviors>
                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <pf:PackIcon Kind="CursorMove" Width="20" Height="20"
                                                                         Foreground="White" HorizontalAlignment="Center" />
                                                            <TextBlock Text="自由拖拽" FontSize="10" Foreground="White"
                                                                       HorizontalAlignment="Center" Margin="0,4,0,0" />
                                                        </StackPanel>
                                                    </Border>
                                                </Canvas>
                                            </Border>
                                        </StackPanel>

                                        <!-- 限制范围 -->
                                        <StackPanel Grid.Column="2">
                                            <TextBlock Text="ConstrainToParentBounds = True" FontSize="11" FontWeight="SemiBold"
                                                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,6" />
                                            <Border Height="160" CornerRadius="6" ClipToBounds="True"
                                                    Background="{DynamicResource SecondaryRegionBrush}"
                                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                                <Canvas>
                                                    <Border Width="72" Height="72" CornerRadius="8" Cursor="SizeAll"
                                                            Canvas.Left="30" Canvas.Top="44"
                                                            Background="{DynamicResource AccentBrush}">
                                                        <pf:Interaction.Behaviors>
                                                            <pf:MouseDragElementBehavior ConstrainToParentBounds="True" />
                                                        </pf:Interaction.Behaviors>
                                                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                            <pf:PackIcon Kind="CursorMove" Width="20" Height="20"
                                                                         Foreground="White" HorizontalAlignment="Center" />
                                                            <TextBlock Text="范围限制" FontSize="10" Foreground="White"
                                                                       HorizontalAlignment="Center" Margin="0,4,0,0" />
                                                        </StackPanel>
                                                    </Border>
                                                </Canvas>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:InteractivityDemoViewModel.XamlDragBehavior}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 4. FluidMoveBehavior ═══════════ -->
                    <Border x:Name="Section_FluidMove" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="4. FluidMoveBehavior — 流体位移动画" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,14"
                                               Text="附加到 Panel，当子元素增删或位移时触发平滑动画。支持独立的 X/Y 缓动函数配置" />

                                    <!-- 操作按钮 -->
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,14">
                                        <Button Content="随机插入" Height="32"
                                                Command="{Binding AddFluidItemCommand}"
                                                Style="{StaticResource ButtonPrimary}" Margin="0,0,8,0" />
                                        <Button Content="移除末项" Height="32"
                                                Command="{Binding RemoveLastCommand}"
                                                Style="{StaticResource ButtonDefault}" Margin="0,0,8,0" />
                                        <Button Content="乱序重排" Height="32"
                                                Command="{Binding ShuffleCommand}"
                                                Style="{StaticResource ButtonDefault}" />
                                    </StackPanel>

                                    <!-- 动画演示区 -->
                                    <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="8"
                                            Padding="12" MinHeight="80" Margin="0,0,0,14"
                                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <ItemsControl ItemsSource="{Binding FluidItems}">
                                            <ItemsControl.ItemsPanel>
                                                <ItemsPanelTemplate>
                                                    <WrapPanel>
                                                        <pf:Interaction.Behaviors>
                                                            <pf:FluidMoveBehavior Duration="0:0:0.4" FloatAbove="True">
                                                                <pf:FluidMoveBehavior.EaseX>
                                                                    <CubicEase EasingMode="EaseInOut" />
                                                                </pf:FluidMoveBehavior.EaseX>
                                                                <pf:FluidMoveBehavior.EaseY>
                                                                    <CubicEase EasingMode="EaseInOut" />
                                                                </pf:FluidMoveBehavior.EaseY>
                                                            </pf:FluidMoveBehavior>
                                                        </pf:Interaction.Behaviors>
                                                    </WrapPanel>
                                                </ItemsPanelTemplate>
                                            </ItemsControl.ItemsPanel>
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Margin="4,4,0,0" Padding="14,7" CornerRadius="6"
                                                            Background="{DynamicResource PrimaryBrush}">
                                                        <TextBlock Text="{Binding}" Foreground="White"
                                                                   FontSize="12" FontWeight="SemiBold" />
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </Border>

                                    <controls:DemoCodeBlock CodeLanguage="XAML"
                                        Code="{x:Static vm:InteractivityDemoViewModel.XamlFluidMove}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
