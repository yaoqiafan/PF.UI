<UserControl x:Class="PF.UI.Views.Demos.GrowlNotificationView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:GrowlNotificationViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="消息通知 Growl / Notification" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="Growl · Notification · Poptip"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <Border Grid.Column="1" MinWidth="200" MaxWidth="340"
                        CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon Kind="Console" Width="14" Height="14"
                                     Foreground="{DynamicResource ThirdlyTextBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LastResult}" FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. Growl ═══════════ -->
                    <Border x:Name="Section_Growl" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. Growl" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" TextWrapping="Wrap"
                                               Text="静态方法 Growl.Success / Info / Warning / Error / Ask，通过 Token 将通知路由到页面内指定 Panel（StackPanel 设置 pf:Growl.Token=&quot;demo-growl&quot;）。" />
                                    <WrapPanel Margin="0,0,0,10">
                                        <Button Content="Success" Command="{Binding GrowlSuccessCommand}"
                                                Style="{StaticResource ButtonSuccess}" Margin="0,0,10,8" />
                                        <Button Content="Info" Command="{Binding GrowlInfoCommand}"
                                                Style="{StaticResource ButtonInfo}" Margin="0,0,10,8" />
                                        <Button Content="Warning" Command="{Binding GrowlWarningCommand}"
                                                Style="{StaticResource ButtonWarning}" Margin="0,0,10,8" />
                                        <Button Content="Error" Command="{Binding GrowlDangerCommand}"
                                                Style="{StaticResource ButtonDanger}" Margin="0,0,10,8" />
                                        <Button Content="Ask 确认" Command="{Binding GrowlAskCommand}"
                                                Style="{StaticResource ButtonDefault}" Margin="0,0,0,8" />
                                    </WrapPanel>

                                    <!-- 本地 Growl 面板，通知在此区域内显示 -->
                                    <Border BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                                            CornerRadius="6" Background="{DynamicResource SecondaryRegionBrush}"
                                            MinHeight="60" Padding="4" Margin="0,0,0,10">
                                        <StackPanel pf:Growl.Token="demo-growl"
                                                    pf:Growl.ShowMode="Prepend" />
                                    </Border>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,0,0,0"
                                        Code="{x:Static vm:GrowlNotificationViewModel.XamlGrowl}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. Notification ═══════════ -->
                    <Border x:Name="Section_Notification" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. Notification" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="Notification.Show(content, animation, staysOpen) 弹出系统通知"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,10" />
                                    <Button Content="弹出系统通知" Command="{Binding ShowNotificationCommand}"
                                            Style="{StaticResource ButtonPrimary}" HorizontalAlignment="Left" Margin="0,0,0,4" />
                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:GrowlNotificationViewModel.XamlNotification}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. Poptip ═══════════ -->
                    <Border x:Name="Section_Poptip" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. Poptip" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>

                                    <!-- HitMode 演示 -->
                                    <TextBlock Text="HitMode — 触发方式" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8" />
                                    <WrapPanel Margin="0,0,0,12">
                                        <Button Content="Hover 悬停" pf:Poptip.HitMode="Hover"
                                                pf:Poptip.Content="HitMode=Hover" Margin="0,0,8,8" />
                                        <Button Content="Click 点击" pf:Poptip.HitMode="Click"
                                                pf:Poptip.Content="HitMode=Click（再次点击关闭）" Margin="0,0,8,8" />
                                        <Button Content="Focus 聚焦" pf:Poptip.HitMode="Focus"
                                                pf:Poptip.Content="HitMode=Focus（失焦关闭）" Margin="0,0,8,8" />
                                        <ToggleButton x:Name="PoptipToggle" Content="None 手动控制" Margin="0,0,0,8"
                                                      pf:Poptip.HitMode="None"
                                                      pf:Poptip.IsOpen="{Binding IsChecked, ElementName=PoptipToggle}"
                                                      pf:Poptip.Content="IsOpen 绑定 ToggleButton.IsChecked" />
                                    </WrapPanel>

                                    <!-- 12 方向展示 -->
                                    <TextBlock Text="PlacementType — 12 方向定位" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,8" />
                                    <Grid Width="360" HorizontalAlignment="Left" Margin="0,0,0,8">
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <!-- 顶行 -->
                                        <UniformGrid Grid.Row="0" Grid.Column="1" Columns="3" Margin="0,0,0,4">
                                            <Button Content="TopLeft" pf:Poptip.HitMode="Hover" pf:Poptip.Placement="TopLeft" pf:Poptip.Content="TopLeft" Margin="2" FontSize="10" />
                                            <Button Content="Top" pf:Poptip.HitMode="Hover" pf:Poptip.Placement="Top" pf:Poptip.Content="Top" Margin="2" FontSize="10" />
                                            <Button Content="TopRight" pf:Poptip.HitMode="Hover" pf:Poptip.Placement="TopRight" pf:Poptip.Content="TopRight" Margin="2" FontSize="10" />
                                        </UniformGrid>
                                        <!-- 左列 -->
                                        <UniformGrid Grid.Row="1" Grid.RowSpan="3" Grid.Column="0" Rows="3" Margin="0,0,4,0">
                                            <Button Content="LeftTop" pf:Poptip.HitMode="Hover" pf:Poptip.Placement="LeftTop" pf:Poptip.Content="LeftTop" Margin="2" FontSize="10" />
                                            <Button Content="Left" pf:Poptip.HitMode="Hover" pf:Poptip.Placement="Left" pf:Poptip.Content="Left" Margin="2" FontSize="10" />
                                            <Button Content="LeftBottom" pf:Poptip.HitMode="Hover" pf:Poptip.Placement="LeftBottom" pf:Poptip.Content="LeftBottom" Margin="2" FontSize="10" />
                                        </UniformGrid>
                                        <!-- 中央 -->
                                        <Border Grid.Row="1" Grid.RowSpan="3" Grid.Column="1"
                                                Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="6" Margin="4">
                                            <TextBlock Text="悬停周围按钮&#x0a;查看气泡方向" HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" TextAlignment="Center" FontSize="11"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}" />
                                        </Border>
                                        <!-- 右列 -->
                                        <UniformGrid Grid.Row="1" Grid.RowSpan="3" Grid.Column="2" Rows="3" Margin="4,0,0,0">
                                            <Button Content="RightTop" pf:Poptip.HitMode="Hover" pf:Poptip.Placement="RightTop" pf:Poptip.Content="RightTop" Margin="2" FontSize="10" />
                                            <Button Content="Right" pf:Poptip.HitMode="Hover" pf:Poptip.Placement="Right" pf:Poptip.Content="Right" Margin="2" FontSize="10" />
                                            <Button Content="RightBottom" pf:Poptip.HitMode="Hover" pf:Poptip.Placement="RightBottom" pf:Poptip.Content="RightBottom" Margin="2" FontSize="10" />
                                        </UniformGrid>
                                        <!-- 底行 -->
                                        <UniformGrid Grid.Row="4" Grid.Column="1" Columns="3" Margin="0,4,0,0">
                                            <Button Content="BottomLeft" pf:Poptip.HitMode="Hover" pf:Poptip.Placement="BottomLeft" pf:Poptip.Content="BottomLeft" Margin="2" FontSize="10" />
                                            <Button Content="Bottom" pf:Poptip.HitMode="Hover" pf:Poptip.Placement="Bottom" pf:Poptip.Content="Bottom" Margin="2" FontSize="10" />
                                            <Button Content="BottomRight" pf:Poptip.HitMode="Hover" pf:Poptip.Placement="BottomRight" pf:Poptip.Content="BottomRight" Margin="2" FontSize="10" />
                                        </UniformGrid>
                                    </Grid>

                                    <!-- UIElement 内容 + Offset -->
                                    <TextBlock Text="Content 为 UIElement · VerticalOffset / HorizontalOffset" FontSize="13" FontWeight="SemiBold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,8,0,8" />
                                    <WrapPanel Margin="0,0,0,4">
                                        <Button Content="图标气泡" pf:Poptip.HitMode="Hover" Margin="0,0,8,8"
                                                pf:Poptip.Placement="Top">
                                            <pf:Poptip.Content>
                                                <StackPanel Orientation="Horizontal">
                                                    <pf:PackIcon Kind="CheckCircle" Width="16" Height="16"
                                                                 Foreground="{DynamicResource SuccessBrush}" Margin="0,0,6,0" />
                                                    <TextBlock Text="Content 可以是任意 UIElement" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </pf:Poptip.Content>
                                        </Button>
                                        <Button Content="偏移 +40px" pf:Poptip.HitMode="Hover"
                                                pf:Poptip.Content="HorizontalOffset=40" pf:Poptip.HorizontalOffset="40"
                                                Margin="0,0,0,8" />
                                    </WrapPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,8,0,0"
                                        Code="{x:Static vm:GrowlNotificationViewModel.XamlPoptip}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
