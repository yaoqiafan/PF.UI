<UserControl x:Class="PF.UI.Views.Demos.SlidersDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:SlidersDemoViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 页头 -->
        <Border Grid.Row="0" Padding="24,14,24,12"
                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                Background="{DynamicResource RegionBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <TextBlock Text="滑块演示" FontSize="20" FontWeight="Bold"
                               Foreground="{DynamicResource PrimaryTextBrush}" />
                    <TextBlock Text="Slider · RangeSlider · PreviewSlider · CompareSlider"
                               FontSize="12" Margin="0,4,0,0"
                               Foreground="{DynamicResource SecondaryTextBrush}" />
                </StackPanel>
                <Border Grid.Column="1" MinWidth="200" MaxWidth="340"
                        CornerRadius="8" Padding="12,8"
                        Background="{DynamicResource SecondaryRegionBrush}"
                        VerticalAlignment="Center" Margin="20,0,0,0">
                    <StackPanel Orientation="Horizontal">
                        <pf:PackIcon Kind="Console" Width="14" Height="14"
                                     Foreground="{DynamicResource ThirdlyTextBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0" />
                        <TextBlock Text="{Binding LastResult}" FontSize="11.5"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" />
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" MinWidth="400" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                          VerticalScrollBarVisibility="Auto"
                          ScrollChanged="ContentScroll_ScrollChanged">
                <StackPanel Margin="24,16,16,24" MaxWidth="820">

                    <!-- ═══════════ 1. 原生 Slider ═══════════ -->
                    <Border x:Name="Section_NativeSlider" Padding="0,0,0,4">
                        <StackPanel>
                            <TextBlock Text="1. 原生 Slider" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="WPF 原生 Slider 自动应用 PF.UI 主题，无需额外样式"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,14" />

                                    <!-- 基本水平 -->
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="40" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="基本水平" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100" VerticalAlignment="Center"
                                                Value="{Binding SliderValue, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="2" FontSize="11" FontFamily="Consolas"
                                                   Foreground="{DynamicResource ThirdlyTextBrush}"
                                                   Text="{Binding SliderValue, StringFormat=F0}"
                                                   VerticalAlignment="Center" HorizontalAlignment="Right" />
                                    </Grid>

                                    <!-- 带刻度 + 对齐 -->
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="刻度对齐" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100"
                                                TickFrequency="10" TickPlacement="BottomRight"
                                                IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- 禁用态 -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="禁用态" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <Slider Grid.Column="1" Minimum="0" Maximum="100"
                                                Value="60" IsEnabled="False" VerticalAlignment="Center" />
                                    </Grid>

                                    <!-- 垂直方向 -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="垂直方向" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Top" Width="120" Margin="0,4,0,0" />
                                        <Slider Orientation="Vertical" Minimum="0" Maximum="100"
                                                Height="100" Value="60" Margin="0,0,20,0" />
                                        <Slider Orientation="Vertical" Minimum="0" Maximum="100"
                                                Height="100" Value="30"
                                                TickFrequency="20" TickPlacement="BottomRight"
                                                IsSnapToTickEnabled="True" />
                                    </StackPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,14,0,0"
                                        Code="{x:Static vm:SlidersDemoViewModel.XamlNativeSlider}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 2. RangeSlider ═══════════ -->
                    <Border x:Name="Section_RangeSlider" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="2. RangeSlider" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="双 Thumb 区间滑块 — ValueStart / ValueEnd 分别控制两端"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,14" />

                                    <!-- 基本区间 -->
                                    <Grid Margin="0,0,0,6">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="基本区间" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <pf:RangeSlider Grid.Column="1" Minimum="0" Maximum="100"
                                                        ValueStart="{Binding RangeStart, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                        ValueEnd="{Binding RangeEnd, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <StackPanel Orientation="Horizontal" Margin="120,0,0,14">
                                        <TextBlock FontSize="10" FontFamily="Consolas"
                                                   Foreground="{DynamicResource ThirdlyTextBrush}">
                                            <Run Text="Start: " /><Run Text="{Binding RangeStart, StringFormat=F0}" />
                                            <Run Text="   End: " /><Run Text="{Binding RangeEnd, StringFormat=F0}" />
                                        </TextBlock>
                                    </StackPanel>

                                    <!-- IsMoveToPointEnabled -->
                                    <Grid Margin="0,0,0,14">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="点击移动" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <pf:RangeSlider Grid.Column="1" Minimum="0" Maximum="100"
                                                        ValueStart="20" ValueEnd="70"
                                                        IsMoveToPointEnabled="True" />
                                    </Grid>

                                    <!-- 带刻度 -->
                                    <Grid Margin="0,0,0,16">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="120" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="刻度对齐" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Center" />
                                        <pf:RangeSlider Grid.Column="1" Minimum="0" Maximum="100"
                                                        ValueStart="30" ValueEnd="80"
                                                        TickFrequency="10" TickPlacement="BottomRight"
                                                        IsSnapToTickEnabled="True" />
                                    </Grid>

                                    <!-- 垂直方向 -->
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="垂直方向" FontSize="12"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                                   VerticalAlignment="Top" Width="120" Margin="0,4,0,0" />
                                        <pf:RangeSlider Orientation="Vertical" Height="110"
                                                        Minimum="0" Maximum="100"
                                                        ValueStart="25" ValueEnd="75" Margin="0,0,20,0" />
                                        <pf:RangeSlider Orientation="Vertical" Height="110"
                                                        Minimum="0" Maximum="100"
                                                        ValueStart="40" ValueEnd="90"
                                                        TickFrequency="20" TickPlacement="BottomRight"
                                                        IsSnapToTickEnabled="True" />
                                    </StackPanel>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,14,0,0"
                                        Code="{x:Static vm:SlidersDemoViewModel.XamlRangeSlider}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 3. PreviewSlider ═══════════ -->
                    <Border x:Name="Section_PreviewSlider" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="3. PreviewSlider" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="PreviewContent — 鼠标悬停时在 Thumb 上方显示浮动气泡，绑定 PreviewPosition 附加属性"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,16" />

                                    <!-- 主色气泡 -->
                                    <TextBlock Text="主色气泡（显示悬停位置值）" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <pf:PreviewSlider Minimum="0" Maximum="100" Value="40" Margin="0,0,0,20">
                                        <pf:PreviewSlider.PreviewContent>
                                            <Border Background="{DynamicResource PrimaryBrush}"
                                                    CornerRadius="4" Padding="10,4">
                                                <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold"
                                                           Text="{Binding Path=(pf:PreviewSlider.PreviewPosition), RelativeSource={RelativeSource Self}, StringFormat=F0}" />
                                            </Border>
                                        </pf:PreviewSlider.PreviewContent>
                                    </pf:PreviewSlider>

                                    <!-- 成功色气泡（带百分号） -->
                                    <TextBlock Text="自定义气泡样式" FontSize="12" FontWeight="SemiBold"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,8" />
                                    <pf:PreviewSlider Minimum="0" Maximum="100" Value="65" Margin="0,0,0,6">
                                        <pf:PreviewSlider.PreviewContent>
                                            <Border CornerRadius="4" Padding="10,5"
                                                    Background="{DynamicResource DarkSuccessBrush}">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Foreground="White" FontSize="11" FontWeight="SemiBold"
                                                               Text="{Binding Path=(pf:PreviewSlider.PreviewPosition), RelativeSource={RelativeSource Self}, StringFormat=F0}" />
                                                    <TextBlock Foreground="White" FontSize="11" Text=" %" />
                                                </StackPanel>
                                            </Border>
                                        </pf:PreviewSlider.PreviewContent>
                                    </pf:PreviewSlider>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:SlidersDemoViewModel.XamlPreviewSlider}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                    <!-- ═══════════ 4. CompareSlider ═══════════ -->
                    <Border x:Name="Section_CompareSlider" Padding="0,4,0,4">
                        <StackPanel>
                            <TextBlock Text="4. CompareSlider" FontSize="16" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />
                            <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                    Padding="16,14" Margin="0,0,0,14"
                                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="SourceContent / TargetContent — 拖动 Thumb 在两侧内容之间切分显示"
                                               FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,14" />

                                    <!-- 色块对比 -->
                                    <pf:CompareSlider Minimum="0" Maximum="100" Value="50"
                                                      Height="140" Margin="0,0,0,14"
                                                      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <pf:CompareSlider.SourceContent>
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#FF1565C0" Offset="0" />
                                                        <GradientStop Color="#FF42A5F5" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <pf:PackIcon Kind="ImageOutline" Width="32" Height="32"
                                                                 Foreground="White" HorizontalAlignment="Center" />
                                                    <TextBlock Text="处理前" Foreground="White"
                                                               FontSize="15" FontWeight="Bold"
                                                               HorizontalAlignment="Center" Margin="0,6,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </pf:CompareSlider.SourceContent>
                                        <pf:CompareSlider.TargetContent>
                                            <Border>
                                                <Border.Background>
                                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                        <GradientStop Color="#FFE65100" Offset="0" />
                                                        <GradientStop Color="#FFFFA726" Offset="1" />
                                                    </LinearGradientBrush>
                                                </Border.Background>
                                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                                    <pf:PackIcon Kind="ImageFilterHdr" Width="32" Height="32"
                                                                 Foreground="White" HorizontalAlignment="Center" />
                                                    <TextBlock Text="处理后" Foreground="White"
                                                               FontSize="15" FontWeight="Bold"
                                                               HorizontalAlignment="Center" Margin="0,6,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </pf:CompareSlider.TargetContent>
                                    </pf:CompareSlider>

                                    <!-- 文字对比 -->
                                    <pf:CompareSlider Minimum="0" Maximum="100" Value="40"
                                                      Height="80" Margin="0,0,0,6"
                                                      BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                        <pf:CompareSlider.SourceContent>
                                            <Border Background="{DynamicResource PrimaryBrush}">
                                                <TextBlock Text="原始版本  v1.0" Foreground="White"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </pf:CompareSlider.SourceContent>
                                        <pf:CompareSlider.TargetContent>
                                            <Border Background="{DynamicResource DarkSuccessBrush}">
                                                <TextBlock Text="新版本  v2.0" Foreground="White"
                                                           FontSize="13" FontWeight="SemiBold"
                                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                        </pf:CompareSlider.TargetContent>
                                    </pf:CompareSlider>

                                    <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,10,0,0"
                                        Code="{x:Static vm:SlidersDemoViewModel.XamlCompareSlider}" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </Border>

                </StackPanel>
            </ScrollViewer>

            <!-- 右侧目录 -->
            <Border Grid.Column="1" Width="170"
                    Background="{DynamicResource RegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                    Padding="0,12,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" Padding="12,6,12,10"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                        <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                        <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                    <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                            Background="Transparent"
                                            MouseLeftButtonDown="TocItem_Click">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                        <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <MultiDataTrigger>
                                                        <MultiDataTrigger.Conditions>
                                                            <Condition Binding="{Binding IsActive}" Value="False" />
                                                            <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                        </MultiDataTrigger.Conditions>
                                                        <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                    </MultiDataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Title}" FontSize="12"
                                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                                            <TextBlock Text="{Binding Sub}" FontSize="10"
                                                       Foreground="{DynamicResource ThirdlyTextBrush}"
                                                       TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</UserControl>
