<UserControl x:Class="PF.UI.Views.Demos.DialogDemoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:prism="http://prismlibrary.com/"
             xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
             xmlns:controls="clr-namespace:PF.UI.Controls"
             xmlns:vm="clr-namespace:PF.UI.ViewModels.Demos"
             mc:Ignorable="d"
             d:DesignHeight="800" d:DesignWidth="820"
             d:DataContext="{d:DesignInstance vm:DialogDemoViewModel, IsDesignTimeCreatable=False}"
             prism:ViewModelLocator.AutoWireViewModel="True"
             Background="{DynamicResource BackgroundBrush}">

    <!--
        DialogOverlay 必须保留为根元素：
        它通过 WPF 路由命令拦截 CloseDialogCommand，
        若不在视觉树根，路由命令冒泡会中断。
    -->
    <pf:DialogOverlay Token="DemoDialog" CloseOnClickAway="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- 页头 -->
            <Border Grid.Row="0" Padding="24,14,24,12"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1"
                    Background="{DynamicResource RegionBrush}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <TextBlock Text="对话框" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" />
                        <TextBlock Text="DialogOverlay 页内遮罩  ·  Prism IDialogService 独立窗口"
                                   FontSize="12" Margin="0,4,0,0"
                                   Foreground="{DynamicResource SecondaryTextBrush}" />
                    </StackPanel>
                    <Border Grid.Column="1" MinWidth="200" MaxWidth="340"
                            CornerRadius="8" Padding="12,8"
                            Background="{DynamicResource SecondaryRegionBrush}"
                            VerticalAlignment="Center" Margin="20,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <pf:PackIcon Kind="Console" Width="14" Height="14"
                                         Foreground="{DynamicResource ThirdlyTextBrush}"
                                         VerticalAlignment="Center" Margin="0,0,8,0" />
                            <TextBlock Text="{Binding LastResult}" FontSize="11.5"
                                       Foreground="{DynamicResource SecondaryTextBrush}"
                                       FontFamily="Consolas" TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- 主体 -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="400" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ScrollViewer Grid.Column="0" x:Name="ContentScroll"
                              VerticalScrollBarVisibility="Auto"
                              ScrollChanged="ContentScroll_ScrollChanged">
                    <StackPanel Margin="24,16,16,24" MaxWidth="820">

                        <!-- ═══════════ 1. DialogOverlay 页内遮罩 ═══════════ -->
                        <Border x:Name="Section_Overlay" Padding="0,0,0,4">
                            <StackPanel>
                                <TextBlock Text="1. DialogOverlay 页内遮罩" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                                <!-- 卡片：基础弹窗类型 -->
                                <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                        Padding="16,14" Margin="0,0,0,12"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,14"
                                                   Text="对话框覆盖在当前页面视觉树上，通过 Token 定位目标 DialogOverlay，await 等待用户交互结果" />

                                        <!-- 基础 4 个 -->
                                        <TextBlock Text="基础弹窗类型" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                        <UniformGrid Columns="2" Margin="0,0,0,12">
                                            <Button Margin="0,0,6,6" Height="48"
                                                    Command="{Binding ShowInfoDialogCommand}"
                                                    Style="{StaticResource ButtonDefault}">
                                                <StackPanel Orientation="Horizontal">
                                                    <pf:PackIcon Kind="InformationOutline" Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                                 Foreground="{DynamicResource InfoBrush}" />
                                                    <TextBlock Text="信息" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Margin="6,0,0,6" Height="48"
                                                    Command="{Binding ShowConfirmDialogCommand}"
                                                    Style="{StaticResource ButtonDefault}">
                                                <StackPanel Orientation="Horizontal">
                                                    <pf:PackIcon Kind="AlertOutline" Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                                 Foreground="{DynamicResource WarningBrush}" />
                                                    <TextBlock Text="确认（OK / 取消）" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Margin="0,0,6,0" Height="48"
                                                    Command="{Binding ShowSuccessDialogCommand}"
                                                    Style="{StaticResource ButtonDefault}">
                                                <StackPanel Orientation="Horizontal">
                                                    <pf:PackIcon Kind="CheckCircleOutline" Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                                 Foreground="{DynamicResource SuccessBrush}" />
                                                    <TextBlock Text="成功" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Margin="6,0,0,0" Height="48"
                                                    Command="{Binding ShowErrorDialogCommand}"
                                                    Style="{StaticResource ButtonDefault}">
                                                <StackPanel Orientation="Horizontal">
                                                    <pf:PackIcon Kind="AlertCircleOutline" Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                                 Foreground="{DynamicResource DangerBrush}" />
                                                    <TextBlock Text="错误" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </UniformGrid>

                                        <Separator Margin="0,4,0,12" />

                                        <!-- 高级用法 -->
                                        <TextBlock Text="高级用法" FontSize="12" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,10" />
                                        <UniformGrid Columns="2">
                                            <Button Margin="0,0,6,0" Height="48"
                                                    Command="{Binding ShowWaitDialogCommand}"
                                                    Style="{StaticResource ButtonDefault}">
                                                <StackPanel Orientation="Horizontal">
                                                    <pf:PackIcon Kind="TimerSandEmpty" Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                                 Foreground="{DynamicResource PrimaryBrush}" />
                                                    <TextBlock Text="等待（3秒自动关闭）" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Margin="6,0,0,0" Height="48"
                                                    Command="{Binding ShowClickAwayDialogCommand}"
                                                    Style="{StaticResource ButtonDefault}">
                                                <StackPanel Orientation="Horizontal">
                                                    <pf:PackIcon Kind="CursorDefaultClickOutline" Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                                 Foreground="{DynamicResource AccentBrush}" />
                                                    <TextBlock Text="点击遮罩关闭" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </UniformGrid>

                                        <controls:DemoCodeBlock CodeLanguage="XAML" Margin="0,14,0,4"
                                            Code="{x:Static vm:DialogDemoViewModel.XamlOverlayDecl}" />
                                        <controls:DemoCodeBlock CodeLanguage="C#" Margin="0,8,0,0"
                                            Code="{x:Static vm:DialogDemoViewModel.XamlOverlayCs}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                        <!-- ═══════════ 2. Prism IDialogService ═══════════ -->
                        <Border x:Name="Section_Prism" Padding="0,4,0,4">
                            <StackPanel>
                                <TextBlock Text="2. Prism IDialogService 独立窗口" FontSize="16" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextBrush}" Margin="0,0,0,12" />

                                <Border Background="{DynamicResource RegionBrush}" CornerRadius="10"
                                        Padding="16,14" Margin="0,0,0,14"
                                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                                    <StackPanel>
                                        <TextBlock FontSize="11" Foreground="{DynamicResource ThirdlyTextBrush}" Margin="0,0,0,14"
                                                   Text="通过 IDialogService 打开独立 WPF 窗口，PFDialogWindow 继承 pf:Window（自定义标题栏 + CubicEase 弹出动画）" />

                                        <!-- 对比表格 -->
                                        <Border Background="{DynamicResource SecondaryRegionBrush}" CornerRadius="6"
                                                Padding="12,10" Margin="0,0,0,14">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>

                                                <!-- 表头 -->
                                                <TextBlock Grid.Row="0" Grid.Column="0" Text="DialogOverlay"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="{DynamicResource PrimaryBrush}" Margin="0,0,0,6" />
                                                <TextBlock Grid.Row="0" Grid.Column="1" Text="IDialogService"
                                                           FontSize="11" FontWeight="Bold"
                                                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,0,6" />

                                                <TextBlock Grid.Row="1" Grid.Column="0" FontSize="10.5"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="同页面视觉树（遮罩覆盖）" Margin="0,2" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" FontSize="10.5"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="独立 WPF 窗口" Margin="0,2" />

                                                <TextBlock Grid.Row="2" Grid.Column="0" FontSize="10.5"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="await Task&lt;object?&gt;" Margin="0,2" />
                                                <TextBlock Grid.Row="2" Grid.Column="1" FontSize="10.5"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="Action&lt;IDialogResult&gt; 回调" Margin="0,2" />

                                                <TextBlock Grid.Row="3" Grid.Column="0" FontSize="10.5"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="适合简单确认 / 提示" Margin="0,2" />
                                                <TextBlock Grid.Row="3" Grid.Column="1" FontSize="10.5"
                                                           Foreground="{DynamicResource SecondaryTextBrush}"
                                                           Text="适合复杂功能 / 隔离 VM" Margin="0,2" />
                                            </Grid>
                                        </Border>

                                        <!-- 按钮 -->
                                        <UniformGrid Columns="2" Margin="0,0,0,14">
                                            <Button Margin="0,0,6,0" Height="48"
                                                    Command="{Binding ShowPrismConfirmCommand}"
                                                    Style="{StaticResource ButtonDefault}">
                                                <StackPanel Orientation="Horizontal">
                                                    <pf:PackIcon Kind="AlertOutline" Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                                 Foreground="{DynamicResource WarningBrush}" />
                                                    <TextBlock Text="确认弹窗（警告）" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                            <Button Margin="6,0,0,0" Height="48"
                                                    Command="{Binding ShowPrismCustomCommand}"
                                                    Style="{StaticResource ButtonDefault}">
                                                <StackPanel Orientation="Horizontal">
                                                    <pf:PackIcon Kind="TrashCanOutline" Width="16" Height="16"
                                                                 VerticalAlignment="Center" Margin="0,0,8,0"
                                                                 Foreground="{DynamicResource DangerBrush}" />
                                                    <TextBlock Text="删除确认（危险）" VerticalAlignment="Center" />
                                                </StackPanel>
                                            </Button>
                                        </UniformGrid>

                                        <controls:DemoCodeBlock CodeLanguage="C#" Margin="0,0,0,8"
                                            Code="{x:Static vm:DialogDemoViewModel.XamlPrismReg}" />
                                        <controls:DemoCodeBlock CodeLanguage="C#" Margin="0,0,0,8"
                                            Code="{x:Static vm:DialogDemoViewModel.XamlPrismCall}" />
                                        <controls:DemoCodeBlock CodeLanguage="C#" Margin="0,0,0,0"
                                            Code="{x:Static vm:DialogDemoViewModel.XamlPrismVm}" />
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- 右侧目录 -->
                <Border Grid.Column="1" Width="170"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1,0,0,0"
                        Padding="0,12,0,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Border Grid.Row="0" Padding="12,6,12,10"
                                BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,0,0,1">
                            <TextBlock Text="📑 目录" FontSize="12" FontWeight="Bold"
                                       Foreground="{DynamicResource PrimaryTextBrush}" />
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                            <ItemsControl ItemsSource="{Binding TocItems}" Margin="4,6,4,20">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:DemoTocItem}">
                                        <Border Padding="10,6" CornerRadius="5" Cursor="Hand"
                                                Background="Transparent"
                                                MouseLeftButtonDown="TocItem_Click">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource LightPrimaryBrush}" />
                                                        </DataTrigger>
                                                        <MultiDataTrigger>
                                                            <MultiDataTrigger.Conditions>
                                                                <Condition Binding="{Binding IsActive}" Value="False" />
                                                                <Condition Binding="{Binding IsMouseOver, RelativeSource={RelativeSource Self}}" Value="True" />
                                                            </MultiDataTrigger.Conditions>
                                                            <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}" />
                                                        </MultiDataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <TextBlock Text="{Binding Title}" FontSize="12"
                                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                                <TextBlock Text="{Binding Sub}" FontSize="10"
                                                           Foreground="{DynamicResource ThirdlyTextBrush}"
                                                           TextTrimming="CharacterEllipsis" Margin="0,2,0,0" />
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </pf:DialogOverlay>
</UserControl>
