<pf:Window x:Class="PF.UI.Views.MainWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:prism="http://prismlibrary.com/"
           xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
           prism:ViewModelLocator.AutoWireViewModel="True"
           Title="PF.UI 控件演示"
           Height="720" Width="1100"
           MinHeight="500" MinWidth="800"
           WindowStartupLocation="CenterScreen"
           ShowNonClientArea="True"
           Background="{DynamicResource BackgroundBrush}">

    <pf:DrawerContainer>
        <Grid>
            <!-- ===== 抽屉侧边栏 ===== -->
            <pf:Drawer x:Name="NavDrawer"
                       Dock="Left"
                       ShowMode="Cover"
                       IsOpen="True"
                       ShowMask="True"
                       MaskCanClose="True"
                       MaskBrush="#40000000"
                       Opened="NavDrawer_Opened"
                       Closed="NavDrawer_Closed">
                <Grid Width="auto"
                      Background="{DynamicResource RegionBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Logo + 搜索区 -->
                    <Border Grid.Row="0"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <Grid Margin="16,14,16,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <!-- Logo 行 -->
                            <StackPanel Orientation="Horizontal">
                                <Border Width="34" Height="34" CornerRadius="8"
                                        Background="{DynamicResource PrimaryBrush}">
                                    <pf:PackIcon Kind="CubeOutline" Width="20" Height="20"
                                                 Foreground="White"
                                                 HorizontalAlignment="Center"
                                                 VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                    <TextBlock Text="PF.UI" FontSize="14" FontWeight="Bold"
                                               Foreground="{DynamicResource PrimaryTextBrush}" />
                                    <TextBlock Text="控件演示库" FontSize="10"
                                               Foreground="{DynamicResource ThirdlyTextBrush}" />
                                </StackPanel>
                            </StackPanel>
                            <!-- 搜索栏 -->
                            <pf:SearchBar x:Name="NavSearchBar"
                                          Grid.Row="1"
                                          Margin="0,10,0,0"
                                          pf:InfoElement.Placeholder="搜索导航..."
                                          IsRealTime="True"
                                          TextChanged="NavSearchBar_TextChanged" />
                        </Grid>
                    </Border>

                    <!-- 导航菜单（SideMenuItem 树由代码后台从 NavGroups 构建） -->
                    <pf:SideMenu x:Name="NavMenu"
                                 Grid.Row="1"
                                 Width="240"
                                 AutoSelect="False"
                                 ExpandMode="Freedom"
                                 SelectedItem="{Binding SelectedItem, Mode=TwoWay}" />

                    <!-- 底部版本 -->
                    <Border Grid.Row="2" Padding="14,8"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <TextBlock Text="v1.0.0 — net8.0-windows"
                                   FontSize="9.5"
                                   Foreground="{DynamicResource ThirdlyTextBrush}" />
                    </Border>
                </Grid>
            </pf:Drawer>

                <!-- ===== 主内容区 ===== -->
            <Grid x:Name="RootGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 顶栏：汉堡按钮 + 标题 + 主题切换 -->
                <Border Grid.Row="0" Height="48"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <!-- 汉堡按钮 -->
                        <Button x:Name="HamburgerBtn"
                                Width="40" Height="40"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="HamburgerBtn_Click"
                                ToolTip="展开/折叠侧边栏">
                            <pf:PackIcon x:Name="HamburgerIcon"
                                         Kind="Menu"
                                         Width="20" Height="20"
                                         Foreground="{DynamicResource PrimaryTextBrush}" />
                        </Button>

                        <!-- 标题 -->
                        <TextBlock Text="PF.UI 控件演示"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />

                        <!-- 主题切换按钮（涟漪按钮 + 扩散全屏）-->
                        <Button x:Name="ThemeBtn"
                                Width="36" Height="36"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="ToggleThemeBtn_Click"
                                ToolTip="切换深色/浅色主题">
                            <pf:Ripple pf:RippleAssist.IsCentered="True"
                                       HorizontalContentAlignment="Center"
                                       VerticalContentAlignment="Center">
                                <pf:PackIcon x:Name="ThemeIcon"
                                             Kind="WeatherNight"
                                             Width="20" Height="20"
                                             Foreground="{DynamicResource PrimaryTextBrush}" />
                            </pf:Ripple>
                        </Button>
                    </Grid>
                </Border>

                <!-- Prism Region -->
                <ContentControl Grid.Row="1"
                                prism:RegionManager.RegionName="DemoRegion" />

                <!-- 主题切换全屏覆盖层（扩散涟漪揭示）-->
                <Rectangle x:Name="ThemeOverlay"
                           Grid.RowSpan="2"
                           Visibility="Collapsed"
                           IsHitTestVisible="False"
                           Panel.ZIndex="100" />
            </Grid>
        </Grid>
    </pf:DrawerContainer>
</pf:Window>
