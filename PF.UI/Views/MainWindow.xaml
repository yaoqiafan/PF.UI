<pf:Window x:Class="PF.UI.Views.MainWindow"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:prism="http://prismlibrary.com/"
           xmlns:pf="clr-namespace:PF.UI.Controls;assembly=PF.UI.Controls"
           xmlns:controls="clr-namespace:PF.UI.Controls"
           prism:ViewModelLocator.AutoWireViewModel="True"
           Title="PF.UI 控件演示"
           Height="720" Width="1100"
           MinHeight="500" MinWidth="800"
           WindowStartupLocation="CenterScreen"
           ShowNonClientArea="True"
           Background="{DynamicResource BackgroundBrush}">

    <pf:DrawerContainer>
        <Grid>
            <!-- ===== 抽屉侧边栏 ===== -->
            <pf:Drawer x:Name="NavDrawer"
                       Dock="Left"
                       ShowMode="Push"
                       IsOpen="True"
                       ShowMask="True"
                       MaskCanClose="True"
                       MaskBrush="#40000000"
                       Opened="NavDrawer_Opened"
                       Closed="NavDrawer_Closed">
                <Grid Width="240"
                      Background="{DynamicResource RegionBrush}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Logo 区 -->
                    <Border Grid.Row="0"
                            Padding="16,18,16,14"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,0,0,1">
                        <StackPanel Orientation="Horizontal">
                            <Border Width="34" Height="34" CornerRadius="8"
                                    Background="{DynamicResource PrimaryBrush}">
                                <pf:PackIcon Kind="CubeOutline" Width="20" Height="20"
                                             Foreground="White"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                            </Border>
                            <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                <TextBlock Text="PF.UI" FontSize="14" FontWeight="Bold"
                                           Foreground="{DynamicResource PrimaryTextBrush}" />
                                <TextBlock Text="控件演示库" FontSize="10"
                                           Foreground="{DynamicResource ThirdlyTextBrush}" />
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- 导航树 -->
                    <controls:SidebarNavView Grid.Row="1"
                                             x:Name="SidebarNav"
                                             Groups="{Binding NavGroups}"
                                             SelectedItem="{Binding SelectedItem, Mode=TwoWay}" />

                    <!-- 底部版本 -->
                    <Border Grid.Row="2" Padding="14,8"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="0,1,0,0">
                        <TextBlock Text="v1.0.0 — net8.0-windows"
                                   FontSize="9.5"
                                   Foreground="{DynamicResource ThirdlyTextBrush}" />
                    </Border>
                </Grid>
            </pf:Drawer>

            <!-- ===== 主内容区 ===== -->
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- 顶栏：汉堡按钮 + 标题 -->
                <Border Grid.Row="0" Height="48"
                        Background="{DynamicResource RegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,0,1">
                    <Grid>
                        <!-- 汉堡按钮 -->
                        <Button x:Name="HamburgerBtn"
                                Width="40" Height="40"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                Margin="8,0,0,0"
                                Background="Transparent"
                                BorderThickness="0"
                                Cursor="Hand"
                                Click="HamburgerBtn_Click"
                                ToolTip="展开/折叠侧边栏">
                            <pf:PackIcon x:Name="HamburgerIcon"
                                         Kind="Menu"
                                         Width="20" Height="20"
                                         Foreground="{DynamicResource PrimaryTextBrush}" />
                        </Button>

                        <!-- 标题 -->
                        <TextBlock Text="PF.UI 控件演示"
                                   FontSize="14" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Grid>
                </Border>

                <!-- Prism Region -->
                <ContentControl Grid.Row="1"
                                prism:RegionManager.RegionName="DemoRegion" />
            </Grid>
        </Grid>
    </pf:DrawerContainer>
</pf:Window>
